---
import Base from "../../layouts/Base.astro";
---
<Base
  title="Academy — TrainedBy"
  description="Sports academy profile on TrainedBy"
>
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --orange:#FF5C00;
  --orange-dim:rgba(255,92,0,0.15);
  --green:#22c55e;
  --green-dim:rgba(34,197,94,0.15);
  --blue:#3b82f6;
  --white:#ffffff;
  --white-80:rgba(255,255,255,0.8);
  --white-60:rgba(255,255,255,0.6);
  --white-30:rgba(255,255,255,0.3);
  --white-10:rgba(255,255,255,0.1);
  --white-06:rgba(255,255,255,0.06);
  --glass:rgba(10,10,10,0.55);
  --glass-border:rgba(255,255,255,0.12);
  --radius:16px;
  --radius-sm:10px;
  --font:'Manrope',sans-serif;
}
html,body{height:100%;width:100%;overflow-x:hidden}
body{font-family:var(--font);background:#0a0a0a;color:var(--white);-webkit-font-smoothing:antialiased}

/* ── HERO ── */
#hero{
  position:relative;min-height:55vh;display:flex;align-items:flex-end;
  padding:0 20px 32px;overflow:hidden;
}
#hero-bg{
  position:absolute;inset:0;background:#111;
  background-size:cover;background-position:center;
  transition:opacity 0.4s;
}
#hero-bg::after{
  content:'';position:absolute;inset:0;
  background:linear-gradient(to bottom,rgba(0,0,0,0.2) 0%,rgba(0,0,0,0.85) 100%);
}
.hero-content{position:relative;z-index:1;width:100%;max-width:680px;margin:0 auto}
.academy-badge{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--orange-dim);border:1px solid var(--orange);
  color:var(--orange);font-size:11px;font-weight:700;letter-spacing:0.08em;
  text-transform:uppercase;padding:4px 10px;border-radius:20px;margin-bottom:12px;
}
.academy-name{font-size:clamp(28px,6vw,48px);font-weight:800;line-height:1.1;margin-bottom:8px}
.academy-meta{display:flex;flex-wrap:wrap;gap:10px;align-items:center;margin-top:10px}
.meta-pill{
  display:inline-flex;align-items:center;gap:5px;
  background:rgba(255,255,255,0.1);border:1px solid var(--glass-border);
  color:var(--white-80);font-size:12px;font-weight:500;
  padding:5px 12px;border-radius:20px;backdrop-filter:blur(8px);
}
.verified-badge{
  display:inline-flex;align-items:center;gap:5px;
  background:var(--green-dim);border:1px solid var(--green);
  color:var(--green);font-size:11px;font-weight:700;
  padding:4px 10px;border-radius:20px;
}

/* ── TOPBAR ── */
#topbar{
  position:fixed;top:0;left:0;right:0;z-index:100;
  display:flex;align-items:center;justify-content:space-between;
  padding:max(env(safe-area-inset-top),16px) 20px 12px;
  background:linear-gradient(to bottom,rgba(0,0,0,0.7),transparent);
  pointer-events:none;
}
#topbar a,#topbar button{pointer-events:all}
.tb-logo{font-size:13px;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--white-60);text-decoration:none}
.tb-cta{
  background:rgba(255,255,255,0.12);border:1px solid var(--glass-border);
  color:var(--white);font-size:12px;font-weight:600;
  padding:7px 14px;border-radius:20px;text-decoration:none;
  backdrop-filter:blur(12px);
}

/* ── MAIN CONTENT ── */
#main{max-width:680px;margin:0 auto;padding:0 20px 100px}

/* ── SECTION HEADER ── */
.section-header{
  display:flex;align-items:center;justify-content:space-between;
  margin:32px 0 16px;
}
.section-title{font-size:18px;font-weight:700}
.section-count{font-size:13px;color:var(--white-60)}

/* ── PROGRAMS GRID ── */
.programs-grid{display:flex;flex-direction:column;gap:12px}
.program-card{
  background:var(--white-06);border:1px solid var(--glass-border);
  border-radius:var(--radius);padding:20px;
  transition:border-color 0.2s,background 0.2s;cursor:pointer;
  position:relative;overflow:hidden;
}
.program-card:hover{border-color:var(--orange);background:rgba(255,92,0,0.05)}
.program-card.featured{border-color:rgba(255,92,0,0.4)}
.featured-tag{
  position:absolute;top:12px;right:12px;
  background:var(--orange);color:#fff;font-size:10px;font-weight:700;
  letter-spacing:0.06em;text-transform:uppercase;padding:3px 8px;border-radius:10px;
}
.prog-sport{
  font-size:11px;font-weight:700;letter-spacing:0.08em;text-transform:uppercase;
  color:var(--orange);margin-bottom:6px;
}
.prog-name{font-size:17px;font-weight:700;margin-bottom:4px}
.prog-age{font-size:13px;color:var(--white-60);margin-bottom:12px}
.prog-desc{font-size:13px;color:var(--white-60);line-height:1.5;margin-bottom:14px}
.prog-meta{display:flex;flex-wrap:wrap;gap:8px;margin-bottom:16px}
.prog-meta-item{
  display:flex;align-items:center;gap:4px;
  font-size:12px;color:var(--white-60);
}
.prog-footer{display:flex;align-items:center;justify-content:space-between}
.prog-price{font-size:22px;font-weight:800;color:var(--white)}
.prog-price span{font-size:13px;font-weight:500;color:var(--white-60)}
.prog-capacity{font-size:12px;color:var(--white-60)}
.prog-capacity.full{color:#ef4444}
.prog-capacity.almost{color:#f59e0b}
.btn-enrol{
  background:var(--orange);color:#fff;font-size:14px;font-weight:700;
  border:none;padding:10px 20px;border-radius:10px;cursor:pointer;
  transition:opacity 0.2s;flex-shrink:0;
}
.btn-enrol:hover{opacity:0.9}
.btn-enrol:disabled{background:#444;cursor:not-allowed;opacity:0.5}

/* ── COACHES ── */
.coaches-row{display:flex;gap:12px;overflow-x:auto;padding-bottom:4px;scrollbar-width:none}
.coaches-row::-webkit-scrollbar{display:none}
.coach-card{
  flex-shrink:0;width:140px;
  background:var(--white-06);border:1px solid var(--glass-border);
  border-radius:var(--radius-sm);padding:16px 12px;text-align:center;
}
.coach-avatar{
  width:60px;height:60px;border-radius:50%;object-fit:cover;
  margin:0 auto 10px;display:block;background:#222;
  border:2px solid var(--glass-border);
}
.coach-name{font-size:13px;font-weight:700;margin-bottom:2px}
.coach-role{font-size:11px;color:var(--orange);font-weight:600;text-transform:capitalize}

/* ── ABOUT ── */
.about-card{
  background:var(--white-06);border:1px solid var(--glass-border);
  border-radius:var(--radius);padding:20px;margin-top:8px;
}
.about-text{font-size:14px;color:var(--white-80);line-height:1.7}
.contact-row{display:flex;flex-wrap:wrap;gap:10px;margin-top:16px}
.contact-btn{
  display:inline-flex;align-items:center;gap:6px;
  background:var(--white-10);border:1px solid var(--glass-border);
  color:var(--white);font-size:13px;font-weight:600;
  padding:9px 16px;border-radius:10px;text-decoration:none;
  transition:background 0.2s;
}
.contact-btn:hover{background:rgba(255,255,255,0.15)}
.contact-btn.wa{background:rgba(37,211,102,0.15);border-color:rgba(37,211,102,0.4);color:#25d366}

/* ── BOOKING MODAL ── */
#bookModal{
  display:none;position:fixed;inset:0;z-index:200;
  background:rgba(0,0,0,0.85);backdrop-filter:blur(8px);
  align-items:flex-end;justify-content:center;
}
#bookModal.open{display:flex}
.modal-sheet{
  background:#111;border:1px solid var(--glass-border);
  border-radius:24px 24px 0 0;width:100%;max-width:520px;
  padding:28px 24px max(env(safe-area-inset-bottom),24px);
  max-height:90vh;overflow-y:auto;
}
.modal-handle{width:40px;height:4px;background:var(--white-30);border-radius:2px;margin:0 auto 20px}
.modal-title{font-size:20px;font-weight:800;margin-bottom:4px}
.modal-subtitle{font-size:13px;color:var(--white-60);margin-bottom:20px}
.form-group{margin-bottom:14px}
.form-label{font-size:12px;font-weight:600;color:var(--white-60);margin-bottom:5px;display:block;text-transform:uppercase;letter-spacing:0.06em}
.form-input{
  width:100%;background:var(--white-06);border:1px solid var(--glass-border);
  color:var(--white);font-size:15px;padding:12px 14px;border-radius:10px;
  font-family:var(--font);outline:none;
  transition:border-color 0.2s;
}
.form-input:focus{border-color:var(--orange)}
.form-row{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.btn-pay{
  width:100%;background:var(--orange);color:#fff;font-size:16px;font-weight:700;
  border:none;padding:16px;border-radius:12px;cursor:pointer;margin-top:8px;
  transition:opacity 0.2s;display:flex;align-items:center;justify-content:center;gap:8px;
}
.btn-pay:hover{opacity:0.9}
.btn-pay:disabled{opacity:0.5;cursor:not-allowed}
.modal-close{
  position:absolute;top:20px;right:20px;
  width:32px;height:32px;border-radius:50%;
  background:var(--white-10);border:none;color:var(--white);
  font-size:18px;cursor:pointer;display:flex;align-items:center;justify-content:center;
}
.modal-wrap{position:relative}
.security-note{
  display:flex;align-items:center;gap:6px;
  font-size:11px;color:var(--white-60);margin-top:10px;justify-content:center;
}

/* ── LOADING / EMPTY ── */
.skeleton{background:var(--white-06);border-radius:var(--radius);animation:pulse 1.5s infinite}
@keyframes pulse{0%,100%{opacity:0.5}50%{opacity:1}}
.empty-state{text-align:center;padding:40px 20px;color:var(--white-60)}
.empty-icon{font-size:40px;margin-bottom:12px}

/* ── STICKY CTA ── */
#sticky-cta{
  position:fixed;bottom:0;left:0;right:0;z-index:50;
  padding:12px 20px max(env(safe-area-inset-bottom),16px);
  background:linear-gradient(to top,rgba(0,0,0,0.95),transparent);
  display:none;
}
#sticky-cta.show{display:block}
.sticky-btn{
  width:100%;max-width:480px;margin:0 auto;display:block;
  background:var(--orange);color:#fff;font-size:16px;font-weight:700;
  border:none;padding:16px;border-radius:14px;cursor:pointer;
  box-shadow:0 8px 24px rgba(255,92,0,0.4);
}
</style>

<!-- TOPBAR -->
<div id="topbar">
  <a href="/" class="tb-logo">TrainedBy</a>
  <a href="/find" class="tb-cta">Find Trainers</a>
</div>

<!-- HERO -->
<div id="hero">
  <div id="hero-bg"></div>
  <div class="hero-content">
    <div id="hero-badge" class="academy-badge">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
      <span id="hero-sport">Academy</span>
    </div>
    <h1 class="academy-name" id="hero-name">Loading...</h1>
    <div class="academy-meta" id="hero-meta"></div>
  </div>
</div>

<!-- MAIN -->
<div id="main">

  <!-- PROGRAMMES -->
  <div class="section-header">
    <div class="section-title">Programmes</div>
    <div class="section-count" id="prog-count"></div>
  </div>
  <div class="programs-grid" id="programs-grid">
    <div class="skeleton" style="height:160px"></div>
    <div class="skeleton" style="height:160px"></div>
  </div>

  <!-- COACHES -->
  <div class="section-header" id="coaches-section" style="display:none">
    <div class="section-title">Coaching Staff</div>
  </div>
  <div class="coaches-row" id="coaches-row"></div>

  <!-- ABOUT -->
  <div class="section-header">
    <div class="section-title">About</div>
  </div>
  <div class="about-card">
    <p class="about-text" id="about-text">Loading...</p>
    <div class="contact-row" id="contact-row"></div>
  </div>

</div>

<!-- STICKY CTA -->
<div id="sticky-cta">
  <button class="sticky-btn" onclick="scrollToPrograms()">View Programmes & Enrol →</button>
</div>

<!-- BOOKING MODAL -->
<div id="bookModal" onclick="if(event.target===this)closeModal()">
  <div class="modal-sheet modal-wrap">
    <button class="modal-close" onclick="closeModal()">×</button>
    <div class="modal-handle"></div>
    <div class="modal-title" id="modal-prog-name">Enrol Now</div>
    <div class="modal-subtitle" id="modal-prog-meta"></div>

    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Your Name</label>
        <input class="form-input" id="parentName" placeholder="Ahmed Al Rashidi" type="text">
      </div>
      <div class="form-group">
        <label class="form-label">Phone / WhatsApp</label>
        <input class="form-input" id="parentPhone" placeholder="+971 50 000 0000" type="tel">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Email Address</label>
      <input class="form-input" id="parentEmail" placeholder="ahmed@email.com" type="email">
    </div>
    <div class="form-row">
      <div class="form-group">
        <label class="form-label">Child's Name</label>
        <input class="form-input" id="childName" placeholder="Omar" type="text">
      </div>
      <div class="form-group">
        <label class="form-label">Child's Age</label>
        <input class="form-input" id="childDob" placeholder="e.g. 9" type="number" min="3" max="25">
      </div>
    </div>
    <div class="form-group">
      <label class="form-label">Any notes? (injuries, experience, etc.)</label>
      <input class="form-input" id="childNotes" placeholder="Optional" type="text">
    </div>

    <button class="btn-pay" id="payBtn" onclick="submitBooking()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><rect x="1" y="4" width="22" height="16" rx="2"/><line x1="1" y1="10" x2="23" y2="10"/></svg>
      <span id="payBtnText">Pay & Enrol</span>
    </button>
    <div class="security-note">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
      Secure payment via Stripe · Apple Pay accepted
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = "https://mezhtdbfyvkshpuplqqw.supabase.co";
const SUPABASE_ANON = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;
const FN = `${SUPABASE_URL}/functions/v1`;

let ACADEMY = null;
let PROGRAMS = [];
let selectedProgramId = null;

async function loadAcademy() {
  const slug = window.location.pathname.split("/academy/")[1]?.replace(/\/$/, "");
  if (!slug) return;

  try {
    const res = await fetch(`${FN}/get-academy?slug=${encodeURIComponent(slug)}`, {
      headers: { "apikey": SUPABASE_ANON }
    });
    if (!res.ok) { renderError(); return; }
    const data = await res.json();
    ACADEMY = data.academy;
    PROGRAMS = data.programs || [];
    renderAcademy(data);
  } catch(e) {
    console.error(e);
    renderError();
  }
}

function renderAcademy({ academy, programs, coaches }) {
  // Update page title
  document.title = `${academy.name} — TrainedBy`;

  // Hero
  if (academy.cover_url) {
    document.getElementById("hero-bg").style.backgroundImage = `url('${academy.cover_url}')`;
  } else {
    // Default sport backgrounds
    const sportBgs = {
      football: "https://images.unsplash.com/photo-1574629810360-7efbbe195018?w=1200&q=80",
      basketball: "https://images.unsplash.com/photo-1546519638-68e109498ffc?w=1200&q=80",
      tennis: "https://images.unsplash.com/photo-1554068865-24cecd4e34b8?w=1200&q=80",
      swimming: "https://images.unsplash.com/photo-1530549387789-4c1017266635?w=1200&q=80",
      default: "https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=1200&q=80",
    };
    const bg = sportBgs[academy.sport?.toLowerCase()] || sportBgs.default;
    document.getElementById("hero-bg").style.backgroundImage = `url('${bg}')`;
  }

  document.getElementById("hero-sport").textContent = academy.sport || "Academy";
  document.getElementById("hero-name").textContent = academy.name;

  // Meta pills
  const meta = document.getElementById("hero-meta");
  const pills = [];
  if (academy.city) pills.push(`📍 ${academy.city}`);
  if (academy.verified) pills.push(`<span class="verified-badge">✓ Verified</span>`);
  if (programs.length) pills.push(`<span class="meta-pill">${programs.length} Programme${programs.length > 1 ? "s" : ""}</span>`);
  meta.innerHTML = pills.map(p => p.startsWith("<") ? p : `<span class="meta-pill">${p}</span>`).join("");

  // Programs
  renderPrograms(programs);

  // Coaches
  if (coaches && coaches.length > 0) {
    document.getElementById("coaches-section").style.display = "flex";
    renderCoaches(coaches);
  }

  // About
  document.getElementById("about-text").textContent = academy.description || `${academy.name} is a leading sports academy in ${academy.city || "Dubai"}, offering world-class coaching programmes for all ages and abilities.`;

  const contactRow = document.getElementById("contact-row");
  const contacts = [];
  if (academy.whatsapp) {
    contacts.push(`<a href="https://wa.me/${academy.whatsapp.replace(/\D/g,'')}" class="contact-btn wa" target="_blank">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      WhatsApp
    </a>`);
  }
  if (academy.contact_phone) {
    contacts.push(`<a href="tel:${academy.contact_phone}" class="contact-btn">📞 Call</a>`);
  }
  if (academy.instagram_url) {
    contacts.push(`<a href="${academy.instagram_url}" class="contact-btn" target="_blank">📸 Instagram</a>`);
  }
  if (academy.website_url) {
    contacts.push(`<a href="${academy.website_url}" class="contact-btn" target="_blank">🌐 Website</a>`);
  }
  contactRow.innerHTML = contacts.join("");

  // Show sticky CTA after scroll
  setTimeout(() => document.getElementById("sticky-cta").classList.add("show"), 2000);
}

function renderPrograms(programs) {
  const grid = document.getElementById("programs-grid");
  const count = document.getElementById("prog-count");

  if (!programs || programs.length === 0) {
    grid.innerHTML = `<div class="empty-state"><div class="empty-icon">📋</div><p>No active programmes right now.<br>Check back soon.</p></div>`;
    return;
  }

  count.textContent = `${programs.length} available`;
  grid.innerHTML = programs.map(p => {
    const spotsLeft = p.max_capacity - (p.enrolled_count || 0);
    const isFull = spotsLeft <= 0;
    const isAlmost = spotsLeft <= 3 && !isFull;
    const price = p.currency === "GBP" ? `£${p.price_gbp}` : `AED ${p.price_aed}`;
    const typeLabel = { term: "Term", holiday_camp: "Holiday Camp", drop_in: "Drop-In", private: "Private", trial: "Trial" }[p.program_type] || p.program_type;

    return `<div class="program-card${p.is_featured ? " featured" : ""}" onclick="openBooking('${p.id}')">
      ${p.is_featured ? `<div class="featured-tag">⭐ Featured</div>` : ""}
      <div class="prog-sport">${p.sport} · ${typeLabel}</div>
      <div class="prog-name">${p.name}</div>
      ${p.age_label ? `<div class="prog-age">Ages: ${p.age_label}</div>` : ""}
      ${p.description ? `<div class="prog-desc">${p.description}</div>` : ""}
      <div class="prog-meta">
        ${p.sessions_per_week ? `<span class="prog-meta-item">📅 ${p.sessions_per_week}x/week</span>` : ""}
        ${p.duration_weeks ? `<span class="prog-meta-item">⏱ ${p.duration_weeks} weeks</span>` : ""}
        ${p.start_date ? `<span class="prog-meta-item">🗓 Starts ${new Date(p.start_date).toLocaleDateString("en-GB",{day:"numeric",month:"short"})}</span>` : ""}
        ${p.location ? `<span class="prog-meta-item">📍 ${p.location}</span>` : ""}
      </div>
      <div class="prog-footer">
        <div>
          <div class="prog-price">${price}<span> / term</span></div>
          <div class="prog-capacity${isFull ? " full" : isAlmost ? " almost" : ""}">
            ${isFull ? "Fully booked" : isAlmost ? `Only ${spotsLeft} spots left!` : `${spotsLeft} of ${p.max_capacity} spots available`}
          </div>
        </div>
        <button class="btn-enrol" ${isFull ? "disabled" : ""} onclick="event.stopPropagation();openBooking('${p.id}')">
          ${isFull ? "Full" : "Enrol →"}
        </button>
      </div>
    </div>`;
  }).join("");
}

function renderCoaches(coaches) {
  const row = document.getElementById("coaches-row");
  row.innerHTML = coaches.map(c => {
    const trainer = c.trainers;
    const photo = c.photo_url || trainer?.photo_url || `https://ui-avatars.com/api/?name=${encodeURIComponent(c.name || "Coach")}&background=1a1a2e&color=ff5c00&size=120`;
    const name = c.name || trainer?.name || "Coach";
    const profileLink = trainer?.slug ? `/profile/${trainer.slug}` : null;
    return `<div class="coach-card">
      <img class="coach-avatar" src="${photo}" alt="${name}" loading="lazy">
      <div class="coach-name">${profileLink ? `<a href="${profileLink}" style="color:inherit;text-decoration:none">${name}</a>` : name}</div>
      <div class="coach-role">${c.role || "Coach"}</div>
    </div>`;
  }).join("");
}

function openBooking(programId) {
  selectedProgramId = programId;
  const prog = PROGRAMS.find(p => p.id === programId);
  if (!prog) return;

  const price = prog.currency === "GBP" ? `£${prog.price_gbp}` : `AED ${prog.price_aed}`;
  document.getElementById("modal-prog-name").textContent = prog.name;
  document.getElementById("modal-prog-meta").textContent = `${prog.sport} · ${price} · ${ACADEMY?.name || ""}`;
  document.getElementById("payBtnText").textContent = `Pay ${price} & Enrol`;
  document.getElementById("bookModal").classList.add("open");
  document.body.style.overflow = "hidden";
}

function closeModal() {
  document.getElementById("bookModal").classList.remove("open");
  document.body.style.overflow = "";
}

async function submitBooking() {
  const parentName = document.getElementById("parentName").value.trim();
  const parentEmail = document.getElementById("parentEmail").value.trim();
  const parentPhone = document.getElementById("parentPhone").value.trim();
  const childName = document.getElementById("childName").value.trim();
  const childDob = document.getElementById("childDob").value.trim();
  const childNotes = document.getElementById("childNotes").value.trim();

  if (!parentName || !parentEmail || !parentPhone || !childName) {
    alert("Please fill in all required fields.");
    return;
  }
  if (!parentEmail.includes("@")) {
    alert("Please enter a valid email address.");
    return;
  }

  const btn = document.getElementById("payBtn");
  btn.disabled = true;
  document.getElementById("payBtnText").textContent = "Processing...";

  try {
    const res = await fetch(`${FN}/create-academy-booking`, {
      method: "POST",
      headers: { "Content-Type": "application/json", "apikey": SUPABASE_ANON },
      body: JSON.stringify({
        program_id: selectedProgramId,
        parent_name: parentName,
        parent_email: parentEmail,
        parent_phone: parentPhone,
        child_name: childName,
        child_dob: childDob ? `2000-01-01` : null, // simplified — just store age
        child_notes: childNotes || null,
      }),
    });

    const data = await res.json();
    if (!res.ok || data.error) {
      alert(data.error || "Something went wrong. Please try again.");
      btn.disabled = false;
      document.getElementById("payBtnText").textContent = "Pay & Enrol";
      return;
    }

    // Redirect to Stripe Checkout
    window.location.href = data.url;
  } catch (e) {
    console.error(e);
    alert("Network error. Please try again.");
    btn.disabled = false;
    document.getElementById("payBtnText").textContent = "Pay & Enrol";
  }
}

function scrollToPrograms() {
  document.getElementById("programs-grid").scrollIntoView({ behavior: "smooth", block: "start" });
}

// Init
loadAcademy();
</script>
</Base>
