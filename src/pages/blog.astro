---
import Base from '../layouts/Base.astro';
---

<Base
  title="TrainedBy Blog — Expert Fitness Advice from UAE's Top Trainers"
  description="Evidence-based fitness, nutrition, and training articles from UAE's REPs-verified personal trainers."
>
  <style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --brand: #FF5C00; --brand-dim: rgba(255,92,0,0.10); --brand-border: rgba(255,92,0,0.25);
  --reps: #00C853; --reps-dim: rgba(0,200,83,0.08); --reps-border: rgba(0,200,83,0.2);
  --surface: #0a0a0a; --surface-2: #111; --surface-3: #1c1c1c; --surface-4: #242424;
  --border: rgba(255,255,255,0.08); --text: #fff;
  --text-muted: rgba(255,255,255,0.5); --text-faint: rgba(255,255,255,0.25);
}
html { scroll-behavior: smooth; }
body {
  background: var(--surface); color: var(--text);
  font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.7;
  -webkit-font-smoothing: antialiased; overflow-x: hidden;
}

/* Nav */
.nav {
  position: sticky; top: 0; z-index: 100;
  background: rgba(10,10,10,0.92); backdrop-filter: blur(16px);
  border-bottom: 1px solid var(--border);
  padding: 0 24px;
}
.nav-inner {
  max-width: 1100px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between;
  height: 60px;
}
.nav-logo {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 16px;
  text-decoration: none; color: var(--text);
}
.nav-links { display: flex; gap: 8px; align-items: center; }
.nav-links a {
  font-size: 13px; font-weight: 600; color: var(--text-muted);
  text-decoration: none; padding: 6px 12px; border-radius: 20px;
  transition: color 0.2s;
}
.nav-links a:hover { color: var(--text); }
.nav-links a.active { color: var(--brand); }
.nav-cta {
  background: var(--brand); color: #fff !important;
  padding: 8px 16px !important; border-radius: 20px;
}
.nav-cta:hover { background: #e05200; }

/* Hero */
.blog-hero {
  max-width: 1100px; margin: 0 auto;
  padding: 60px 24px 48px;
  border-bottom: 1px solid var(--border);
}
.blog-hero-eyebrow {
  font-size: 11px; font-weight: 700; color: var(--brand);
  letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 12px;
}
.blog-hero-title {
  font-family: 'Manrope', sans-serif; font-size: clamp(28px, 5vw, 48px);
  font-weight: 800; letter-spacing: -1px; line-height: 1.1;
  margin-bottom: 16px;
}
.blog-hero-sub {
  font-size: 16px; color: var(--text-muted); max-width: 520px; line-height: 1.6;
  margin-bottom: 28px;
}
.blog-hero-stats {
  display: flex; gap: 24px; flex-wrap: wrap;
}
.blog-stat { font-size: 13px; color: var(--text-faint); }
.blog-stat strong { color: var(--text); font-weight: 700; }

/* Filter bar */
.filter-bar {
  max-width: 1100px; margin: 0 auto;
  padding: 20px 24px;
  display: flex; gap: 8px; flex-wrap: wrap;
  border-bottom: 1px solid var(--border);
}
.filter-pill {
  padding: 7px 16px; border-radius: 20px;
  font-size: 12px; font-weight: 600; cursor: pointer;
  border: 1px solid var(--border); background: transparent;
  color: var(--text-muted); transition: all 0.2s; font-family: 'Inter', sans-serif;
}
.filter-pill:hover { border-color: var(--brand-border); color: var(--text); }
.filter-pill.active { background: var(--brand); border-color: var(--brand); color: #fff; }

/* Main layout */
.blog-main {
  max-width: 1100px; margin: 0 auto;
  padding: 40px 24px 80px;
  display: grid;
  grid-template-columns: 1fr 320px;
  gap: 48px;
  align-items: start;
}
@media (max-width: 768px) {
  .blog-main { grid-template-columns: 1fr; gap: 32px; }
  .blog-sidebar { order: -1; }
}

/* Featured article */
.featured-article {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 20px; overflow: hidden; margin-bottom: 32px;
  cursor: pointer; transition: border-color 0.2s, transform 0.2s;
}
.featured-article:hover { border-color: rgba(255,92,0,0.3); transform: translateY(-2px); }
.featured-img {
  width: 100%; aspect-ratio: 16/7; object-fit: cover;
  background: var(--surface-3);
}
.featured-img-placeholder {
  width: 100%; aspect-ratio: 16/7;
  background: linear-gradient(135deg, var(--surface-3), var(--surface-4));
  display: flex; align-items: center; justify-content: center;
  font-size: 48px;
}
.featured-body { padding: 24px; }
.article-category {
  font-size: 11px; font-weight: 700; color: var(--brand);
  letter-spacing: 0.06em; text-transform: uppercase; margin-bottom: 8px;
}
.featured-title {
  font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 800;
  letter-spacing: -0.3px; line-height: 1.25; margin-bottom: 10px;
}
.featured-excerpt {
  font-size: 14px; color: var(--text-muted); line-height: 1.6; margin-bottom: 16px;
}
.article-meta {
  display: flex; align-items: center; gap: 12px;
  font-size: 12px; color: var(--text-faint);
}
.article-meta-avatar {
  width: 28px; height: 28px; border-radius: 50%;
  object-fit: cover; background: var(--surface-3);
  border: 1px solid var(--border);
}
.article-meta-avatar-initials {
  width: 28px; height: 28px; border-radius: 50%;
  background: var(--brand-dim); border: 1px solid var(--brand-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 10px; font-weight: 800; color: var(--brand);
  font-family: 'Manrope', sans-serif;
}
.article-meta-name { color: var(--text-muted); font-weight: 600; }
.reps-badge-sm {
  background: var(--reps-dim); border: 1px solid var(--reps-border);
  color: var(--reps); font-size: 10px; font-weight: 700;
  padding: 2px 7px; border-radius: 10px;
}

/* Article grid */
.article-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 16px;
}
@media (max-width: 600px) { .article-grid { grid-template-columns: 1fr; } }
.article-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden; cursor: pointer;
  transition: border-color 0.2s, transform 0.2s;
}
.article-card:hover { border-color: rgba(255,92,0,0.25); transform: translateY(-2px); }
.article-card-img {
  width: 100%; aspect-ratio: 16/9; object-fit: cover;
  background: var(--surface-3);
}
.article-card-img-placeholder {
  width: 100%; aspect-ratio: 16/9;
  background: linear-gradient(135deg, var(--surface-3), var(--surface-4));
  display: flex; align-items: center; justify-content: center;
  font-size: 32px;
}
.article-card-body { padding: 16px; }
.article-card-title {
  font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 700;
  line-height: 1.3; margin-bottom: 8px; letter-spacing: -0.2px;
}
.article-card-meta {
  display: flex; align-items: center; gap: 8px;
  font-size: 11px; color: var(--text-faint);
}

/* Sidebar */
.blog-sidebar { position: sticky; top: 80px; }
.sidebar-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 16px; padding: 20px; margin-bottom: 20px;
}
.sidebar-title {
  font-family: 'Manrope', sans-serif; font-size: 13px; font-weight: 800;
  letter-spacing: 0.02em; margin-bottom: 16px;
}
.sidebar-trainer {
  display: flex; align-items: center; gap: 10px;
  padding: 10px 0; border-bottom: 1px solid var(--border);
  cursor: pointer; text-decoration: none; color: inherit;
  transition: opacity 0.2s;
}
.sidebar-trainer:last-child { border-bottom: none; padding-bottom: 0; }
.sidebar-trainer:hover { opacity: 0.75; }
.sidebar-trainer-av {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--brand-dim); border: 1px solid var(--brand-border);
  display: flex; align-items: center; justify-content: center;
  font-size: 11px; font-weight: 800; color: var(--brand);
  font-family: 'Manrope', sans-serif; flex-shrink: 0;
}
.sidebar-trainer-name { font-size: 13px; font-weight: 600; }
.sidebar-trainer-spec { font-size: 11px; color: var(--text-faint); }
.sidebar-cta {
  background: linear-gradient(135deg, var(--brand-dim), rgba(255,92,0,0.04));
  border: 1px solid var(--brand-border); border-radius: 16px;
  padding: 20px; text-align: center;
}
.sidebar-cta-title {
  font-family: 'Manrope', sans-serif; font-size: 16px; font-weight: 800;
  margin-bottom: 8px; line-height: 1.3;
}
.sidebar-cta-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.5; }
.sidebar-cta-btn {
  display: block; width: 100%;
  background: var(--brand); color: #fff;
  border: none; border-radius: 10px; padding: 12px;
  font-family: 'Manrope', sans-serif; font-size: 13px; font-weight: 800;
  cursor: pointer; text-decoration: none; transition: background 0.2s;
}
.sidebar-cta-btn:hover { background: #e05200; }

/* Write for us banner */
.write-banner {
  background: linear-gradient(135deg, rgba(0,200,83,0.08), rgba(0,200,83,0.02));
  border: 1px solid rgba(0,200,83,0.2); border-radius: 16px;
  padding: 20px; margin-bottom: 32px;
}
.write-banner-title {
  font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 800;
  margin-bottom: 6px;
}
.write-banner-sub { font-size: 12px; color: var(--text-muted); line-height: 1.5; margin-bottom: 12px; }
.write-banner-btn {
  display: inline-block; padding: 9px 18px;
  background: rgba(0,200,83,0.15); border: 1px solid rgba(0,200,83,0.3);
  color: var(--reps); border-radius: 10px;
  font-size: 12px; font-weight: 700; text-decoration: none;
  transition: background 0.2s;
}
.write-banner-btn:hover { background: rgba(0,200,83,0.25); }

/* Empty state */
.empty-state {
  text-align: center; padding: 60px 20px;
  color: var(--text-muted);
}
.empty-state-icon { font-size: 40px; margin-bottom: 16px; }
.empty-state-title { font-family: 'Manrope', sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 8px; color: var(--text); }

/* Footer */
.blog-footer {
  border-top: 1px solid var(--border);
  padding: 32px 24px;
  text-align: center;
  font-size: 12px; color: var(--text-faint);
}
.blog-footer a { color: var(--brand); text-decoration: none; }

/* Loading */
.loading-pulse {
  background: var(--surface-3); border-radius: 8px;
  animation: pulse 1.5s ease-in-out infinite;
}
@keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.4} }
  </style>

<!-- Nav -->
<nav class="nav">
  <div class="nav-inner">
    <a href="/landing.html" class="nav-logo">
      <svg width="28" height="28" viewBox="0 0 32 32"><rect width="32" height="32" rx="8" fill="#FF5C00"/><text x="16" y="23" font-family="Manrope,Arial,sans-serif" font-size="14" font-weight="800" text-anchor="middle" fill="white">TB</text></svg>
      TrainedBy
    </a>
    <div class="nav-links">
      <a href="/find.html">Find a Trainer</a>
      <a href="/blog.html" class="active">Blog</a>
      <a href="/join.html" class="nav-cta">Get Your Page</a>
    </div>
  </div>
</nav>

<!-- Hero -->
<div class="blog-hero">
  <div class="blog-hero-eyebrow">Expert Knowledge</div>
  <h1 class="blog-hero-title">Fitness advice from<br>trainers who actually train.</h1>
  <p class="blog-hero-sub">Every article on TrainedBy is written by a REPs UAE verified personal trainer. No generic content. No AI fluff. Real expertise, cited sources.</p>
  <div class="blog-hero-stats">
    <div class="blog-stat"><strong id="article-count">—</strong> articles published</div>
    <div class="blog-stat"><strong id="trainer-count">—</strong> verified trainers contributing</div>
    <div class="blog-stat"><strong>100%</strong> evidence-based</div>
  </div>
</div>

<!-- Filter bar -->
<div class="filter-bar" id="filter-bar">
  <button class="filter-pill active" onclick="filterArticles('all', this)">All</button>
  <button class="filter-pill" onclick="filterArticles('nutrition', this)">Nutrition</button>
  <button class="filter-pill" onclick="filterArticles('training', this)">Training</button>
  <button class="filter-pill" onclick="filterArticles('fat-loss', this)">Fat Loss</button>
  <button class="filter-pill" onclick="filterArticles('muscle-gain', this)">Muscle Gain</button>
  <button class="filter-pill" onclick="filterArticles('recovery', this)">Recovery</button>
  <button class="filter-pill" onclick="filterArticles('mindset', this)">Mindset</button>
  <button class="filter-pill" onclick="filterArticles('uae-lifestyle', this)">UAE Lifestyle</button>
</div>

<!-- Main -->
<div class="blog-main">
  <div class="blog-content">

    <!-- Write for us banner -->
    <div class="write-banner">
      <div class="write-banner-title">Are you a REPs UAE verified trainer?</div>
      <div class="write-banner-sub">Publish an article on TrainedBy and get your profile in front of thousands of potential clients searching for expertise in your specialty.</div>
      <a href="/edit.html" class="write-banner-btn">Write for TrainedBy →</a>
    </div>

    <!-- Featured article -->
    <div id="featured-slot"></div>

    <!-- Article grid -->
    <div id="article-grid" class="article-grid"></div>

    <!-- Empty state -->
    <div id="empty-state" class="empty-state" style="display:none;">
      <div class="empty-state-icon">📝</div>
      <div class="empty-state-title">No articles yet in this category</div>
      <p>Be the first trainer to publish in this category. Your article will be featured here and indexed by Google.</p>
    </div>

  </div>

  <!-- Sidebar -->
  <aside class="blog-sidebar">

    <!-- Top contributors -->
    <div class="sidebar-card">
      <div class="sidebar-title">Top Contributors</div>
      <div id="top-contributors"></div>
    </div>

    <!-- CTA -->
    <div class="sidebar-cta">
      <div class="sidebar-cta-title">Find your perfect trainer in Dubai</div>
      <div class="sidebar-cta-sub">Browse 100+ REPs UAE verified personal trainers. Free to contact.</div>
      <a href="/find.html" class="sidebar-cta-btn">Browse Trainers →</a>
    </div>

  </aside>
</div>

<!-- Footer -->
<footer class="blog-footer">
  <p>© 2025 TrainedBy.ae · <a href="/landing.html">For Trainers</a> · <a href="/find.html">Find a Trainer</a> · <a href="/blog.html">Blog</a></p>
</footer>

<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2.49.4/dist/umd/supabase.min.js" crossorigin="anonymous"></script>
<script is:inline>
const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lemh0ZGJmeXZrc2hwdXBscXF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MzE4NDIsImV4cCI6MjA5MDUwNzg0Mn0.zJG9xodJS70Wl2IJWiLxk2bSL7eukg5uUbLfF7jvQAo';
const sb = supabase.createClient(SUPABASE_URL, SUPABASE_KEY);

let allArticles = [];
let activeCategory = 'all';

async function loadBlog() {
  try {
    // Load articles from Supabase (table: blog_posts, joined with trainers)
    const { data: articles, error } = await sb
      .from('blog_posts')
      .select(`
        id, title, slug, excerpt, category, cover_url, emoji, read_time_mins,
        published_at, view_count,
        trainer:trainer_id (id, name, slug, avatar_url, photo_url, reps_verified, specialties)
      `)
      .eq('published', true)
      .order('published_at', { ascending: false })
      .limit(20);

    if (error || !articles) {
      renderSampleArticles();
      return;
    }

    allArticles = articles;
    renderArticles(articles);
    loadTopContributors(articles);
    updateStats(articles);
  } catch(e) {
    renderSampleArticles();
  }
}

function renderArticles(articles) {
  const featuredSlot = document.getElementById('featured-slot');
  const grid = document.getElementById('article-grid');
  const emptyState = document.getElementById('empty-state');

  featuredSlot.innerHTML = '';
  grid.innerHTML = '';

  if (!articles.length) {
    emptyState.style.display = 'block';
    return;
  }
  emptyState.style.display = 'none';

  // Featured (first article)
  const featured = articles[0];
  featuredSlot.innerHTML = buildFeaturedCard(featured);

  // Grid (remaining)
  articles.slice(1).forEach(a => {
    const card = document.createElement('div');
    card.className = 'article-card';
    card.onclick = () => goToArticle(a.slug || a.id);
    card.innerHTML = buildArticleCard(a);
    grid.appendChild(card);
  });
}

function buildFeaturedCard(a) {
  const trainer = a.trainer || {};
  const initials = (trainer.name||'TB').split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase();
  const avatarHtml = trainer.avatar_url || trainer.photo_url
    ? `<img class="article-meta-avatar" src="${trainer.avatar_url||trainer.photo_url}" alt="${trainer.name}">`
    : `<div class="article-meta-avatar-initials">${initials}</div>`;
  const imgHtml = a.cover_url
    ? `<img class="featured-img" src="${a.cover_url}" alt="${a.title}" loading="lazy">`
    : `<div class="featured-img-placeholder">${a.emoji || '💪'}</div>`;
  const date = a.published_at ? new Date(a.published_at).toLocaleDateString('en-AE', {day:'numeric',month:'long',year:'numeric'}) : '';
  return `
    <div class="featured-article" onclick="goToArticle('${a.slug||a.id}')">
      ${imgHtml}
      <div class="featured-body">
        <div class="article-category">${a.category || 'Training'}</div>
        <div class="featured-title">${a.title}</div>
        <div class="featured-excerpt">${a.excerpt || ''}</div>
        <div class="article-meta">
          ${avatarHtml}
          <span class="article-meta-name">${trainer.name || 'TrainedBy Trainer'}</span>
          ${trainer.reps_verified ? '<span class="reps-badge-sm">REPs</span>' : ''}
          <span>·</span>
          <span>${a.read_time_mins || 5} min read</span>
          ${date ? `<span>·</span><span>${date}</span>` : ''}
        </div>
      </div>
    </div>`;
}

function buildArticleCard(a) {
  const trainer = a.trainer || {};
  const initials = (trainer.name||'TB').split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase();
  const imgHtml = a.cover_url
    ? `<img class="article-card-img" src="${a.cover_url}" alt="${a.title}" loading="lazy">`
    : `<div class="article-card-img-placeholder">${a.emoji || '🏋️'}</div>`;
  return `
    ${imgHtml}
    <div class="article-card-body">
      <div class="article-category" style="margin-bottom:6px;">${a.category || 'Training'}</div>
      <div class="article-card-title">${a.title}</div>
      <div class="article-card-meta">
        <span>${trainer.name || 'Trainer'}</span>
        ${trainer.reps_verified ? '<span class="reps-badge-sm">REPs</span>' : ''}
        <span>·</span>
        <span>${a.read_time_mins || 5} min</span>
      </div>
    </div>`;
}

function loadTopContributors(articles) {
  const trainerMap = {};
  articles.forEach(a => {
    if (!a.trainer) return;
    const t = a.trainer;
    if (!trainerMap[t.id]) trainerMap[t.id] = { ...t, count: 0 };
    trainerMap[t.id].count++;
  });
  const top = Object.values(trainerMap).sort((a,b) => b.count - a.count).slice(0,5);
  const container = document.getElementById('top-contributors');
  if (!top.length) {
    container.innerHTML = '<div style="font-size:12px;color:var(--text-faint);">No contributors yet — be the first to publish.</div>';
    return;
  }
  top.forEach(t => {
    const initials = (t.name||'?').split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase();
    const a = document.createElement('a');
    a.href = `/${t.slug}`;
    a.className = 'sidebar-trainer';
    a.innerHTML = `
      <div class="sidebar-trainer-av">${initials}</div>
      <div>
        <div class="sidebar-trainer-name">${t.name}</div>
        <div class="sidebar-trainer-spec">${t.count} article${t.count>1?'s':''} · ${(t.specialties||[])[0] || 'Personal Trainer'}</div>
      </div>`;
    container.appendChild(a);
  });
}

function updateStats(articles) {
  document.getElementById('article-count').textContent = articles.length;
  const uniqueTrainers = new Set(articles.map(a => a.trainer?.id).filter(Boolean)).size;
  document.getElementById('trainer-count').textContent = uniqueTrainers || '—';
}

function filterArticles(category, btn) {
  activeCategory = category;
  document.querySelectorAll('.filter-pill').forEach(p => p.classList.remove('active'));
  btn.classList.add('active');
  if (category === 'all') {
    renderArticles(allArticles);
  } else {
    const filtered = allArticles.filter(a => (a.category||'').toLowerCase().replace(/\s+/g,'-') === category);
    renderArticles(filtered);
  }
}

function goToArticle(slugOrId) {
  window.location.href = `/blog/${slugOrId}`;
}

// Sample articles for when DB is empty or blog_posts table doesn't exist yet
function renderSampleArticles() {
  const samples = [
    {
      id: 1, title: 'How to Train During Ramadan: A Complete Guide for UAE Athletes',
      excerpt: 'Fasting during Ramadan doesn\'t mean losing your gains. Here\'s how to structure your training, nutrition, and recovery around the holy month.',
      category: 'UAE Lifestyle', emoji: '🌙', read_time_mins: 7,
      trainer: { name: 'Ahmed Al Mansoori', reps_verified: true, specialties: ['Strength', 'Nutrition'] }
    },
    {
      id: 2, title: 'The Truth About Protein Timing: What the Science Actually Says',
      excerpt: 'Does it matter when you eat protein? We reviewed 12 studies so you don\'t have to.',
      category: 'Nutrition', emoji: '🥩', read_time_mins: 5,
      trainer: { name: 'Sarah Mitchell', reps_verified: true, specialties: ['Nutrition'] }
    },
    {
      id: 3, title: '5 Exercises Every Dubai Office Worker Should Do Daily',
      excerpt: 'Sitting 8 hours a day in an air-conditioned office is destroying your posture. Fix it in 15 minutes.',
      category: 'Training', emoji: '🏢', read_time_mins: 4,
      trainer: { name: 'Marcus Chen', reps_verified: true, specialties: ['Rehabilitation'] }
