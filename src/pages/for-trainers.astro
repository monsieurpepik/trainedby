---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName || 'TrainedBy';
const isPaid = market.paymentEnabled !== false;
const isWaitlist = market.waitlistEnabled === true;
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<Base
  title={`Run Accountability Clubs for Your Audience — ${brandName}`}
  description={`Turn your Instagram followers into paying club members. AI writes 30 daily missions. You coach, shout out, and earn 80% of every membership.`}
>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --brand: #FF5C00;
      --brand-dim: rgba(255,92,0,0.10);
      --brand-border: rgba(255,92,0,0.25);
      --reps: #00C853;
      --surface: #0a0a0a;
      --surface-2: #111111;
      --surface-3: #1a1a1a;
      --surface-4: #222222;
      --border: rgba(255,255,255,0.07);
      --border-2: rgba(255,255,255,0.12);
      --text: #f2f2f2;
      --text-2: #888888;
      --text-3: #555555;
      --max: 1100px;
    }
    body { background: var(--surface); color: var(--text); font-family: 'Manrope', -apple-system, sans-serif; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    /* NAV */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 32px; height: 64px; display: flex; align-items: center; gap: 32px; transition: background 0.3s, border-color 0.3s; border-bottom: 1px solid transparent; }
    .nav.scrolled { background: rgba(10,10,10,0.95); backdrop-filter: blur(20px); border-color: var(--border); }
    .nav-logo { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 20px; color: var(--brand); text-decoration: none; letter-spacing: -0.5px; margin-right: auto; }
    .nav-links { display: flex; gap: 28px; align-items: center; }
    .nav-links a { color: var(--text-2); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { display: inline-flex; align-items: center; gap: 6px; padding: 9px 20px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 13px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; white-space: nowrap; }
    .nav-cta:hover { background: #e05200; }
    @media (max-width: 640px) { .nav-links { display: none; } .nav { padding: 0 20px; } }

    /* HERO */
    .hero { min-height: 88vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 24px 80px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 30%, rgba(255,92,0,0.07) 0%, transparent 65%); pointer-events: none; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; padding: 6px 16px; border-radius: 100px; border: 1px solid var(--brand-border); background: var(--brand-dim); font-size: 12px; font-weight: 700; color: var(--brand); letter-spacing: 0; margin-bottom: 28px; }
    .hero-headline { font-family: 'Manrope', sans-serif; font-size: clamp(36px, 6.5vw, 76px); font-weight: 900; line-height: 1.0; letter-spacing: -3px; max-width: 800px; margin-bottom: 20px; }
    .hero-headline em { font-style: normal; color: var(--brand); }
    .hero-sub { font-size: clamp(15px, 2vw, 17px); color: var(--text-2); max-width: 480px; line-height: 1.7; margin-bottom: 40px; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 56px; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 14px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; border: none; cursor: pointer; white-space: nowrap; }
    .btn-primary:hover { background: #e05200; }
    .btn-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: transparent; color: var(--text); font-size: 14px; font-weight: 600; text-decoration: none; border: 1px solid var(--border-2); transition: border-color 0.2s; white-space: nowrap; }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.25); }

    /* PROOF STRIP */
    .proof-strip { display: flex; gap: 40px; flex-wrap: wrap; justify-content: center; }
    .proof-item { text-align: center; }
    .proof-val { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 28px; letter-spacing: -1px; color: var(--text); }
    .proof-label { font-size: 12px; color: var(--text-2); margin-top: 2px; font-weight: 600; }

    /* SECTION */
    .section { padding: 80px 24px; max-width: var(--max); margin: 0 auto; }
    .section-eyebrow { font-size: 11px; font-weight: 600; color: var(--brand); letter-spacing: 0; margin-bottom: 14px; }
    .section-title { font-family: 'Manrope', sans-serif; font-size: clamp(26px, 4vw, 44px); font-weight: 900; letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 16px; }
    .section-sub { font-size: 15px; color: var(--text-2); line-height: 1.7; max-width: 480px; }

    /* FEATURES GRID */
    .features-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; margin-top: 48px; }
    .feature-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 28px; }
    .feature-icon { width: 44px; height: 44px; border-radius: 12px; background: var(--brand-dim); border: 1px solid var(--brand-border); display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 18px; }
    .feature-title { font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 17px; margin-bottom: 8px; }
    .feature-desc { font-size: 14px; color: var(--text-2); line-height: 1.65; }
    .feature-badge { display: inline-block; margin-top: 12px; padding: 3px 10px; border-radius: 20px; background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.2); color: #00C853; font-size: 11px; font-weight: 700; }

    /* HOW IT WORKS */
    .steps { display: flex; flex-direction: column; gap: 0; margin-top: 48px; }
    .step { display: grid; grid-template-columns: 64px 1fr; gap: 24px; padding: 32px 0; border-bottom: 1px solid var(--border); }
    .step:last-child { border-bottom: none; }
    .step-num { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 36px; color: var(--brand); opacity: 0.5; letter-spacing: -1px; line-height: 1; padding-top: 4px; }
    .step-title { font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 20px; margin-bottom: 8px; }
    .step-desc { font-size: 14px; color: var(--text-2); line-height: 1.65; max-width: 520px; }
    .step-time { display: inline-block; margin-top: 10px; padding: 3px 10px; border-radius: 20px; background: var(--brand-dim); border: 1px solid var(--brand-border); color: var(--brand); font-size: 11px; font-weight: 700; }

    /* PRICING */
    .pricing-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(280px, 1fr)); gap: 16px; margin-top: 48px; }
    .pricing-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 20px; padding: 32px; position: relative; }
    .pricing-card.featured { border-color: rgba(255,92,0,0.3); background: linear-gradient(135deg, rgba(255,92,0,0.06), var(--surface-2)); }
    .pricing-popular { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); padding: 4px 16px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 11px; font-weight: 700; white-space: nowrap; }
    .pricing-tier { font-size: 12px; font-weight: 700; color: var(--text-2); letter-spacing: 0; margin-bottom: 8px; }
    .pricing-price { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 40px; letter-spacing: -2px; margin-bottom: 4px; }
    .pricing-price span { font-size: 14px; font-weight: 500; color: var(--text-2); letter-spacing: 0; }
    .pricing-desc { font-size: 13px; color: var(--text-2); line-height: 1.6; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
    .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; }
    .pricing-features li { font-size: 13px; color: var(--text-2); display: flex; align-items: flex-start; gap: 8px; }
    .pricing-features li::before { content: '✓'; color: #00C853; font-weight: 700; flex-shrink: 0; margin-top: 1px; }
    .pricing-features li.muted { color: var(--text-3); }
    .pricing-features li.muted::before { color: var(--text-3); }
    .pricing-btn { display: block; text-align: center; padding: 13px 24px; border-radius: 100px; font-size: 14px; font-weight: 700; text-decoration: none; transition: all 0.2s; }
    .pricing-btn-primary { background: var(--brand); color: #fff; }
    .pricing-btn-primary:hover { background: #e05200; }
    .pricing-btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border-2); }
    .pricing-btn-ghost:hover { border-color: rgba(255,255,255,0.25); }

    /* FAQ */
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 48px; }
    .faq-item { padding: 24px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; }
    .faq-q { font-family: 'Manrope', sans-serif; font-weight: 700; font-size: 15px; margin-bottom: 10px; }
    .faq-a { font-size: 13px; color: var(--text-2); line-height: 1.65; }
    @media (max-width: 640px) { .faq-grid { grid-template-columns: 1fr; } }

    /* BOTTOM CTA */
    .cta-bottom { padding: 100px 24px; text-align: center; border-top: 1px solid var(--border); background: linear-gradient(180deg, transparent, rgba(255,92,0,0.03)); }
    .cta-bottom-title { font-family: 'Manrope', sans-serif; font-size: clamp(32px, 5vw, 60px); font-weight: 900; letter-spacing: -2px; line-height: 1.05; margin-bottom: 16px; }
    .cta-bottom-sub { font-size: 16px; color: var(--text-2); max-width: 400px; margin: 0 auto 40px; line-height: 1.7; }

    /* WAITLIST */
    .waitlist-section { background: linear-gradient(135deg, rgba(255,92,0,0.10), rgba(255,92,0,0.03)); border-top: 1px solid rgba(255,92,0,0.2); border-bottom: 1px solid rgba(255,92,0,0.2); padding: 72px 24px; text-align: center; }
    .waitlist-inner { max-width: 520px; margin: 0 auto; }
    .waitlist-form { display: flex; gap: 10px; flex-wrap: wrap; justify-content: center; margin-top: 28px; }
    .waitlist-input { flex: 1; min-width: 200px; padding: 12px 18px; border-radius: 100px; border: 1px solid var(--border-2); background: var(--surface-2); color: var(--text); font-size: 14px; outline: none; font-family: inherit; }
    .waitlist-input:focus { border-color: rgba(255,92,0,0.4); }

    /* FOOTER */
    footer { border-top: 1px solid var(--border); padding: 48px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; max-width: var(--max); margin: 0 auto; }
    .footer-logo { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 18px; color: var(--brand); text-decoration: none; }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { color: var(--text-2); text-decoration: none; font-size: 13px; transition: color 0.2s; }
    .footer-links a:hover { color: var(--text); }
    .footer-copy { font-size: 12px; color: var(--text-3); }
  </style>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="/landing" class="nav-logo">{brandName}</a>
    <div class="nav-links">
      <a href="/find">Find a Club</a>
      <a href="/blog">Stories</a>
      <a href="/community">Community</a>
      <a href="/for-trainers" style="color:var(--brand);font-weight:700">For Coaches</a>
    </div>
    <a href="/join" class="nav-cta">Launch your club →</a>
  </nav>

  <!-- HERO -->
  <section class="hero">
    <div style="font-size:13px;color:var(--text-2);line-height:1.7;max-width:440px;margin-bottom:28px;text-align:center;">
      BODi pays its trainers $0. You built an audience. Your followers trust you.<br>
      <span style="color:var(--brand);font-weight:700;">Now build a business from it.</span>
    </div>
    <h1 class="hero-headline">
      Run <em>your</em> 30-day club.<br>Keep 80% of every<br>membership.
    </h1>
    <p class="hero-sub">
      AI writes 30 daily missions from your goal. Your audience joins. You coach, shout out, and earn — while they show up every day.
    </p>
    <div class="hero-actions">
      {isPaid ? (
        <a href="/join" class="btn-primary">Launch your first club →</a>
      ) : (
        <a href="#waitlist" class="btn-primary">Join the waitlist →</a>
      )}
      <a href="#how-it-works" class="btn-ghost" onclick="document.getElementById('how-it-works').scrollIntoView({behavior:'smooth'});return false;">See how it works</a>
    </div>
    <div class="proof-strip">
      <div class="proof-item">
        <div class="proof-val">87%</div>
        <div class="proof-label">Mission completion rate <span style="font-size:10px;color:var(--text-3)">(projected)</span></div>
      </div>
      <div class="proof-item">
        <div class="proof-val">$2,400</div>
        <div class="proof-label">Avg monthly per club <span style="font-size:10px;color:var(--text-3)">(projected)</span></div>
      </div>
      <div class="proof-item">
        <div class="proof-val">30 sec</div>
        <div class="proof-label">To generate a full plan</div>
      </div>
    </div>
  </section>

  <!-- URGENCY STRIP -->
  <div style="background:rgba(124,58,237,0.08);border-top:1px solid rgba(124,58,237,0.15);padding:12px 24px;display:flex;align-items:center;justify-content:center;gap:10px;">
    <div style="width:7px;height:7px;border-radius:50%;background:#4ade80;flex-shrink:0;"></div>
    <div style="font-size:12px;color:var(--text-2)" id="trainer-launch-strip">Coaches are launching accountability clubs this week</div>
  </div>

  <!-- WHAT YOU GET -->
  <div style="border-top:1px solid var(--border)">
    <div class="section">
      <p class="section-eyebrow">What you get</p>
      <h2 class="section-title">Everything you need<br>to run your club.</h2>
      <p class="section-sub">No third-party tools. No manual admin. Everything is built in.</p>
      <div class="features-grid">
        <div class="feature-card">
          <div class="feature-icon">🤖</div>
          <div class="feature-title">AI mission generator</div>
          <p class="feature-desc">30 days of structured daily content in 30 seconds — so you can focus on coaching, not writing.</p>
          <span class="feature-badge">Powered by Claude</span>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📬</div>
          <div class="feature-title">Daily email nudge</div>
          <p class="feature-desc">Get tomorrow's AI-drafted mission in your inbox each morning — so you can review it in 2 minutes and stay in control of the plan.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📊</div>
          <div class="feature-title">Member roster + streaks</div>
          <p class="feature-desc">See exactly who's showing up, what their streak is, and who hasn't checked in today — so you know exactly where to focus your energy.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">📣</div>
          <div class="feature-title">Shoutout button</div>
          <p class="feature-desc">One tap to celebrate the whole club in their feed — so consistency feels rewarded and members keep coming back.</p>
        </div>
        <div class="feature-card">
          <div class="feature-icon">💳</div>
          <div class="feature-title">Stripe payments built in</div>
          <p class="feature-desc">Set a price, get paid — so you earn 80% of every membership with no setup, no third-party tools, and no chasing invoices.</p>
          <span class="feature-badge">80% goes to you</span>
        </div>
        <div class="feature-card">
          <div class="feature-icon">🎥</div>
          <div class="feature-title">Live drops <span style="font-size:11px;color:var(--text-3);font-weight:400;">(coming soon)</span></div>
          <p class="feature-desc">Go live with your club, drop surprise missions, and build the kind of energy that keeps members enrolled month after month.</p>
        </div>
      </div>
    </div>
  </div>

  <!-- HOW IT WORKS -->
  <div id="how-it-works" style="border-top:1px solid var(--border);background:var(--surface-2)">
    <div class="section">
      <p class="section-eyebrow">How it works</p>
      <h2 class="section-title">Live in under<br>5 minutes.</h2>
      <div class="steps">
        <div class="step">
          <div class="step-num">01</div>
          <div>
            <div class="step-title">Create your club</div>
            <p class="step-desc">Name it, describe the transformation goal, set a price (or keep it free). Your club gets a shareable link — put it in your Instagram bio and you're done.</p>
            <span class="step-time">~2 minutes</span>
          </div>
        </div>
        <div class="step">
          <div class="step-num">02</div>
          <div>
            <div class="step-title">AI writes the plan</div>
            <p class="step-desc">Claude generates 30 daily missions from your goal in 30 seconds. Review them, edit tomorrow's mission each day if you want. The plan is yours — AI just does the drafting.</p>
            <span class="step-time">30 seconds</span>
          </div>
        </div>
        <div class="step">
          <div class="step-num">03</div>
          <div>
            <div class="step-title">Your audience joins</div>
            <p class="step-desc">Share your club link. Members pay, check in daily, and build public streaks visible to the whole group. You see who's showing up, send shoutouts, and earn recurring income.</p>
            <span class="step-time">Members start Day 1</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ECONOMICS -->
  <div style="border-top:1px solid var(--border)">
    <div class="section">
      <p class="section-eyebrow">The economics</p>
      <h2 class="section-title">BODi pays its trainers $0.<br>You keep 80%.</h2>
      <p class="section-sub">BODi built a $700M business on your kind of content. The difference: they kept the revenue. You won't.</p>

      <!-- Comparison table -->
      <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;margin-top:48px;max-width:600px;">
        <div style="background:var(--surface-2);border:1px solid var(--border);border-radius:16px;padding:28px;opacity:0.7;">
          <div style="font-size:12px;font-weight:700;color:var(--text-2);margin-bottom:16px;letter-spacing:0;">BODi</div>
          <div style="font-size:32px;font-weight:900;color:var(--text-3);letter-spacing:-1px;margin-bottom:8px;">$0</div>
          <div style="font-size:13px;color:var(--text-3);line-height:1.6;">paid to trainers per month, regardless of how many members use their content</div>
        </div>
        <div style="background:linear-gradient(135deg,rgba(255,92,0,0.08),var(--surface-2));border:1px solid rgba(255,92,0,0.25);border-radius:16px;padding:28px;">
          <div style="font-size:12px;font-weight:700;color:var(--brand);margin-bottom:16px;letter-spacing:0;">{brandName}</div>
          <div style="font-size:32px;font-weight:900;color:var(--text);letter-spacing:-1px;margin-bottom:8px;">80%</div>
          <div style="font-size:13px;color:var(--text-2);line-height:1.6;">of every membership goes directly to you — every month, from every member</div>
        </div>
      </div>

      <!-- Example calculation -->
      <div style="margin-top:40px;padding:32px;background:var(--surface-2);border:1px solid var(--border);border-radius:20px;max-width:560px;">
        <div style="font-size:12px;font-weight:600;color:var(--brand);margin-bottom:20px;letter-spacing:0;">Example · One club</div>
        <div style="display:flex;flex-direction:column;gap:12px;">
          <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:12px;border-bottom:1px solid var(--border);">
            <span style="font-size:14px;color:var(--text-2);">50 members × {market.currencySymbol}49/month</span>
            <span style="font-size:16px;font-weight:800;color:var(--text);">{market.currencySymbol}2,450</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;padding-bottom:12px;border-bottom:1px solid var(--border);">
            <span style="font-size:14px;color:var(--text-2);">Your 80% share</span>
            <span style="font-size:16px;font-weight:800;color:var(--text);">{market.currencySymbol}1,960</span>
          </div>
          <div style="display:flex;justify-content:space-between;align-items:center;">
            <span style="font-size:14px;color:var(--text-2);">Two clubs running</span>
            <span style="font-size:20px;font-weight:900;color:var(--brand);">{market.currencySymbol}3,920/mo</span>
          </div>
        </div>
        <div style="margin-top:20px;font-size:12px;color:var(--text-3);">Recurring. Every month. While they keep showing up.</div>
      </div>
    </div>
  </div>

  <!-- FAQ -->
  <div style="border-top:1px solid var(--border);background:var(--surface-2)">
    <div class="section">
      <p class="section-eyebrow">Questions</p>
      <h2 class="section-title">Common questions.</h2>
      <div class="faq-grid">
        <div class="faq-item">
          <div class="faq-q">Do I need to be {market.certificationBody} registered?</div>
          <div class="faq-a">You can create a profile and go live immediately without verification. The {market.certificationBody} badge is added once we verify your registration — usually within 24 hours. Non-verified profiles still get full access to all features.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">How does the Digital Product Hub work?</div>
          <div class="faq-a">Upload any file (PDF, video link, Notion document) and set a price. When a client buys it, the payment goes directly to your account minus a small platform fee. You get paid within 2 business days.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">What is the Affiliate Vault?</div>
          <div class="faq-a">We negotiate affiliate agreements with fitness brands on behalf of all {brandName} trainers. You activate the brands you already recommend, share your unique link with clients, and earn commission on every purchase they make — automatically, every month.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">Can I cancel anytime?</div>
          <div class="faq-a">Yes. No contracts, no lock-in. Cancel from your dashboard and your profile reverts to the Free tier — it stays live, just without the Pro tools. Your digital products and affiliate earnings are yours to keep.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">What is the trainer referral programme?</div>
          <div class="faq-a">Every Pro trainer gets a unique referral link. When another trainer signs up to Pro through your link, you earn 20% of their monthly subscription — recurring, for as long as they stay subscribed.</div>
        </div>
        <div class="faq-item">
          <div class="faq-q">How does the AI assistant work?</div>
          <div class="faq-a">Your AI assistant knows your full profile, your specialties, your market, and your clients. Ask it anything — write a 12-week programme, draft a follow-up email to a lead, explain a nutrition concept, or help you price your packages. It responds in your language.</div>
        </div>
      </div>
    </div>
  </div>

  <!-- WAITLIST (for markets without payments) -->
  {isWaitlist && (
    <div class="waitlist-section" id="waitlist">
      <div class="waitlist-inner">
        <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 14px;border-radius:100px;border:1px solid rgba(255,92,0,0.3);background:rgba(255,92,0,0.08);font-size:11px;font-weight:700;color:var(--brand);letter-spacing:0;margin-bottom:24px;">
          {market.flag} Coming Soon to {market.cityName || market.market.toUpperCase()}
        </div>
        <h2 style="font-family:'Manrope',sans-serif;font-size:clamp(24px,4vw,36px);font-weight:900;letter-spacing:-1px;line-height:1.15;margin-bottom:16px;">
          Be first. Lock in the launch price.
        </h2>
        <p style="font-size:15px;color:var(--text-2);line-height:1.7;">{market.paymentNote}</p>
        <div class="waitlist-form" id="waitlist-form">
          <input id="wl-name" type="text" placeholder="Your name" class="waitlist-input" />
          <input id="wl-email" type="email" required placeholder="Your email" class="waitlist-input" />
          <button type="button" onclick="submitWaitlist()" class="btn-primary" style="padding:12px 24px;font-size:14px;">Join the Waitlist →</button>
        </div>
        <div id="wl-success" style="display:none;margin-top:20px;padding:12px 24px;border-radius:100px;background:rgba(0,200,83,0.1);border:1px solid rgba(0,200,83,0.2);color:#00C853;font-size:14px;font-weight:600;">
          ✓ You're on the list! We'll email you when we launch.
        </div>
      </div>
    </div>
  )}

  <!-- BOTTOM CTA -->
  <div class="cta-bottom">
    <h2 class="cta-bottom-title">Your expertise.<br>Your profile.<br><em style="color:var(--brand);font-style:normal">Your practice.</em></h2>
    <p class="cta-bottom-sub">Free to start. Live in minutes. No credit card required.</p>
    <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap">
      {isPaid ? (
        <a href="/join" class="btn-primary" style="font-size:16px;padding:16px 32px">Create your free profile →</a>
      ) : (
        <a href="#waitlist" class="btn-primary" style="font-size:16px;padding:16px 32px">Join the waitlist →</a>
      )}
      <a href="/find" class="btn-ghost" style="font-size:16px;padding:16px 32px">See live profiles ⊙</a>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <a href="/landing" class="footer-logo">{brandName}</a>
    <div class="footer-links">
      <a href="/landing">Home</a>
      <a href="/find">Find a Trainer</a>
      <a href="/blog">Stories</a>
      <a href="/community">Community</a>
      <a href="/join">Join as Trainer</a>
    </div>
    <div class="footer-copy">© {new Date().getFullYear()} {brandName}</div>
  </footer>

  <script define:vars={{ marketData: { market: market.market, waitlistEnabled: market.waitlistEnabled }, SUPABASE_ANON_KEY }}>
    // Nav scroll
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Waitlist
    window.submitWaitlist = async function() {
      const email = document.getElementById('wl-email').value;
      const name = document.getElementById('wl-name').value;
      if (!email) return;
      const btn = document.querySelector('#waitlist-form button');
      if (btn) { btn.textContent = '...'; btn.disabled = true; }
      try {
        await fetch('https://mezhtdbfyvkshpuplqqw.supabase.co/functions/v1/join-waitlist', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, name, market: marketData.market, source_domain: window.location.hostname, role: 'trainer' })
        });
        document.getElementById('waitlist-form').style.display = 'none';
        document.getElementById('wl-success').style.display = 'block';
      } catch(e) {
        if (btn) { btn.textContent = 'Try again'; btn.disabled = false; }
      }
    };
  </script>
</Base>
