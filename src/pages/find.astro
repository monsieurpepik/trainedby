---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName;
const SUPABASE_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---

<Base
  title={`Find a Verified Trainer | ${brandName}`}
  description={`Browse verified personal trainers on ${brandName}. Filter by speciality, location and training mode.`}
>
  <Fragment slot="head">
    <meta name="color-scheme" content="light">
    <meta name="theme-color" content="#FFFFFF">
    <link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,400;0,9..40,500;0,9..40,700;0,9..40,800;1,9..40,400&display=swap" rel="stylesheet">
    <!-- Light theme override — must be LAST in <head> to win the CSS cascade over Base.astro dark globals -->
    <style>
      :root {
        --bg: #FFFFFF;
        --surface: #FAFAF9;
        --surface-2: #F5F4F3;
        --surface-3: #E8E5E2;
        --text: #1A1411;
        --text-muted: #6B6460;
        --border: rgba(0,0,0,0.07);
        --border-hover: rgba(0,0,0,0.14);
        --brand: #FF5C00;
        --brand-dim: rgba(255,92,0,0.08);
        --brand-border: rgba(255,92,0,0.2);
        --font-body: 'DM Sans', system-ui, sans-serif;
        --font-display: 'DM Sans', system-ui, sans-serif;
      }
      body {
        background: #FFFFFF;
        color: #1A1411;
        font-family: 'DM Sans', system-ui, sans-serif;
      }
    </style>
  </Fragment>

  <style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#FFFFFF;
  --surface:#FAFAF9;
  --surface2:#F5F4F3;
  --surface3:#E8E5E2;
  --text:#1A1411;
  --text-muted:#6B6460;
  --border:rgba(0,0,0,0.07);
  --border-hover:rgba(0,0,0,0.14);
  --brand:#FF5C00;
  --brand-dim:rgba(255,92,0,0.08);
  --brand-border:rgba(255,92,0,0.2);
  --green:#00C853;
  --radius:14px;
  --font:'DM Sans',system-ui,sans-serif;
}
html,body{min-height:100vh;background:var(--bg);color:var(--text);font-family:var(--font);-webkit-font-smoothing:antialiased}

/* TOP BAR */
.top-bar{
  position:sticky;top:0;z-index:100;
  background:#fff;
  border-bottom:1px solid var(--border);
}
.top-bar-inner{
  max-width:960px;margin:0 auto;
  display:flex;align-items:center;gap:12px;
  padding:10px 16px;
}
.nav-logo{font-size:15px;font-weight:800;letter-spacing:-0.02em;text-decoration:none;color:var(--text);flex-shrink:0}
.search-wrap{
  flex:1;position:relative;
}
.search-wrap svg{position:absolute;left:12px;top:50%;transform:translateY(-50%);color:var(--text-muted);pointer-events:none}
#search-input{
  width:100%;padding:10px 12px 10px 38px;
  background:var(--surface);border:1px solid var(--border);
  border-radius:10px;color:var(--text);font-family:var(--font);font-size:14px;
  outline:none;transition:border-color 0.2s;
}
#search-input:focus{border-color:var(--brand)}
#search-input::placeholder{color:var(--text-muted)}
.result-count{font-size:12px;color:var(--text-muted);font-weight:500;white-space:nowrap;flex-shrink:0}
.nav-cta{
  background:var(--brand);color:#fff;font-size:13px;font-weight:700;
  padding:8px 16px;border-radius:20px;text-decoration:none;white-space:nowrap;flex-shrink:0;
}

/* FILTERS */
.filters{
  display:flex;gap:8px;overflow-x:auto;padding:10px 16px;
  scrollbar-width:none;-webkit-overflow-scrolling:touch;
  max-width:960px;margin:0 auto;
  border-bottom:1px solid var(--border);
}
.filters::-webkit-scrollbar{display:none}
.filter-pill{
  flex-shrink:0;padding:6px 14px;border-radius:100px;
  border:1px solid var(--border);background:var(--surface);
  color:var(--text-muted);font-size:12px;font-weight:600;cursor:pointer;
  transition:all 0.15s;white-space:nowrap;font-family:var(--font);
}
.filter-pill:hover{border-color:var(--brand-border);color:var(--brand);background:var(--brand-dim)}
.filter-pill.active{
  background:var(--text);border-color:var(--text);
  color:#fff;font-weight:700;
}

/* MAIN LAYOUT */
.main{max-width:960px;margin:0 auto;padding:20px 16px 60px}

/* RESULTS HEADER */
.results-header{
  display:flex;align-items:center;justify-content:space-between;
  margin-bottom:16px;
}
.results-count{font-size:13px;color:var(--text-muted);font-weight:500}
.sort-select{
  background:var(--surface);border:1px solid var(--border);
  color:var(--text);font-family:var(--font);font-size:12px;font-weight:600;
  padding:6px 10px;border-radius:8px;outline:none;cursor:pointer;
}

/* TRAINER GRID */
#trainerGrid{
  display:grid;
  grid-template-columns:repeat(2,1fr);
  gap:16px;
}
@media(min-width:768px){
  #trainerGrid{grid-template-columns:repeat(4,1fr);}
}

/* TRAINER CARD — light design */
.trainer-card{
  background:var(--surface);
  border-radius:16px;
  overflow:hidden;
  cursor:pointer;
  transition:transform 0.15s,box-shadow 0.15s,border-color 0.15s;
  display:block;
  border:1px solid var(--border);
}
.trainer-card:hover{
  transform:translateY(-2px);
  box-shadow:0 4px 16px rgba(0,0,0,0.08);
  border-color:var(--border-hover);
}
.trainer-card:focus-visible{
  outline:2px solid var(--brand);
  outline-offset:2px;
}
.tc-photo-wrap{position:relative;aspect-ratio:3/4;background:var(--surface2);overflow:hidden}
.tc-photo{
  width:100%;height:100%;
  object-fit:cover;object-position:top center;
}
.tc-initials{
  position:absolute;inset:0;display:flex;align-items:center;justify-content:center;
  font-size:48px;font-weight:800;color:rgba(255,92,0,0.15);
  font-family:'DM Sans',sans-serif;user-select:none;
}
.tc-verified{
  position:absolute;top:10px;right:10px;
  background:rgba(0,200,83,0.12);border:1px solid rgba(0,200,83,0.25);
  border-radius:100px;padding:3px 9px;
  font-size:10px;font-weight:700;color:#00A844;
}
.tc-body{padding:14px}
.tc-name{font-size:14px;font-weight:800;color:var(--text);margin-bottom:2px;letter-spacing:-0.01em}
.tc-meta{font-size:12px;color:var(--text-muted);margin-bottom:10px}
.tc-price{font-size:13px;font-weight:700;color:var(--text);margin-bottom:12px}
.tc-wa-btn{
  display:flex;align-items:center;justify-content:center;gap:6px;
  background:#25D366;color:#fff;border-radius:10px;
  padding:10px 14px;font-size:13px;font-weight:700;
  text-decoration:none;transition:background 0.15s;
}
.tc-wa-btn:hover{background:#1db954}
.tc-wa-btn svg{flex-shrink:0}

/* EMPTY STATE */
.empty-state{
  text-align:center;padding:60px 20px;
  grid-column:1/-1;
}
.empty-icon{font-size:48px;margin-bottom:16px}
.empty-title{font-size:18px;font-weight:700;margin-bottom:8px}
.empty-sub{font-size:14px;color:var(--text-muted)}

/* SKELETON */
.skeleton-card{
  background:var(--surface);border:1px solid var(--border);
  border-radius:16px;overflow:hidden;
}
.skel{background:linear-gradient(90deg,var(--surface2) 25%,var(--surface3) 50%,var(--surface2) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:6px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel-cover{height:100px;border-radius:0}
.skel-body{padding:14px}
.skel-line{height:12px;margin-bottom:8px}
.skel-line.w60{width:60%}.skel-line.w80{width:80%}.skel-line.w40{width:40%}

/* LOAD MORE */
.load-more-wrap{text-align:center;margin-top:28px}
.btn-load-more{
  background:var(--surface);border:1px solid var(--border);
  color:var(--text);font-family:var(--font);font-size:14px;font-weight:600;
  padding:12px 28px;border-radius:20px;cursor:pointer;
  transition:border-color 0.2s;
}
.btn-load-more:hover{border-color:var(--brand);color:var(--brand)}

/* ── Mobile responsive ────────────────────────────────────────────── */
@media(max-width:640px){
  .main{padding:12px 12px max(60px,calc(60px + env(safe-area-inset-bottom)))}
  .results-header{flex-direction:column;align-items:flex-start;gap:8px}
  .sort-select{width:100%}
}

/* ── Safe area ───────────────────────────────────────────────────── */
.main{padding-bottom:max(60px,calc(60px + env(safe-area-inset-bottom)))}
/* EMPTY STATE */
.empty-state{
  text-align:center;padding:60px 20px;
  grid-column:1/-1;
}
.empty-icon{font-size:48px;margin-bottom:16px}
.empty-title{font-size:18px;font-weight:700;margin-bottom:8px}
.empty-sub{font-size:14px;color:var(--white-60)}

/* SKELETON */
.skeleton-card{
  background:var(--surface2);border:1px solid var(--glass-border);
  border-radius:var(--radius);overflow:hidden;
}
.skel{background:linear-gradient(90deg,var(--surface3) 25%,rgba(255,255,255,0.04) 50%,var(--surface3) 75%);background-size:200% 100%;animation:shimmer 1.5s infinite;border-radius:6px}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.skel-cover{height:100px;border-radius:0}
.skel-body{padding:14px}
.skel-line{height:12px;margin-bottom:8px}
.skel-line.w60{width:60%}.skel-line.w80{width:80%}.skel-line.w40{width:40%}

/* LOAD MORE */
.load-more-wrap{text-align:center;margin-top:28px}
.btn-load-more{
  background:var(--surface3);border:1px solid var(--glass-border);
  color:var(--white);font-family:var(--font);font-size:14px;font-weight:600;
  padding:12px 28px;border-radius:20px;cursor:pointer;
  transition:border-color 0.2s;
}
.btn-load-more:hover{border-color:var(--brand);color:var(--brand)}

/* ── Mobile responsive ────────────────────────────────────────────── */
@media(max-width:640px){
  #trainerGrid{grid-template-columns:1fr}
  .main{padding:0 12px max(60px,calc(60px + env(safe-area-inset-bottom)))}
  .search-wrap{padding:0 16px}
  .results-header{flex-direction:column;align-items:flex-start;gap:8px}
  .sort-select{width:100%}
  nav{padding:12px 16px}
}
@media(min-width:641px) and (max-width:900px){
  #trainerGrid{grid-template-columns:repeat(2,1fr)}
}

/* ── Safe area ───────────────────────────────────────────────────── */
.main{padding-bottom:max(60px,calc(60px + env(safe-area-inset-bottom)))}
  </style>

<div class="top-bar">
  <div class="top-bar-inner">
    <a href="/" class="nav-logo">{brandName}</a>
    <div class="search-wrap">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input type="text" id="search-input" placeholder="Search by name, specialty or gym…" oninput="filterTrainers()">
    </div>
    <span class="result-count" id="result-count"></span>
    <a href="/join" class="nav-cta">Get Your Page →</a>
  </div>
  <div class="filters" id="filters">
    <button class="filter-pill active" data-filter="all" onclick="setFilter('all',this)">All Trainers</button>
    <button class="filter-pill" data-filter="in-person" onclick="setFilter('in-person',this)">In-Person</button>
    <button class="filter-pill" data-filter="online" onclick="setFilter('online',this)">Online</button>
    <button class="filter-pill" data-filter="hybrid" onclick="setFilter('hybrid',this)">Hybrid</button>
    <button class="filter-pill" data-filter="strength" onclick="setFilter('strength',this)">Strength</button>
    <button class="filter-pill" data-filter="fat-loss" onclick="setFilter('fat-loss',this)">Fat Loss</button>
    <button class="filter-pill" data-filter="hiit" onclick="setFilter('hiit',this)">HIIT</button>
    <button class="filter-pill" data-filter="pilates" onclick="setFilter('pilates',this)">Pilates</button>
    <button class="filter-pill" data-filter="boxing" onclick="setFilter('boxing',this)">Boxing</button>
    <button class="filter-pill" data-filter="yoga" onclick="setFilter('yoga',this)">Yoga</button>
    <button class="filter-pill" data-filter="nutrition" onclick="setFilter('nutrition',this)">Nutrition</button>
    <button class="filter-pill" data-filter="female-only" onclick="setFilter('female-only',this)">Female Trainers</button>
  </div>
</div>

<div class="main">
  <div class="results-header">
    <div class="results-count" id="resultsCount">Loading trainers…</div>
    <select class="sort-select" id="sortSelect" onchange="sortTrainers()">
      <option value="featured">Featured</option>
      <option value="rating">Top Rated</option>
      <option value="experience">Most Experienced</option>
      <option value="price_low">Price: Low to High</option>
      <option value="price_high">Price: High to Low</option>
    </select>
  </div>

  <div id="trainerGrid">
    <!-- Skeletons while loading -->
    ${Array(6).fill(0).map(() => `
    <div class="skeleton-card">
      <div class="skel skel-cover"></div>
      <div class="skel-body">
        <div class="skel skel-line w80"></div>
        <div class="skel skel-line w60"></div>
        <div class="skel skel-line w40" style="margin-top:12px"></div>
      </div>
    </div>`).join('')}
  </div>

  <div class="load-more-wrap" id="loadMoreWrap" style="display:none">
    <button class="btn-load-more" onclick="loadMore()">Load More Trainers</button>
  </div>
</div>

<script is:inline define:vars={{ SUPABASE_KEY }}>
const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';

let allTrainers = [];
let filtered = [];
let activeFilter = 'all';
let page = 0;
const PAGE_SIZE = 12;

async function loadTrainers() {
  try {
    const mkt = (window.__MARKET__ || 'ae');
    const r = await fetch(
      `${SUPABASE_URL}/rest/v1/trainers?verification_status=eq.verified&market=eq.${mkt}&order=created_at.desc&limit=200`,
      { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
    );
    const trainers = await r.json();

    // Also fetch packages for pricing
    const ids = trainers.map(t => t.id);
    let packages = [];
    if (ids.length) {
      const pr = await fetch(
        `${SUPABASE_URL}/rest/v1/session_packages?trainer_id=in.(${ids.join(',')})&order=price.asc`,
        { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
      );
      packages = await pr.json();
    }

    // Attach min price to each trainer
    allTrainers = trainers.map(t => {
      const tPkgs = packages.filter(p => p.trainer_id === t.id);
      const minPrice = tPkgs.length ? Math.min(...tPkgs.map(p => p.price || 0)) : null;
      return { ...t, min_price: minPrice, packages: tPkgs };
    });

    // If no verified trainers, show demo data
    if (!allTrainers.length) {
      allTrainers = getDemoTrainers();
    }

    filtered = [...allTrainers];
    renderGrid();
  } catch(e) {
    allTrainers = getDemoTrainers();
    filtered = [...allTrainers];
    renderGrid();
  }
}

