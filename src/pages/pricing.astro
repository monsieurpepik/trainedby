<script is:inline>
const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
const EDGE_BASE = SUPABASE_URL + '/functions/v1';
let isAnnual = false;

function toggleBilling() { setBilling(isAnnual ? 'monthly' : 'annual'); }
function setBilling(mode) {
  isAnnual = mode === 'annual';
  document.getElementById('billing-switch').classList.toggle('annual', isAnnual);
  document.getElementById('monthly-label').classList.toggle('active', !isAnnual);
  document.getElementById('annual-label').classList.toggle('active', isAnnual);
  document.getElementById('pro-price').textContent = isAnnual ? '79' : '99';
  document.getElementById('premium-price').textContent = isAnnual ? '159' : '199';
  document.getElementById('pro-annual-note').textContent = isAnnual ? 'AED 948/yr — save AED 240' : '';
  document.getElementById('premium-annual-note').textContent = isAnnual ? 'AED 1,908/yr — save AED 480' : '';
}

function getAuthToken() {
  const cookies = document.cookie.split(';').map(c => c.trim());
  for (const c of cookies) {
    if (c.startsWith('tb_session=')) return c.slice('tb_session='.length);
  }
  return localStorage.getItem('tb_edit_token');
}

async function startCheckout(plan) {
  const token = getAuthToken();
  if (!token) { location.href = '/join'; return; }
  try {
    const res = await fetch(EDGE_BASE + '/create-checkout', {
      method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token },
      body: JSON.stringify({ plan, billing: isAnnual ? 'annual' : 'monthly', success_url: location.origin + '/dashboard?upgraded=1', cancel_url: location.origin + '/pricing' })
    });
    const data = await res.json();
    if (data.url) location.href = data.url;
  } catch { alert('Could not start checkout. Please try again.'); }
}
</script>
</Base>
