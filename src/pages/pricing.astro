---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName;
---

<Base
  title={`Pricing — ${brandName}`}
  description={`Simple, transparent pricing for ${brandName}. Free to start. Pro plan with a 30-day ROI guarantee.`}
>
  <style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --brand: #FF5C00; --brand-dim: rgba(255,92,0,0.10); --brand-border: rgba(255,92,0,0.25);
  --reps: #00C853; --reps-dim: rgba(0,200,83,0.08); --reps-border: rgba(0,200,83,0.2);
  --surface: #0a0a0a; --surface-2: #111; --surface-3: #1c1c1c;
  --border: rgba(255,255,255,0.08); --text: #fff;
  --text-muted: rgba(255,255,255,0.55); --text-faint: rgba(255,255,255,0.25);
}
html { scroll-behavior: smooth; }
body {
  background: var(--surface); color: var(--text);
  font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; min-height: 100vh;
}
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  background: rgba(10,10,10,0.9); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
}
.nav-inner {
  max-width: 1100px; margin: 0 auto; padding: 0 24px;
  display: flex; align-items: center; justify-content: space-between; height: 60px;
}
.nav-logo {
  display: flex; align-items: center; gap: 10px;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 18px;
  text-decoration: none; color: var(--text);
}
.nav-cta {
  padding: 10px 20px; border-radius: 20px; background: var(--brand); color: #fff;
  font-family: 'Manrope', sans-serif; font-size: 13px; font-weight: 700;
  text-decoration: none; transition: background 0.2s;
}
.nav-cta:hover { background: #e05200; }

.pricing-wrap { max-width: 1000px; margin: 0 auto; padding: 100px 24px 80px; }
.pricing-header { text-align: center; margin-bottom: 48px; }
.pricing-label {
  font-size: 11px; font-weight: 700; color: var(--brand);
  text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px;
}
.pricing-title {
  font-family: 'Manrope', sans-serif; font-size: clamp(28px, 5vw, 48px); font-weight: 800;
  letter-spacing: -1px; margin-bottom: 12px;
}
.pricing-sub { font-size: 16px; color: var(--text-muted); max-width: 440px; margin: 0 auto; }

/* Billing toggle */
.billing-toggle {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  margin-bottom: 40px;
}
.billing-option {
  font-size: 13px; font-weight: 600; color: var(--text-muted); cursor: pointer;
}
.billing-option.active { color: var(--text); }
.toggle-switch {
  width: 48px; height: 26px; border-radius: 13px;
  background: var(--surface-3); border: 1px solid var(--border);
  position: relative; cursor: pointer; transition: background 0.2s;
}
.toggle-switch.annual { background: var(--brand); border-color: var(--brand); }
.toggle-knob {
  position: absolute; top: 3px; left: 3px;
  width: 18px; height: 18px; border-radius: 50%;
  background: #fff; transition: left 0.2s;
}
.toggle-switch.annual .toggle-knob { left: 25px; }
.billing-save {
  background: var(--reps-dim); border: 1px solid var(--reps-border);
  color: var(--reps); font-size: 11px; font-weight: 700;
  padding: 3px 8px; border-radius: 10px;
}

/* Plans grid */
.plans-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px; align-items: start;
}
.plan-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 24px; padding: 28px; position: relative;
  transition: border-color 0.2s;
}
.plan-card.popular {
  border-color: var(--brand-border);
  background: linear-gradient(135deg, rgba(255,92,0,0.06) 0%, var(--surface-2) 100%);
}
.popular-badge {
  position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  background: var(--brand); color: #fff;
  font-family: 'Manrope', sans-serif; font-size: 11px; font-weight: 700;
  padding: 4px 14px; border-radius: 20px; white-space: nowrap;
  letter-spacing: 0.04em; text-transform: uppercase;
}
.plan-name {
  font-family: 'Manrope', sans-serif; font-size: 13px; font-weight: 700;
  color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.08em;
  margin-bottom: 12px;
}
.plan-price {
  display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px;
}
.plan-price-value {
  font-family: 'Manrope', sans-serif; font-size: 40px; font-weight: 800;
  letter-spacing: -2px;
}
.plan-price-currency { font-size: 18px; font-weight: 700; color: var(--text-muted); }
.plan-price-period { font-size: 13px; color: var(--text-muted); }
.plan-price-annual { font-size: 11px; color: var(--reps); font-weight: 600; margin-bottom: 16px; min-height: 18px; }
.plan-desc { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }
.plan-btn {
  width: 100%; padding: 14px; border-radius: 12px;
  font-family: 'Manrope', sans-serif; font-size: 14px; font-weight: 700;
  cursor: pointer; transition: all 0.2s; border: none; margin-bottom: 24px;
}
.plan-btn-brand { background: var(--brand); color: #fff; }
.plan-btn-brand:hover { background: #e05200; }
.plan-btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }
.plan-btn-ghost:hover { border-color: rgba(255,255,255,0.2); }
.plan-features { display: flex; flex-direction: column; gap: 10px; }
.plan-feature {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 13px; color: var(--text-muted);
}
.plan-feature svg { flex-shrink: 0; margin-top: 2px; }
.plan-feature.included { color: var(--text); }
.plan-feature.excluded { opacity: 0.4; }
.plan-divider {
  height: 1px; background: var(--border); margin: 20px 0;
}

/* Comparison table */
.compare-section { margin-top: 60px; }
.compare-title {
  font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 800;
  text-align: center; margin-bottom: 24px;
}
.compare-table { width: 100%; border-collapse: collapse; }
.compare-table th {
  padding: 12px 16px; text-align: center;
  font-family: 'Manrope', sans-serif; font-size: 13px; font-weight: 700;
  border-bottom: 1px solid var(--border);
}
.compare-table th:first-child { text-align: left; }
.compare-table td {
  padding: 12px 16px; text-align: center;
  font-size: 13px; color: var(--text-muted);
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.compare-table td:first-child { text-align: left; color: var(--text); font-weight: 500; }
.compare-table tr:hover td { background: rgba(255,255,255,0.02); }
.check { color: var(--reps); font-size: 16px; }
.cross { color: var(--text-faint); font-size: 16px; }
.plan-highlight { color: var(--brand); font-weight: 700; }

footer {
  padding: 40px 24px; border-top: 1px solid var(--border); margin-top: 60px;
}
.footer-inner {
  max-width: 1100px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
}
.footer-logo {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 15px;
  text-decoration: none; color: var(--text);
}
.footer-copy { font-size: 12px; color: var(--text-faint); }
  </style>

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo">
      <svg width="30" height="30" viewBox="0 0 32 32"><rect width="32" height="32" rx="8" fill="#FF5C00"/><text x="16" y="23" font-family="Manrope,Arial,sans-serif" font-size="14" font-weight="800" text-anchor="middle" fill="white">TB</text></svg>
      {brandName}
    </a>
    <a href="/join" class="nav-cta">Get Your Page →</a>
  </div>
</nav>

<div class="pricing-wrap">

  <div class="pricing-header">
    <div class="pricing-label">Pricing</div>
    <h1 class="pricing-title">Invest AED 99.<br>Earn AED 10,000+.</h1>
    <p class="pricing-sub">Pro pays for itself the moment your first affiliate commission lands. Most trainers see ROI in under 7 days.</p>
    <div style="display:inline-flex;align-items:center;gap:8px;margin-top:16px;padding:8px 16px;border-radius:100px;border:1px solid rgba(0,200,83,0.25);background:rgba(0,200,83,0.06);font-size:12px;font-weight:600;color:#00C853">
      🛡 ROI Guarantee: 1,000 AED in 30 days or full refund
    </div>
  </div>

  <!-- Billing toggle -->
  <div class="billing-toggle">
    <span class="billing-option active" id="monthly-label" onclick="setBilling('monthly')">Monthly</span>
    <div class="toggle-switch" id="billing-switch" onclick="toggleBilling()">
      <div class="toggle-knob"></div>
    </div>
    <span class="billing-option" id="annual-label" onclick="setBilling('annual')">Annual</span>
    <span class="billing-save">Save 20%</span>
  </div>

  <!-- Plans -->
  <div class="plans-grid">

    <!-- Free -->
    <div class="plan-card">
      <div class="plan-name">Free</div>
      <div class="plan-price">
        <span class="plan-price-currency">AED</span>
        <span class="plan-price-value">0</span>
        <span class="plan-price-period">/mo</span>
      </div>
      <div class="plan-price-annual">&nbsp;</div>
      <div class="plan-desc">Get your verified profile live in 2 minutes. No credit card required.</div>
      <button class="plan-btn plan-btn-ghost" onclick="location.href='/join'">Get Started Free</button>
      <div class="plan-features">
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Public profile page
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          REPs UAE verified badge
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          WhatsApp CTA button
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          1 session package
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.2)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          Fitness assessment tool
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.2)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          WhatsApp lead notifications
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.2)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          Analytics &amp; lead tracking
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(255,255,255,0.2)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          Priority search placement
        </div>
      </div>
    </div>

    <!-- Pro (Popular) -->
    <div class="plan-card popular">
      <div class="popular-badge">Most Popular</div>
      <div class="plan-name">Pro</div>
      <div class="plan-price">
        <span class="plan-price-currency">AED</span>
        <span class="plan-price-value" id="pro-price">99</span>
        <span class="plan-price-period">/mo</span>
      </div>
      <div class="plan-price-annual" id="pro-annual-note">&nbsp;</div>
      <div class="plan-desc">The complete income OS. Passive income from affiliates, digital products, and Grand Slam Offers — all in one place.</div>
      <button class="plan-btn plan-btn-brand" onclick="startCheckout('pro')">Unlock Passive Income →</button>
      <div class="plan-features">
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Everything in Free
        </div>
        <div class="plan-feature included" style="background:rgba(255,92,0,0.04);border-radius:8px;padding:6px 8px;margin:-2px 0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#FF5C00"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong style="color:#FF5C00">💰 Master Affiliate Vault</strong> <span style="font-size:11px;color:var(--text-muted)">— earn from Gymshark, ZEROFAT &amp; more</span>
        </div>
        <div class="plan-feature included" style="background:rgba(255,92,0,0.04);border-radius:8px;padding:6px 8px;margin:-2px 0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#FF5C00"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong style="color:#FF5C00">📦 Digital Product Hub</strong> <span style="font-size:11px;color:var(--text-muted)">— sell PDFs, plans &amp; courses (5% fee)</span>
        </div>
        <div class="plan-feature included" style="background:rgba(255,92,0,0.04);border-radius:8px;padding:6px 8px;margin:-2px 0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#FF5C00"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong style="color:#FF5C00">🎯 Grand Slam Offer Builder</strong> <span style="font-size:11px;color:var(--text-muted)">— AI outcome + guarantee cards</span>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Unlimited session packages
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>WhatsApp lead notifications</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>Priority search placement</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Transformation gallery (9 photos)
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>Analytics dashboard + weekly report</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Remove TrainedBy branding
        </div>
      </div>
    </div>

    <!-- Premium -->
    <div class="plan-card">
      <div class="plan-name">Premium</div>
      <div class="plan-price">
        <span class="plan-price-currency">AED</span>
        <span class="plan-price-value" id="premium-price">199</span>
        <span class="plan-price-period">/mo</span>
      </div>
      <div class="plan-price-annual" id="premium-annual-note">&nbsp;</div>
      <div class="plan-desc">For elite trainers and gym owners managing multiple profiles.</div>
      <button class="plan-btn plan-btn-brand" style="background:var(--surface-3);color:var(--text);border:1px solid var(--border);" onmouseover="this.style.background='var(--brand)';this.style.borderColor='var(--brand)'" onmouseout="this.style.background='var(--surface-3)';this.style.borderColor='var(--border)'" onclick="startCheckout('premium')">Get Premium</button>
      <div class="plan-features">
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Everything in Pro
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>Up to 5 trainer profiles</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Gym / agency page
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Featured trainer spotlight
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Priority support
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          Custom domain (coming soon)
        </div>
      </div>
    </div>

  </div>

  <!-- Comparison table -->
  <div class="compare-section">
    <div class="compare-title">Full Comparison</div>
    <table class="compare-table">
      <thead>
        <tr>
          <th>Feature</th>
          <th>Free</th>
          <th style="color:var(--brand);">Pro</th>
          <th>Premium</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Public profile page</td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td></tr>
        <tr><td>REPs UAE verified badge</td><td><span class="check">✓</span></td><td><span class="check">✓</span></td><td><span class="check">✓</span></td></tr>
