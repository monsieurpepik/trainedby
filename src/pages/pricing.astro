---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import { getMarket } from '../lib/market.ts';
import { getLocale, t, getBrand } from '../lib/i18n.ts';
const market = getMarket(Astro.url.hostname);
const locale = getLocale(Astro.request);
const brand = getBrand(locale);
const brandName = brand.name;
// Per-market pricing
const proMonthly = market.currency === 'AED' ? 99 : market.currency === 'GBP' ? 29 : market.currency === 'EUR' ? 29 : market.currency === 'INR' ? 1999 : 29;
const proAnnual = Math.round(proMonthly * 0.8);
const premiumMonthly = market.currency === 'AED' ? 199 : market.currency === 'GBP' ? 59 : market.currency === 'EUR' ? 59 : market.currency === 'INR' ? 3999 : 59;
const premiumAnnual = Math.round(premiumMonthly * 0.8);
const pricingHeadline = t(locale, 'pricing.headline').replace('{price}', `${market.currency} ${proMonthly}`);
const DEMO_SLUGS: Record<string, string> = {
  'en-ae': 'sarah-al-mansoori',
  'en-uk': 'james-hartley',
  'en-us': 'marcus-johnson',
  'en-in': 'arjun-sharma',
  'es':    'lucia-fernandez',
  'fr':    'thomas-moreau',
  'it':    'giulia-romano',
};
const demoSlug = DEMO_SLUGS[locale] ?? 'sarah-al-mansoori';
---

<Base
  title={`Pricing - ${brandName}`}
  description={`Simple, transparent pricing for ${brandName}. Free to start. Pro plan with a 30-day ROI guarantee.`}
>
  <Fragment slot="head">
    <style>
      :root {
        --bg: #FFFFFF;
        --surface: #FAFAF9;
        --surface-2: #F5F4F3;
        --surface-3: #E8E5E2;
        --text: #1A1411;
        --text-2: #4A4240;
        --text-muted: #6B6460;
        --text-faint: #9B9290;
        --border: rgba(0,0,0,0.07);
        --border-hover: rgba(0,0,0,0.15);
        --border-strong: rgba(0,0,0,0.20);
        --brand: #FF5C00;
        --brand-hover: #e05200;
        --brand-dim: rgba(255,92,0,0.08);
        --brand-border: rgba(255,92,0,0.20);
        --reps: #16a34a;
        --reps-dim: rgba(22,163,74,0.08);
        --reps-border: rgba(22,163,74,0.20);
      }
    </style>
  </Fragment>
  <style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--bg); color: var(--text);
  font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 15px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; min-height: 100vh;
}

/* ── Nav layout (Nav.astro renders the HTML) ─────────────── */
.nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 50;
  display: flex; align-items: center; justify-content: space-between;
  padding: 0 32px; height: 64px;
  background: rgba(255,255,255,0.85); backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--border);
  transition: background 0.3s, box-shadow 0.3s;
}
.nav.scrolled {
  background: rgba(255,255,255,0.95);
  box-shadow: 0 1px 12px rgba(0,0,0,0.07);
}
.nav-logo {
  font-family: 'DM Sans', sans-serif; font-weight: 900; font-size: 20px;
  text-decoration: none; color: var(--text); display: flex; align-items: center;
}
.nav-links { display: flex; gap: 28px; }
.nav-links a {
  font-size: 14px; font-weight: 500; color: var(--text-muted);
  text-decoration: none; transition: color 0.2s;
}
.nav-links a:hover { color: var(--text); }
.nav-cta {
  background: var(--text); color: var(--bg);
  padding: 9px 18px; border-radius: 20px;
  font-size: 13px; font-weight: 700; text-decoration: none;
  transition: opacity 0.2s;
}
.nav-cta:hover { opacity: 0.85; }
/* Logo "By" sub-span color on light nav */
:global(#nav .nav-logo span) { color: var(--text); }
:global(#nav .nav-logo span span) { color: var(--brand) !important; }
@media (max-width: 768px) {
  .nav-links { display: none; }
  .nav { padding: 0 20px; }
}

.pricing-wrap { max-width: 1000px; margin: 0 auto; padding: 100px 24px 80px; }
.pricing-header { text-align: center; margin-bottom: 48px; }
.pricing-label {
  font-size: 11px; font-weight: 700; color: var(--brand);
  text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 10px;
}
.pricing-title {
  font-family: var(--font-display, 'DM Sans', sans-serif); font-size: clamp(28px, 5vw, 48px); font-weight: 900;
  letter-spacing: -0.04em; margin-bottom: 12px;
}
.pricing-sub { font-size: 16px; color: var(--text-muted); max-width: 440px; margin: 0 auto; }

/* Billing toggle */
.billing-toggle {
  display: flex; align-items: center; justify-content: center; gap: 12px;
  margin-bottom: 40px;
}
.billing-option {
  font-size: 13px; font-weight: 600; color: var(--text-muted); cursor: pointer;
}
.billing-option.active { color: var(--text); }
.toggle-switch {
  width: 48px; height: 26px; border-radius: 13px;
  background: var(--surface-3); border: 1px solid var(--border);
  position: relative; cursor: pointer; transition: background 0.2s;
}
.toggle-switch.annual { background: var(--brand); border-color: var(--brand); }
.toggle-knob {
  position: absolute; top: 3px; left: 3px;
  width: 18px; height: 18px; border-radius: 50%;
  background: #fff; transition: left 0.2s;
}
.toggle-switch.annual .toggle-knob { left: 25px; }
.billing-save {
  background: var(--reps-dim); border: 1px solid var(--reps-border);
  color: var(--reps); font-size: 11px; font-weight: 700;
  padding: 3px 8px; border-radius: 10px;
}

/* Plans grid */
.plans-grid {
  display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 16px; align-items: start;
}
.plan-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 24px; padding: 28px; position: relative;
  transition: border-color 0.2s;
}
/* Pro card: metallic gold treatment */
.plan-card.popular {
  border-color: var(--pro-border, rgba(197,162,39,0.35));
  background: linear-gradient(135deg, rgba(197,162,39,0.07) 0%, var(--surface-2, #111) 60%);
  box-shadow: 0 0 0 1px var(--pro-border, rgba(197,162,39,0.35)), 0 0 40px var(--pro-dim, rgba(197,162,39,0.10));
  position: relative;
}
.plan-card.popular::before {
  content: '';
  position: absolute;
  inset: 0;
  border-radius: 24px;
  background: linear-gradient(135deg, rgba(245,208,107,0.04) 0%, transparent 55%);
  pointer-events: none;
}
.popular-badge {
  position: absolute; top: -12px; left: 50%; transform: translateX(-50%);
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  color: #0a0a0a;
  font-family: var(--font-display, 'DM Sans', sans-serif); font-size: 11px; font-weight: 800;
  padding: 4px 14px; border-radius: 20px; white-space: nowrap;
  letter-spacing: 0.06em; text-transform: uppercase;
  box-shadow: 0 2px 12px rgba(197,162,39,0.4);
}
.plan-name {
  font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 11px; font-weight: 700;
  color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.1em;
  margin-bottom: 12px;
}
/* Pro plan name gets metallic gold color */
.plan-card.popular .plan-name {
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}
.plan-price {
  display: flex; align-items: baseline; gap: 4px; margin-bottom: 4px;
}
.plan-price-value {
  font-family: var(--font-display, 'DM Sans', sans-serif); font-size: 40px; font-weight: 900;
  letter-spacing: -0.05em;
}
.plan-price-currency { font-size: 18px; font-weight: 700; color: var(--text-muted); }
.plan-price-period { font-size: 13px; color: var(--text-muted); }
.plan-price-annual { font-size: 11px; color: var(--reps); font-weight: 600; margin-bottom: 16px; min-height: 18px; }
.plan-desc { font-size: 13px; color: var(--text-muted); margin-bottom: 20px; line-height: 1.6; }
.plan-btn {
  width: 100%; padding: 14px; border-radius: 12px;
  font-family: var(--font-display, 'DM Sans', sans-serif); font-size: 14px; font-weight: 700;
  cursor: pointer; transition: all 0.2s; border: none; margin-bottom: 24px;
}
.plan-btn-brand { background: var(--brand); color: #fff; }
.plan-btn-brand:hover { background: var(--brand-hover, #e05200); transform: translateY(-1px); }
/* Pro CTA button: metallic gold */
.plan-card.popular .plan-btn-brand {
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  color: #0a0a0a;
  box-shadow: 0 4px 20px rgba(197,162,39,0.35);
}
.plan-card.popular .plan-btn-brand:hover {
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  box-shadow: 0 6px 28px rgba(197,162,39,0.5);
  transform: translateY(-2px);
}
.plan-btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border); }
.plan-btn-ghost:hover { border-color: var(--border-hover); }
.plan-features { display: flex; flex-direction: column; gap: 10px; }
.plan-feature {
  display: flex; align-items: flex-start; gap: 10px;
  font-size: 13px; color: var(--text-muted);
}
.plan-feature svg { flex-shrink: 0; margin-top: 2px; }
.plan-feature.included { color: var(--text); }
.plan-feature.excluded { opacity: 0.4; }
.plan-divider {
  height: 1px; background: var(--border); margin: 20px 0;
}

/* Comparison table */
.compare-section { margin-top: 60px; }
.compare-title {
  font-family: var(--font-display, 'DM Sans', sans-serif); font-size: 22px; font-weight: 900;
  text-align: center; margin-bottom: 24px; letter-spacing: -0.03em;
}
.compare-table { width: 100%; border-collapse: collapse; }
.compare-table th {
  padding: 12px 16px; text-align: center;
  font-family: var(--font-body, 'DM Sans', sans-serif); font-size: 12px; font-weight: 700;
  border-bottom: 1px solid var(--border); letter-spacing: 0.02em;
}
.compare-table th:first-child { text-align: left; }
.compare-table td {
  padding: 12px 16px; text-align: center;
  font-size: 13px; color: var(--text-muted);
  border-bottom: 1px solid var(--border);
}
.compare-table td:first-child { text-align: left; color: var(--text); font-weight: 500; }
.compare-table tr:hover td { background: rgba(0,0,0,0.02); }
.check { color: var(--reps); font-size: 16px; }
.cross { color: var(--text-faint); font-size: 16px; }
.plan-highlight { color: var(--brand); font-weight: 700; }

/* ── Mobile responsive ────────────────────────────────────────────── */
@media (max-width: 640px) {
  .pricing-wrap { padding: 80px 16px 40px; }
  .plans-grid { grid-template-columns: 1fr; }
  .plan-card { padding: 24px 20px; }
  .billing-toggle { flex-wrap: wrap; gap: 8px; }
  .compare-section { overflow-x: auto; -webkit-overflow-scrolling: touch; }
  .compare-table { min-width: 480px; }
}

/* ── Safe area for notched phones ─────────────────────────────────── */
.pricing-wrap {
  padding-bottom: max(80px, calc(80px + env(safe-area-inset-bottom)));
}

footer {
  padding: 40px 24px; border-top: 1px solid var(--border); margin-top: 60px;
  padding-bottom: max(40px, calc(40px + env(safe-area-inset-bottom)));
}
.footer-inner {
  max-width: 1100px; margin: 0 auto;
  display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 16px;
}
.footer-logo {
  display: flex; align-items: center; gap: 8px;
  font-family: 'DM Sans', sans-serif; font-weight: 800; font-size: 15px;
  text-decoration: none; color: var(--text);
}
.footer-copy { font-size: 12px; color: var(--text-faint); }
  </style>

<Nav variant="landing" />

<div class="pricing-wrap">

  <div class="pricing-header">
    <div class="pricing-label">{t(locale, 'pricing.title')}</div>
    <h1 class="pricing-title" set:html={pricingHeadline.replace('. ', '.<br>')}></h1>
    <p class="pricing-sub">{t(locale, 'pricing.sub_ext')}</p>
  </div>

  <!-- Billing toggle -->
  <div class="billing-toggle">
    <span class="billing-option active" id="monthly-label" onclick="setBilling('monthly')">{t(locale, 'pricing.monthly_label')}</span>
    <div class="toggle-switch" id="billing-switch" onclick="toggleBilling()">
      <div class="toggle-knob"></div>
    </div>
    <span class="billing-option" id="annual-label" onclick="setBilling('annual')">{t(locale, 'pricing.annual_label')}</span>
    <span class="billing-save">{t(locale, 'pricing.save')}</span>
  </div>

  <!-- Plans -->
  <div class="plans-grid">

    <!-- Free -->
    <div class="plan-card">
      <div class="plan-name">{t(locale, 'pricing.free_name')}</div>
      <div class="plan-price">
        <span class="plan-price-currency">{market.currency}</span>
        <span class="plan-price-value">0</span>
        <span class="plan-price-period">/{t(locale, 'pricing.monthly')}</span>
      </div>
      <div class="plan-price-annual">&nbsp;</div>
      <div class="plan-desc">{t(locale, 'pricing.free_desc')}</div>
      <button class="plan-btn plan-btn-ghost" onclick="location.href='/join'">{t(locale, 'pricing.get_started_free')}</button>
      <div class="plan-features">
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_profile')}
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {market.certificationBody} {t(locale, 'pricing.f_badge')}
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_whatsapp')}
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_1_package')}
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(26,20,17,0.15)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          {t(locale, 'pricing.f_assessment')}
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(26,20,17,0.15)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          {t(locale, 'pricing.f_ai')}
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(26,20,17,0.15)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          {t(locale, 'pricing.f_analytics')}
        </div>
        <div class="plan-feature excluded">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="rgba(26,20,17,0.15)"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm5 13.59L15.59 17 12 13.41 8.41 17 7 15.59 10.59 12 7 8.41 8.41 7 12 10.59 15.59 7 17 8.41 13.41 12 17 15.59z"/></svg>
          {t(locale, 'pricing.f_priority')}
        </div>
      </div>
    </div>

    <!-- Pro (Popular) -->
    <div class="plan-card popular">
      <div class="popular-badge">{t(locale, 'pricing.popular')}</div>
      <div class="plan-name">{t(locale, 'pricing.pro_name')}</div>
      <div class="plan-price">
        <span class="plan-price-currency">{market.currency}</span>
        <span class="plan-price-value" id="pro-price">{proMonthly}</span>
        <span class="plan-price-period">/{t(locale, 'pricing.monthly')}</span>
      </div>
      <div class="plan-price-annual" id="pro-annual-note">&nbsp;</div>
      <div class="plan-desc">{t(locale, 'pricing.pro_desc')}</div>
      <button class="plan-btn plan-btn-brand" onclick="startCheckout('pro')">{t(locale, 'pricing.upgrade_pro')}</button>
      <a href={`/${demoSlug}`} style="display:block;text-align:center;margin-top:10px;font-size:12px;color:var(--text-muted);text-decoration:underline;text-underline-offset:3px" target="_blank" rel="noopener">See an example Pro profile</a>
      <div class="plan-features">
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_everything_free')}
        </div>
        <div class="plan-feature included" style="background:rgba(255,92,0,0.04);border-radius:8px;padding:6px 8px;margin:-2px 0">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#FF5C00"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong style="color:#FF5C00">📊 {t(locale, 'pricing.f_analytics')}</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_unlimited')} {t(locale, 'pricing.f_packages').toLowerCase()}
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>{t(locale, 'pricing.f_ai')} ({t(locale, 'pricing.f_unlimited').toLowerCase()})</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>{t(locale, 'pricing.f_priority')}</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_gallery')} ({t(locale, 'pricing.f_9_photos')})
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          <strong>{t(locale, 'pricing.f_analytics')}</strong>
        </div>
        <div class="plan-feature included">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="#00C853"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
          {t(locale, 'pricing.f_branding')}
        </div>
      </div>
    </div>

    <!-- Premium -->
    <div class="plan-card">
      <div class="plan-name">{t(locale, 'pricing.premium_name')}</div>
      <div class="plan-price">
        <span class="plan-price-currency">{market.currency}</span>
        <span class="plan-price-value" id="premium-price">{premiumMonthly}</span>
        <span class="plan-price-period">/{t(locale, 'pricing.monthly')}</span>
      </div>
      <div class="plan-price-annual" id="premium-annual-note">&nbsp;</div>
      <div class="plan-desc">{t(locale, 'pricing.premium_desc')}</div>
