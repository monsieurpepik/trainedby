---
import Base from '../layouts/Base.astro';
---

<Base
  title="Edit Profile — TrainedBy"
  description="Edit your TrainedBy trainer profile, packages, and settings."
>
  <style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --brand: #FF5C00; --brand-dim: rgba(255,92,0,0.10); --brand-border: rgba(255,92,0,0.25);
  --reps: #00C853; --reps-dim: rgba(0,200,83,0.08); --reps-border: rgba(0,200,83,0.2);
  --surface: #0a0a0a; --surface-2: #111; --surface-3: #1c1c1c; --surface-4: #242424;
  --border: rgba(255,255,255,0.08); --border-hover: rgba(255,255,255,0.14);
  --text: #fff; --text-muted: rgba(255,255,255,0.5); --text-faint: rgba(255,255,255,0.25);
}
html { scroll-behavior: smooth; }
body {
  background: var(--surface); color: var(--text);
  font-family: 'Inter', sans-serif; font-size: 14px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; min-height: 100vh;
}

/* ===== LAYOUT ===== */
.edit-wrap {
  max-width: 480px; margin: 0 auto;
  padding: 0 20px max(60px, env(safe-area-inset-bottom));
}
.edit-header {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: max(20px, env(safe-area-inset-top)); padding-bottom: 20px;
  position: sticky; top: 0; background: var(--surface); z-index: 10;
  border-bottom: 1px solid var(--border); margin: 0 -20px; padding-left: 20px; padding-right: 20px;
}
.edit-logo {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 16px;
  text-decoration: none; color: var(--text);
}
.header-actions { display: flex; align-items: center; gap: 10px; }
.header-btn {
  padding: 8px 16px; border-radius: 20px;
  font-family: 'Manrope', sans-serif; font-size: 12px; font-weight: 700;
  cursor: pointer; transition: all 0.2s; border: none;
}
.header-btn-ghost {
  background: transparent; color: var(--text-muted);
  border: 1px solid var(--border);
}
.header-btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }
.header-btn-brand { background: var(--brand); color: #fff; }
.header-btn-brand:hover { background: #e05200; }
.header-btn-brand:disabled { opacity: 0.5; cursor: not-allowed; }

/* ===== AUTH GATE ===== */
.auth-gate {
  display: flex; flex-direction: column; align-items: center;
  padding: 60px 0; text-align: center;
}
.auth-gate h2 {
  font-family: 'Manrope', sans-serif; font-size: 22px; font-weight: 800;
  margin-bottom: 8px;
}
.auth-gate p { font-size: 14px; color: var(--text-muted); margin-bottom: 28px; max-width: 280px; line-height: 1.6; }
.auth-field {
  width: 100%; max-width: 340px; padding: 14px 16px;
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; color: var(--text); font-family: 'Inter', sans-serif;
  font-size: 15px; outline: none; margin-bottom: 12px;
  transition: border-color 0.2s;
}
.auth-field:focus { border-color: var(--brand); }
.auth-btn {
  width: 100%; max-width: 340px; padding: 15px;
  background: var(--brand); color: #fff; border: none;
  border-radius: 12px; font-family: 'Manrope', sans-serif;
  font-size: 15px; font-weight: 700; cursor: pointer; transition: all 0.2s;
}
.auth-btn:hover { background: #e05200; }
.auth-btn:disabled { opacity: 0.5; cursor: not-allowed; }
.auth-hint { font-size: 11px; color: var(--text-faint); margin-top: 8px; }

/* ===== SECTIONS ===== */
.edit-section {
  padding: 24px 0; border-bottom: 1px solid var(--border);
}
.edit-section:last-child { border-bottom: none; }
.section-heading {
  font-family: 'Manrope', sans-serif; font-size: 15px; font-weight: 800;
  margin-bottom: 4px;
}
.section-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 18px; }

/* ===== FORM FIELDS ===== */
.field { margin-bottom: 16px; }
.field label {
  display: block; font-size: 11px; font-weight: 600;
  color: var(--text-muted); text-transform: uppercase;
  letter-spacing: 0.06em; margin-bottom: 7px;
}
.field input, .field select, .field textarea {
  width: 100%; padding: 13px 15px;
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; color: var(--text);
  font-family: 'Inter', sans-serif; font-size: 14px; outline: none;
  transition: border-color 0.2s;
}
.field input:focus, .field select:focus, .field textarea:focus { border-color: var(--brand); }
.field textarea { resize: vertical; min-height: 90px; }
.field-hint { font-size: 11px; color: var(--text-faint); margin-top: 4px; }

/* ===== AVATAR EDITOR ===== */
.avatar-editor {
  display: flex; align-items: center; gap: 16px; margin-bottom: 20px;
}
.avatar-edit-circle {
  width: 80px; height: 80px; border-radius: 50%;
  background: var(--surface-3); border: 2px solid var(--border);
  position: relative; overflow: hidden; cursor: pointer; flex-shrink: 0;
}
.avatar-edit-circle img {
  width: 100%; height: 100%; object-fit: cover;
}
.avatar-edit-overlay {
  position: absolute; inset: 0; background: rgba(0,0,0,0.5);
  display: flex; align-items: center; justify-content: center;
  opacity: 0; transition: opacity 0.2s;
}
.avatar-edit-circle:hover .avatar-edit-overlay { opacity: 1; }
.avatar-edit-circle input[type="file"] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer;
}

/* ===== TOGGLE PILLS ===== */
.toggle-row { display: flex; gap: 8px; flex-wrap: wrap; }
.toggle-pill {
  padding: 7px 13px; border-radius: 20px;
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text-muted); font-size: 12px; font-weight: 600;
  cursor: pointer; transition: all 0.15s; user-select: none;
}
.toggle-pill.active {
  background: var(--brand-dim); border-color: var(--brand-border); color: var(--brand);
}

/* ===== PACKAGE CARDS ===== */
.package-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; padding: 14px; margin-bottom: 10px;
}
.package-card-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 12px;
}
.package-delete {
  width: 28px; height: 28px; border-radius: 50%;
  background: rgba(255,85,85,0.08); border: 1px solid rgba(255,85,85,0.15);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; color: #ff5555; font-size: 16px; line-height: 1;
}

/* ===== AVAILABILITY TOGGLE ===== */
.avail-toggle {
  display: flex; align-items: center; justify-content: space-between;
  padding: 14px 16px; background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; cursor: pointer; transition: border-color 0.2s;
}
.avail-toggle:hover { border-color: var(--border-hover); }
.avail-label { font-size: 14px; font-weight: 600; }
.avail-sub { font-size: 11px; color: var(--text-muted); margin-top: 2px; }
.switch {
  width: 44px; height: 24px; border-radius: 12px;
  background: var(--surface-3); border: 1px solid var(--border);
  position: relative; transition: background 0.2s; flex-shrink: 0;
}
.switch.on { background: var(--reps); border-color: var(--reps); }
.switch-knob {
  position: absolute; top: 2px; left: 2px;
  width: 18px; height: 18px; border-radius: 50%;
  background: #fff; transition: left 0.2s;
}
.switch.on .switch-knob { left: 22px; }

/* ===== GALLERY UPLOAD ===== */
.gallery-grid-edit {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 6px;
  margin-bottom: 12px;
}
.gallery-item-edit {
  aspect-ratio: 1; border-radius: 8px; overflow: hidden;
  background: var(--surface-3); border: 1px solid var(--border);
  position: relative; cursor: pointer;
}
.gallery-item-edit img {
  width: 100%; height: 100%; object-fit: cover;
}
.gallery-item-delete {
  position: absolute; top: 4px; right: 4px;
  width: 22px; height: 22px; border-radius: 50%;
  background: rgba(0,0,0,0.7); border: 1px solid rgba(255,85,85,0.3);
  display: flex; align-items: center; justify-content: center;
  font-size: 12px; color: #ff5555; cursor: pointer;
}
.gallery-add {
  aspect-ratio: 1; border-radius: 8px;
  background: var(--surface-2); border: 2px dashed var(--border);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  cursor: pointer; transition: all 0.2s; position: relative;
}
.gallery-add:hover { border-color: var(--brand); }
.gallery-add input[type="file"] {
  position: absolute; inset: 0; opacity: 0; cursor: pointer;
}

/* ===== DANGER ZONE ===== */
.danger-zone {
  padding: 16px; border-radius: 12px;
  background: rgba(255,85,85,0.04); border: 1px solid rgba(255,85,85,0.12);
}
.danger-title { font-size: 13px; font-weight: 700; color: #ff5555; margin-bottom: 4px; }
.danger-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 12px; }
.danger-btn {
  padding: 10px 18px; border-radius: 8px;
  background: transparent; border: 1px solid rgba(255,85,85,0.3);
  color: #ff5555; font-size: 13px; font-weight: 600; cursor: pointer;
  transition: all 0.2s;
}
.danger-btn:hover { background: rgba(255,85,85,0.08); }

/* ===== TOAST ===== */
.toast {
  position: fixed; bottom: max(24px, env(safe-area-inset-bottom));
  left: 50%; transform: translateX(-50%) translateY(80px);
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text); padding: 12px 20px; border-radius: 24px;
  font-size: 13px; font-weight: 600; z-index: 100;
  transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
  white-space: nowrap; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.success { background: var(--reps-dim); border-color: var(--reps-border); color: var(--reps); }
.toast.error { background: rgba(255,85,85,0.08); border-color: rgba(255,85,85,0.2); color: #ff5555; }

/* ===== SPINNER ===== */
.spinner {
  display: inline-block; width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.2); border-top-color: #fff;
  border-radius: 50%; animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.hidden { display: none !important; }
  </style>

<div class="edit-wrap">

  <!-- Header -->
  <div class="edit-header">
    <a href="/" class="edit-logo">
      <svg width="26" height="26" viewBox="0 0 32 32"><rect width="32" height="32" rx="8" fill="#FF5C00"/><text x="16" y="23" font-family="Manrope,Arial,sans-serif" font-size="14" font-weight="800" text-anchor="middle" fill="white">TB</text></svg>
      Edit Profile
    </a>
    <div class="header-actions">
      <a id="view-profile-link" href="#" class="header-btn header-btn-ghost" style="text-decoration:none;">View</a>
      <button id="save-btn" class="header-btn header-btn-brand" onclick="saveAll()">Save</button>
    </div>
  </div>

  <!-- ===== AUTH GATE ===== -->
  <div id="auth-gate">
    <div class="auth-gate">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" style="margin-bottom:20px;"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
      <h2>Sign in to edit</h2>
      <p>Enter your email to receive a magic link — no password needed.</p>
      <input class="auth-field" type="email" id="auth-email" placeholder="your@email.com" autocomplete="email">
      <div id="auth-error" style="display:none;font-size:12px;color:#ff5555;margin-bottom:10px;max-width:340px;"></div>
      <button class="auth-btn" id="auth-btn" onclick="sendMagicLink()">Send Magic Link</button>
      <div class="auth-hint">Check your inbox — link expires in 15 minutes.</div>
    </div>
    <div id="auth-sent" class="hidden" style="text-align:center;padding:40px 0;">
      <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="var(--brand)" stroke-width="1.5" style="margin-bottom:16px;"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
      <h2 style="font-family:'Manrope',sans-serif;font-size:20px;font-weight:800;margin-bottom:8px;">Check your inbox</h2>
      <p style="font-size:14px;color:var(--text-muted);max-width:280px;margin:0 auto;">We sent a magic link to <strong id="auth-sent-email" style="color:var(--brand);"></strong>. Click it to sign in.</p>
    </div>
  </div>

  <!-- ===== EDIT FORM (shown after auth) ===== -->
  <div id="edit-form" class="hidden">

    <!-- Section: Profile Photo -->
    <div class="edit-section">
      <div class="section-heading">Profile Photo</div>
      <div class="section-sub">Your photo appears on your public profile and in search results.</div>
      <div class="avatar-editor">
        <div class="avatar-edit-circle" id="avatar-circle">
          <img id="avatar-img" src="" alt="Avatar">
          <div class="avatar-edit-overlay">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2"><path d="M23 19a2 2 0 01-2 2H3a2 2 0 01-2-2V8a2 2 0 012-2h4l2-3h6l2 3h4a2 2 0 012 2z"/><circle cx="12" cy="13" r="4"/></svg>
          </div>
          <input type="file" accept="image/*" onchange="changeAvatar(this)">
        </div>
        <div>
          <div style="font-size:13px;font-weight:600;margin-bottom:4px;">Change photo</div>
          <div style="font-size:11px;color:var(--text-muted);">JPG or PNG, at least 400×400px</div>
          <div id="avatar-upload-status" style="font-size:11px;color:var(--brand);margin-top:4px;display:none;">Uploading...</div>
        </div>
      </div>
    </div>

    <!-- Section: Basic Info -->
    <div class="edit-section">
      <div class="section-heading">Basic Info</div>
      <div class="section-sub">Your name, title, and bio are the first things clients see.</div>

      <div class="field">
        <label>Full Name</label>
        <input type="text" id="e-name" placeholder="Your full name" autocomplete="name">
      </div>
      <div class="field">
        <label>Title / Role</label>
        <input type="text" id="e-title" placeholder="e.g. Strength & Conditioning Coach" maxlength="60">
      </div>
      <div class="field">
        <label style="display:flex;align-items:center;justify-content:space-between;">Bio <button type="button" onclick="generateAIBio()" style="background:var(--brand-dim);border:1px solid var(--brand-border);color:var(--brand);font-size:11px;font-weight:700;padding:4px 10px;border-radius:8px;cursor:pointer;font-family:'Manrope',sans-serif;" id="ai-bio-btn">✦ Write with AI</button></label>
        <textarea id="e-bio" maxlength="400" oninput="document.getElementById('bio-count').textContent=this.value.length"></textarea>
        <div class="field-hint"><span id="bio-count">0</span>/400 characters</div>
      </div>
      <div style="display:flex;gap:12px;">
        <div class="field" style="flex:1;">
          <label>Years Experience</label>
          <input type="number" id="e-exp" min="0" max="50" inputmode="numeric">
        </div>
        <div class="field" style="flex:1;">
          <label>Clients Trained</label>
          <input type="number" id="e-clients" min="0" inputmode="numeric">
        </div>
      </div>
    </div>

    <!-- Section: Specialties -->
    <div class="edit-section">
      <div class="section-heading">Specialties</div>
      <div class="section-sub">Select all that apply — shown as pills on your profile.</div>
      <div class="toggle-row" id="spec-row">
        <div class="toggle-pill" onclick="togglePill(this,'spec','Strength')">Strength</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Fat Loss')">Fat Loss</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Muscle Gain')">Muscle Gain</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','HIIT')">HIIT</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Cardio')">Cardio</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Yoga')">Yoga</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Pilates')">Pilates</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','CrossFit')">CrossFit</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Boxing')">Boxing</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Nutrition')">Nutrition</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Rehabilitation')">Rehabilitation</div>
        <div class="toggle-pill" onclick="togglePill(this,'spec','Sport Specific')">Sport Specific</div>
      </div>
    </div>

    <!-- Section: Availability -->
    <div class="edit-section">
      <div class="section-heading">Availability</div>
      <div class="section-sub">Let clients know if you're taking new clients.</div>
      <div class="avail-toggle" onclick="toggleAvailability()">
        <div>
          <div class="avail-label">Accepting New Clients</div>
          <div class="avail-sub" id="avail-sub-text">Currently showing as available</div>
        </div>
        <div class="switch" id="avail-switch">
          <div class="switch-knob"></div>
        </div>
      </div>
    </div>

    <!-- Section: Session Packages -->
    <div class="edit-section">
      <div class="section-heading">Session Packages</div>
      <div class="section-sub">Clients see these on your profile. Add up to 5 packages.</div>
      <div id="packages-edit-list"></div>
      <button onclick="addEditPackage()" style="width:100%;padding:12px;border-radius:10px;background:transparent;border:1px dashed var(--border);color:var(--text-muted);font-size:13px;font-weight:600;cursor:pointer;transition:all 0.2s;" onmouseover="this.style.borderColor='var(--brand)';this.style.color='var(--brand)'" onmouseout="this.style.borderColor='var(--border)';this.style.color='var(--text-muted)'">
        + Add Package
      </button>
    </div>

    <!-- Section: Transformation Gallery -->
    <div class="edit-section">
      <div class="section-heading">Transformation Gallery</div>
      <div class="section-sub">Before/after photos build trust. Add up to 9 images.</div>
      <div class="gallery-grid-edit" id="gallery-edit-grid">
        <div class="gallery-add">
          <input type="file" accept="image/*" multiple onchange="addGalleryImages(this)">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.2)" stroke-width="1.5"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
          <span style="font-size:10px;color:var(--text-faint);margin-top:4px;">Add</span>
        </div>
      </div>
    </div>

    <!-- Section: Training Modes -->
    <div class="edit-section">
      <div class="section-heading">Training Modes</div>
      <div class="section-sub">Let clients know how you can train them.</div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;" id="mode-row">
        <button type="button" class="toggle-pill" onclick="togglePill(this,'modes','in-person')">In-Person</button>
        <button type="button" class="toggle-pill" onclick="togglePill(this,'modes','online')">Online</button>
        <button type="button" class="toggle-pill" onclick="togglePill(this,'modes','hybrid')">Hybrid</button>
      </div>
    </div>

    <!-- Section: Video Intro -->
    <div class="edit-section">
      <div class="section-heading">Video Intro</div>
      <div class="section-sub">Add a short intro video — YouTube or Instagram Reel link. Clients who watch a video are 3× more likely to book.</div>
      <div class="field">
        <label>Video URL</label>
        <input type="url" id="e-video-intro" placeholder="https://youtube.com/shorts/... or https://instagram.com/reel/...">
        <div class="field-hint">YouTube Shorts or Instagram Reels work best (under 60 seconds)</div>
      </div>
    </div>

    <!-- Section: Social Links -->
    <div class="edit-section">
      <div class="section-heading">Social Links</div>
      <div class="section-sub">Connect your social media to your profile.</div>
      <div class="field">
        <label>Instagram</label>
        <div style="display:flex;align-items:center;background:var(--surface-2);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color 0.2s;" id="ig-wrap">
          <span style="padding:13px 0 13px 15px;font-size:14px;color:var(--text-faint);">@</span>
          <input type="text" id="e-instagram" placeholder="yourhandle" style="border:none;background:transparent;padding:13px 15px 13px 6px;font-size:14px;flex:1;min-width:0;color:var(--text);outline:none;" onfocus="document.getElementById('ig-wrap').style.borderColor='var(--brand)'" onblur="document.getElementById('ig-wrap').style.borderColor='var(--border)'">
        </div>
      </div>
      <div class="field">
        <label>TikTok</label>
        <div style="display:flex;align-items:center;background:var(--surface-2);border:1px solid var(--border);border-radius:12px;overflow:hidden;transition:border-color 0.2s;" id="tt-wrap">
          <span style="padding:13px 0 13px 15px;font-size:14px;color:var(--text-faint);">@</span>
          <input type="text" id="e-tiktok" placeholder="yourhandle" style="border:none;background:transparent;padding:13px 15px 13px 6px;font-size:14px;flex:1;min-width:0;color:var(--text);outline:none;" onfocus="document.getElementById('tt-wrap').style.borderColor='var(--brand)'" onblur="document.getElementById('tt-wrap').style.borderColor='var(--border)'">
        </div>
      </div>
      <div class="field">
        <label>YouTube</label>
        <input type="url" id="e-youtube" placeholder="https://youtube.com/@yourchannel">
      </div>
    </div>

    <!-- Section: REPs Verification -->
    <div class="edit-section">
      <div class="section-heading">REPs UAE Verification</div>
      <div class="section-sub">Your verified badge builds client trust.</div>
      <div id="reps-verified-card" class="hidden" style="background:var(--reps-dim);border:1px solid var(--reps-border);border-radius:12px;padding:14px;display:flex;align-items:center;gap:12px;margin-bottom:14px;">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="#00C853"><path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/></svg>
        <div>
          <div style="font-size:13px;font-weight:700;color:var(--reps);">REPs UAE Verified</div>
          <div id="reps-number-display" style="font-size:11px;color:var(--text-muted);"></div>
        </div>
      </div>
      <div id="reps-unverified-card">
        <div class="field">
          <label>REPs UAE Number</label>
          <input type="text" id="e-reps" placeholder="REP-12345" style="font-family:'Manrope',sans-serif;font-weight:700;font-size:15px;letter-spacing:0.05em;">
          <div class="field-hint">Find your number at repsuae.com/searcht</div>
        </div>
        <button onclick="submitRepsVerification()" style="padding:12px 20px;border-radius:10px;background:var(--reps-dim);border:1px solid var(--reps-border);color:var(--reps);font-size:13px;font-weight:700;cursor:pointer;transition:all 0.2s;">
          Submit for Verification
