---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';

const market = getMarket(Astro.url.hostname);
const brand = market.brandName ?? 'TrainedBy';
const domain = market.domain;
const effectiveDate = 'April 15, 2026';
const contactEmail = `legal@${domain}`;

const t = {
  fr: { title: 'Politique de Cookies', intro: `${brand} utilise des cookies pour faire fonctionner la plateforme et améliorer votre expérience.` },
  it: { title: 'Politica sui Cookie', intro: `${brand} utilizza i cookie per far funzionare la piattaforma e migliorare la tua esperienza.` },
  es: { title: 'Política de Cookies', intro: `${brand} utiliza cookies para hacer funcionar la plataforma y mejorar tu experiencia.` },
}[market.i18nLocale] ?? {
  title: 'Cookie Policy',
  intro: `${brand} uses cookies and local storage to operate the platform and, with your consent, to monitor performance.`,
};
---
<Base title={`${t.title} - ${brand}`} description={t.intro} canonical={`https://${domain}/cookie-policy`}>
  <main style="max-width:760px;margin:0 auto;padding:48px 24px;color:var(--text-1);">
    <h1 style="font-size:28px;font-weight:700;margin-bottom:8px;">{t.title}</h1>
    <p style="color:var(--text-3);font-size:13px;margin-bottom:40px;">Effective date: {effectiveDate}</p>

    <p style="margin-bottom:24px;">{t.intro}</p>

    <h2>What Are Cookies</h2>
    <p>Cookies are small text files stored on your device when you visit a website. They allow the website to remember your preferences and session state across page loads. Some of the storage described below uses browser <code>localStorage</code> rather than cookies — it behaves similarly and is subject to the same consent rules.</p>

    <h2>Storage We Use</h2>
    <table>
      <thead>
        <tr><th>Name</th><th>Type</th><th>Purpose</th><th>Duration</th></tr>
      </thead>
      <tbody>
        <tr>
          <td><code>sb-access-token</code><br/><code>sb-refresh-token</code></td>
          <td>Essential (cookie)</td>
          <td>Maintains your authenticated session as a Trainer. Set by Supabase Auth when you log in. Deleted on logout.</td>
          <td>1 hour (access) / 7 days (refresh)</td>
        </tr>
        <tr>
          <td><code>tb_cookie_consent</code></td>
          <td>Essential (localStorage + cookie)</td>
          <td>Stores your cookie consent preference so the banner does not reappear on subsequent visits.</td>
          <td>1 year</td>
        </tr>
        <tr>
          <td><code>_sentry_session</code><br/><code>_sentry_release</code></td>
          <td>Performance (opt-in)</td>
          <td>Used by Sentry to monitor platform errors and performance. Collects anonymised stack traces and browser metadata. No personal data is included. Set only if you accept performance cookies.</td>
          <td>Session / 1 year</td>
        </tr>
      </tbody>
    </table>

    <h2>Essential Storage</h2>
    <p>Essential cookies and localStorage entries are required for the platform to function correctly. The Supabase session cookies are only set when you log in as a Trainer. The consent preference entry is set the first time you interact with the cookie banner. These cannot be disabled without logging out or clearing your browser data.</p>

    <h2>Performance Cookies</h2>
    <p>We use Sentry for error monitoring and performance tracking. Sentry does not collect personal data and does not share data with advertisers. Performance cookies are only set if you click "Accept all" on the cookie banner. If you choose "Essential only", no performance cookies are set.</p>

    <h2>Managing Your Preferences</h2>
    <p>You can change your cookie preferences at any time by clearing your browser cookies and localStorage for this site. Refusing performance cookies does not affect your ability to use the platform. The cookie banner will reappear the next time you visit after clearing your preferences.</p>

    <h2>Contact</h2>
    <p>For questions about our use of cookies, contact <a href={`mailto:${contactEmail}`}>{contactEmail}</a>.</p>
  </main>
</Base>

<style>
  h2 { font-size: 18px; font-weight: 700; margin: 32px 0 12px; color: var(--text-1); }
  p { font-size: 15px; line-height: 1.7; color: var(--text-2); margin-bottom: 12px; }
  a { color: var(--brand); text-decoration: underline; }
  table { width: 100%; border-collapse: collapse; margin: 16px 0 24px; font-size: 14px; }
  th { text-align: left; padding: 10px 12px; background: var(--surface-2); font-weight: 600; border-bottom: 1px solid var(--border); }
  td { padding: 10px 12px; border-bottom: 1px solid var(--border); color: var(--text-2); vertical-align: top; }
  code { font-family: monospace; background: var(--surface-2); padding: 2px 5px; border-radius: 3px; font-size: 12px; }
</style>
