---
import Base from '../layouts/Base.astro';
import ProfileCompleteness from '../components/ProfileCompleteness.astro';
import { getMarket } from '../lib/market.ts';
import { getLocale, t, getBrand } from '../lib/i18n.ts';
const market = getMarket(Astro.url.hostname);
const locale = getLocale(Astro.request);
const brand = getBrand(locale);
---

<Base
  title={`Dashboard - ${market.brandName}`}
  description={`Your ${market.brandName} trainer dashboard. Manage leads, analytics, and your profile.`}
>
  <style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  /* Aliases to Base.astro global tokens */
  --reps: var(--green, #00C853);
  --reps-dim: var(--green-dim, rgba(0,200,83,0.08));
  --reps-border: var(--green-border, rgba(0,200,83,0.2));
  --surface: var(--bg, #0a0a0a);
  --surface-2: var(--surface, #111);
  --surface-3: var(--surface-3, #1c1c1c);
  --surface-4: var(--surface-4, #222);
  --text-muted: var(--text-2, rgba(255,255,255,0.5));
  --text-faint: var(--text-faint, rgba(255,255,255,0.25));
}
html { scroll-behavior: smooth; }
body {
  background: var(--bg, #0a0a0a); color: var(--text, #f0f0f0);
  font-family: var(--font-body, 'Inter', sans-serif); font-size: 14px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; min-height: 100vh;
}
.dash-wrap {
  max-width: 480px; margin: 0 auto;
  padding: 0 20px max(80px, env(safe-area-inset-bottom));
}

/* Header */
.dash-header {
  display: flex; align-items: center; justify-content: space-between;
  padding-top: max(20px, env(safe-area-inset-top)); padding-bottom: 20px;
  border-bottom: 1px solid var(--border); margin: 0 -20px; padding-left: 20px; padding-right: 20px;
}
.dash-logo {
  display: flex; align-items: center; gap: 8px;
  font-family: 'Manrope', sans-serif; font-weight: 800; font-size: 16px;
  text-decoration: none; color: var(--text);
}
.header-nav { display: flex; gap: 8px; }
.header-nav a {
  padding: 8px 14px; border-radius: 20px;
  font-size: 12px; font-weight: 700; text-decoration: none;
  transition: all 0.2s;
}
.header-nav .nav-edit {
  background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted);
}
.header-nav .nav-edit:hover { border-color: var(--border-hover); color: var(--text); }
.header-nav .nav-view {
  background: var(--brand); color: #fff;
}
.header-nav .nav-view:hover { background: #e05200; }

/* Trainer greeting */
.trainer-greeting {
  padding: 24px 0 20px;
  border-bottom: 1px solid var(--border);
}
.greeting-row { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
.greeting-avatar {
  width: 44px; height: 44px; border-radius: 50%;
  object-fit: cover; background: var(--surface-3);
  border: 2px solid var(--brand);
}
.greeting-name {
  font-family: 'Manrope', sans-serif; font-size: 18px; font-weight: 800;
}
.greeting-sub { font-size: 12px; color: var(--text-muted); }

/* Profile URL copy bar */
.url-bar {
  display: flex; align-items: center; gap: 10px;
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; padding: 12px 14px;
}
.url-bar-text {
  flex: 1; font-size: 13px; font-weight: 600; color: var(--brand);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.url-copy-btn {
  padding: 6px 12px; border-radius: 8px;
  background: var(--brand-dim); border: 1px solid var(--brand-border);
  color: var(--brand); font-size: 11px; font-weight: 700;
  cursor: pointer; flex-shrink: 0;
}

/* Stats grid */
.stats-section { padding: 24px 0; border-bottom: 1px solid var(--border); }
.stats-section-title {
  font-size: 11px; font-weight: 700; color: var(--text-faint);
  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 14px;
}
.stats-grid {
  display: grid; grid-template-columns: 1fr 1fr; gap: 10px;
}
.stat-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 14px; padding: 16px;
}
.stat-card.brand-card {
  background: var(--brand-dim); border-color: var(--brand-border);
}
.stat-card-icon {
  width: 32px; height: 32px; border-radius: 8px;
  background: var(--surface-3); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
  margin-bottom: 10px; color: var(--text-muted);
}
.stat-card.brand-card .stat-card-icon {
  background: var(--brand-dim); border-color: var(--brand-border); color: var(--brand);
}
.stat-card-value {
  font-family: 'Manrope', sans-serif; font-size: 26px; font-weight: 800;
  letter-spacing: -0.5px; margin-bottom: 2px;
}
.stat-card-label { font-size: 11px; color: var(--text-muted); font-weight: 500; }
.stat-card-change {
  font-size: 11px; font-weight: 600; margin-top: 4px;
}
.stat-card-change.up { color: var(--reps); }
.stat-card-change.down { color: #ff5555; }

/* Chart placeholder */
.chart-section { padding: 24px 0; border-bottom: 1px solid var(--border); }
.chart-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}
.chart-title {
  font-size: 11px; font-weight: 700; color: var(--text-faint);
  text-transform: uppercase; letter-spacing: 0.08em;
}
.chart-period-select {
  padding: 6px 10px; border-radius: 8px;
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text-muted); font-size: 11px; font-weight: 600;
  cursor: pointer; outline: none;
}
.chart-area {
  width: 100%; height: 120px; position: relative;
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; overflow: hidden;
}
.chart-bars {
  display: flex; align-items: flex-end; gap: 4px;
  padding: 12px 12px 0; height: 100%;
}
.chart-bar {
  flex: 1; border-radius: 4px 4px 0 0;
  background: var(--brand-dim); border: 1px solid var(--brand-border);
  transition: background 0.2s; cursor: pointer; min-height: 4px;
}
.chart-bar:hover { background: rgba(255,92,0,0.25); }
.chart-bar.today { background: var(--brand); border-color: var(--brand); }
.chart-labels {
  display: flex; gap: 4px; padding: 4px 12px 0;
}
.chart-label {
  flex: 1; text-align: center; font-size: 9px; color: var(--text-faint);
  font-weight: 600;
}

/* Leads section */
.leads-section { padding: 24px 0; border-bottom: 1px solid var(--border); }
.leads-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 14px;
}
.leads-title {
  font-size: 11px; font-weight: 700; color: var(--text-faint);
  text-transform: uppercase; letter-spacing: 0.08em;
}
.leads-count {
  background: var(--brand); color: #fff;
  font-size: 10px; font-weight: 700; padding: 2px 8px;
  border-radius: 10px;
}
.lead-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; background: var(--surface-2);
  border: 1px solid var(--border); border-radius: 12px;
  margin-bottom: 8px;
}
.lead-avatar {
  width: 36px; height: 36px; border-radius: 50%;
  background: var(--surface-3); display: flex; align-items: center;
  justify-content: center; font-family: 'Manrope', sans-serif;
  font-size: 14px; font-weight: 800; color: var(--text-muted);
  flex-shrink: 0;
}
.lead-name { font-size: 13px; font-weight: 700; margin-bottom: 1px; }
.lead-meta { font-size: 11px; color: var(--text-muted); }
.lead-actions { display: flex; gap: 6px; margin-left: auto; }
.lead-wa-btn {
  width: 32px; height: 32px; border-radius: 50%;
  background: rgba(37,211,102,0.08); border: 1px solid rgba(37,211,102,0.15);
  display: flex; align-items: center; justify-content: center;
  cursor: pointer; text-decoration: none; color: #25D366;
  transition: background 0.2s;
}
.lead-wa-btn:hover { background: rgba(37,211,102,0.15); }
.lead-type-tag {
  padding: 3px 8px; border-radius: 6px; font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.04em;
}
.lead-type-tag.assessment {
  background: var(--brand-dim); border: 1px solid var(--brand-border); color: var(--brand);
}
.lead-type-tag.booking {
  background: var(--reps-dim); border: 1px solid var(--reps-border); color: var(--reps);
}
.lead-type-tag.package {
  background: rgba(100,100,255,0.08); border: 1px solid rgba(100,100,255,0.2); color: #8888ff;
}

/* Onboarding checklist */
.checklist-section { padding: 24px 0; border-bottom: 1px solid var(--border); }
.checklist-title {
  font-size: 11px; font-weight: 700; color: var(--text-faint);
  text-transform: uppercase; letter-spacing: 0.08em; margin-bottom: 14px;
}
.checklist-item {
  display: flex; align-items: center; gap: 12px;
  padding: 12px 14px; border-radius: 12px;
  margin-bottom: 6px; transition: background 0.2s;
}
.checklist-item.done { opacity: 0.5; }
.check-circle {
  width: 24px; height: 24px; border-radius: 50%; flex-shrink: 0;
  border: 2px solid var(--border); display: flex; align-items: center; justify-content: center;
}
.check-circle.done {
  background: var(--reps); border-color: var(--reps);
}
.checklist-text { font-size: 13px; font-weight: 600; }
.checklist-sub { font-size: 11px; color: var(--text-muted); }
.checklist-action {
  margin-left: auto; padding: 6px 12px; border-radius: 8px;
  background: var(--brand-dim); border: 1px solid var(--brand-border);
  color: var(--brand); font-size: 11px; font-weight: 700;
  text-decoration: none; cursor: pointer; flex-shrink: 0;
}

/* Upgrade banner - Pro metallic gold treatment */
.upgrade-banner {
  background: linear-gradient(135deg, rgba(197,162,39,0.10) 0%, rgba(197,162,39,0.04) 100%);
  border: 1px solid var(--pro-border, rgba(197,162,39,0.35));
  border-radius: 16px; padding: 20px; margin: 24px 0;
  box-shadow: 0 0 32px var(--pro-dim, rgba(197,162,39,0.08));
  position: relative; overflow: hidden;
}
.upgrade-banner::before {
  content: '';
  position: absolute; top: 0; left: 0; right: 0; height: 1px;
  background: var(--pro-gradient, linear-gradient(90deg,transparent,rgba(245,208,107,0.5),transparent));
}
.upgrade-title {
  font-family: var(--font-display, 'Manrope', sans-serif); font-size: 16px; font-weight: 800;
  margin-bottom: 6px;
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;
}
.upgrade-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.6; }
.upgrade-features {
  display: flex; flex-direction: column; gap: 6px; margin-bottom: 16px;
}
.upgrade-feature {
  display: flex; align-items: center; gap: 8px;
  font-size: 12px; color: var(--text-muted);
}
.upgrade-feature svg { flex-shrink: 0; }
.upgrade-btn {
  width: 100%; padding: 14px; border-radius: 12px;
  background: var(--pro-gradient, linear-gradient(135deg,#c9a227,#f5d06b,#c9a227));
  color: #0a0a0a; border: none;
  font-family: var(--font-display, 'Manrope', sans-serif); font-size: 14px; font-weight: 800;
  cursor: pointer; transition: all 0.2s;
  box-shadow: 0 4px 20px rgba(197,162,39,0.3);
}
.upgrade-btn:hover { box-shadow: 0 6px 28px rgba(197,162,39,0.5); transform: translateY(-1px); }

/* Income stream cards */
.income-section { padding: 24px 0; border-bottom: 1px solid var(--border); }
.income-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
.income-stream-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 14px; padding: 14px;
  position: relative; overflow: hidden;
}
.income-stream-card.active {
  background: linear-gradient(135deg, rgba(255,92,0,0.10) 0%, var(--surface-2) 100%);
  border-color: var(--brand-border);
}
.income-stream-card.locked { opacity: 0.55; }
.income-stream-icon { font-size: 20px; margin-bottom: 8px; }
.income-stream-label { font-size: 10px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 2px; }
.income-stream-value { font-family: 'Manrope', sans-serif; font-size: 18px; font-weight: 800; letter-spacing: -0.5px; }
.income-stream-value.green { color: var(--reps); }
.income-stream-sub { font-size: 10px; color: var(--text-muted); margin-top: 2px; line-height: 1.4; }
.income-stream-lock {
  position: absolute; top: 10px; right: 10px;
  width: 20px; height: 20px; border-radius: 50%;
  background: var(--surface-3); border: 1px solid var(--border);
  display: flex; align-items: center; justify-content: center;
}

/* Referral flywheel */
.referral-section { padding: 24px 0; }
.referral-card {
  background: linear-gradient(135deg, rgba(255,92,0,0.08) 0%, var(--surface-2) 100%);
  border: 1px solid var(--brand-border);
  border-radius: 16px; padding: 18px;
}
.referral-title { font-size: 15px; font-weight: 800; margin-bottom: 4px; font-family: 'Manrope', sans-serif; }
.referral-sub { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.6; }
/* Flywheel progress */
.flywheel-progress { margin-bottom: 16px; }
.flywheel-label { display: flex; justify-content: space-between; font-size: 11px; font-weight: 600; margin-bottom: 6px; }
.flywheel-label span:last-child { color: var(--brand); }
.flywheel-bar { height: 6px; background: var(--surface-3); border-radius: 3px; overflow: hidden; }
.flywheel-fill { height: 100%; background: var(--brand); border-radius: 3px; transition: width 0.6s cubic-bezier(0.4,0,0.2,1); }
.flywheel-steps { display: flex; gap: 6px; margin-top: 10px; }
.flywheel-step {
  flex: 1; height: 4px; border-radius: 2px;
  background: var(--surface-3);
}
.flywheel-step.done { background: var(--brand); }
.flywheel-reward {
  display: flex; align-items: center; gap: 8px;
  background: rgba(0,200,83,0.06); border: 1px solid rgba(0,200,83,0.15);
  border-radius: 10px; padding: 10px 12px; margin-bottom: 14px;
  font-size: 12px; color: var(--reps); font-weight: 600;
}
.referral-url {
  display: flex; align-items: center; gap: 8px;
  background: var(--surface-3); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px 12px;
}
.referral-url-text {
  flex: 1; font-size: 12px; font-weight: 600; color: var(--text-muted);
  overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
}
.referral-share-btns { display: flex; gap: 8px; margin-top: 10px; }
.referral-share-btn {
  flex: 1; padding: 10px; border-radius: 10px; border: 1px solid var(--border);
  background: var(--surface-3); color: var(--text-muted);
  font-size: 11px; font-weight: 700; cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 5px;
  transition: all 0.2s; text-decoration: none;
}
.referral-share-btn:hover { border-color: var(--brand-border); color: var(--brand); }

/* ── AI Assistant Panel ───────────────────────────────────────────────────────────────────────────── */
.ai-panel {
  display: none; flex-direction: column;
  position: fixed; inset: 0; z-index: 50;
  background: #080810; /* Slightly blue-tinted dark for AI context */
  padding-top: max(0px, env(safe-area-inset-top));
  padding-bottom: max(64px, calc(env(safe-area-inset-bottom) + 64px));
}
.ai-panel.open { display: flex; }
.ai-panel-header {
  display: flex; align-items: center; justify-content: space-between;
  padding: 16px 20px; border-bottom: 1px solid rgba(99,102,241,0.2);
  flex-shrink: 0;
  background: rgba(99,102,241,0.04);
}
.ai-panel-title {
  font-family: var(--font-display, 'Manrope', sans-serif); font-size: 16px; font-weight: 800;
  display: flex; align-items: center; gap: 8px;
}
.ai-panel-badge {
  font-size: 10px; font-weight: 700; padding: 3px 8px; border-radius: 20px;
  background: rgba(99,102,241,0.15); color: #818cf8; border: 1px solid rgba(99,102,241,0.3);
}
.ai-panel-close {
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text-muted); border-radius: 8px; padding: 6px 12px;
  font-size: 12px; font-weight: 600; cursor: pointer;
}
.ai-panel-close:hover { color: var(--text); border-color: var(--border-hover); }
.ai-messages {
  flex: 1; overflow-y: auto; padding: 20px;
  display: flex; flex-direction: column; gap: 14px;
  scroll-behavior: smooth;
}
.ai-msg {
  max-width: 88%; padding: 12px 15px; border-radius: 14px;
  font-size: 13px; line-height: 1.6;
  animation: msgIn 0.2s ease;
}
@keyframes msgIn { from { opacity: 0; transform: translateY(6px); } to { opacity: 1; transform: none; } }
.ai-msg.user {
  background: #6366f1; color: #fff;
  border-bottom-right-radius: 4px; align-self: flex-end;
}
.ai-msg.bot {
  background: rgba(99,102,241,0.08); color: var(--text);
  border: 1px solid rgba(99,102,241,0.2); border-bottom-left-radius: 4px; align-self: flex-start;
  white-space: pre-wrap;
}
.ai-msg.typing {
  background: rgba(99,102,241,0.06); border: 1px solid rgba(99,102,241,0.15);
  align-self: flex-start; color: var(--text-muted); font-style: italic;
}
.ai-quick-prompts {
  padding: 0 20px 12px; display: flex; gap: 8px; flex-wrap: wrap; flex-shrink: 0;
}
.ai-chip {
  padding: 7px 13px; border-radius: 20px; font-size: 12px; font-weight: 600;
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text-muted); cursor: pointer; transition: all 0.15s;
  white-space: nowrap;
}
.ai-chip:hover { border-color: rgba(99,102,241,0.4); color: #818cf8; background: rgba(99,102,241,0.1); }
.ai-input-row {
  padding: 12px 20px; border-top: 1px solid rgba(99,102,241,0.15);
  display: flex; gap: 10px; align-items: flex-end; flex-shrink: 0;
  background: #080810;
}
.ai-input {
  flex: 1; background: var(--surface-3); border: 1px solid var(--border);
  border-radius: 12px; padding: 11px 14px; color: var(--text);
  font-size: 13px; font-family: inherit; outline: none; resize: none;
  max-height: 100px; line-height: 1.5;
  transition: border-color 0.2s;
}
.ai-input:focus { border-color: rgba(99,102,241,0.5); box-shadow: 0 0 0 3px rgba(99,102,241,0.08); }
.ai-input::placeholder { color: var(--text-faint); }
.ai-send {
  width: 42px; height: 42px; border-radius: 12px; border: none;
  background: #6366f1; color: #fff; cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  flex-shrink: 0; transition: all 0.2s;
  box-shadow: 0 2px 12px rgba(99,102,241,0.4);
}
.ai-send:hover { background: #4f46e5; box-shadow: 0 4px 20px rgba(99,102,241,0.5); }
.ai-send:disabled { opacity: 0.4; cursor: not-allowed; }
.ai-welcome {
  text-align: center; padding: 32px 20px 16px;
}
.ai-welcome-icon {
  width: 56px; height: 56px; border-radius: 16px;
  background: rgba(99,102,241,0.15);
  border: 1px solid rgba(99,102,241,0.35);
  display: flex; align-items: center;
  justify-content: center; margin: 0 auto 16px;
  animation: ai-breathe 3s ease-in-out infinite;
}
.ai-welcome-title {
  font-family: var(--font-display, 'Manrope', sans-serif); font-size: 18px; font-weight: 800; margin-bottom: 6px;
}
.ai-welcome-sub { font-size: 13px; color: var(--text-muted); line-height: 1.5; }
/* AI channel settings */
.ai-channel-btn {
  display: flex; align-items: center; gap: 6px;
  padding: 8px 14px; border-radius: 20px; font-size: 12px; font-weight: 600;
  background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted);
  cursor: pointer; transition: all 0.2s;
}
.ai-channel-btn:hover { border-color: var(--border-hover); color: var(--text); }
.ai-channel-btn.active { background: var(--brand-dim); border-color: var(--brand-border); color: var(--brand); }
.ai-channel-info { padding: 4px 0; }
.btn-primary {
  display: block; width: 100%; padding: 14px; border-radius: 12px;
  background: var(--brand); color: #fff; font-size: 14px; font-weight: 700;
  border: none; cursor: pointer; transition: background 0.2s; text-align: center;
}
.btn-primary:hover { background: #e05200; }

/* Empty state */
.empty-state {
  text-align: center; padding: 32px 0;
}
.empty-state-icon { margin-bottom: 12px; }
.empty-state-text { font-size: 13px; color: var(--text-muted); }

/* Bottom nav */
.bottom-nav {
  position: fixed; bottom: 0; left: 0; right: 0;
  background: rgba(10,10,10,0.95); backdrop-filter: blur(12px);
  border-top: 1px solid var(--border);
  display: flex; padding: 12px 0 max(12px, env(safe-area-inset-bottom));
  z-index: 20;
}
.bottom-nav-item {
  flex: 1; display: flex; flex-direction: column; align-items: center;
  gap: 3px; cursor: pointer; text-decoration: none;
  color: var(--text-faint); transition: color 0.2s;
}
.bottom-nav-item.active { color: var(--brand); }
.bottom-nav-item span { font-size: 10px; font-weight: 600; }

/* Spinner */
.spinner {
  display: inline-block; width: 14px; height: 14px;
  border: 2px solid rgba(255,255,255,0.2); border-top-color: #fff;
  border-radius: 50%; animation: spin 0.7s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }

/* Toast */
.toast {
  position: fixed; bottom: max(80px, calc(env(safe-area-inset-bottom) + 70px));
  left: 50%; transform: translateX(-50%) translateY(80px);
  background: var(--surface-3); border: 1px solid var(--border);
  color: var(--text); padding: 12px 20px; border-radius: 24px;
  font-size: 13px; font-weight: 600; z-index: 100;
  transition: transform 0.3s cubic-bezier(0.32,0.72,0,1);
  white-space: nowrap; box-shadow: 0 8px 32px rgba(0,0,0,0.5);
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.success { background: var(--reps-dim); border-color: var(--reps-border); color: var(--reps); }

.hidden { display: none !important; }

@keyframes pulse{0%,80%,100%{transform:scale(0.6);opacity:0.3}40%{transform:scale(1);opacity:1}}
@keyframes ai-breathe {
  0%, 100% { box-shadow: 0 0 0 0 rgba(99,102,241,0), 0 0 12px rgba(99,102,241,0.2); }
  50% { box-shadow: 0 0 0 8px rgba(99,102,241,0.08), 0 0 28px rgba(99,102,241,0.4); }
}
  </style>

<div class="dash-wrap">

  <!-- Header -->
  <div class="dash-header">
    <a href="/" class="dash-logo">
      <svg width="26" height="26" viewBox="0 0 32 32"><rect width="32" height="32" rx="8" fill="#FF5C00"/><text x="16" y="23" font-family="Manrope,Arial,sans-serif" font-size="14" font-weight="800" text-anchor="middle" fill="white">TB</text></svg>
      Dashboard
    </a>
    <div class="header-nav">
      <a href="/edit" class="nav-edit">Edit</a>
      <a id="view-link" href="#" class="nav-view">View Profile</a>
    </div>
  </div>

  <!-- Loading -->
  <div id="dash-loading" style="text-align:center;padding:60px 0;">
    <div style="display:flex;align-items:center;justify-content:center;gap:8px;">
      <div style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out infinite;"></div>
      <div style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out infinite;animation-delay:0.2s;"></div>
      <div style="width:8px;height:8px;border-radius:50%;background:var(--brand);animation:pulse 1.2s ease-in-out infinite;animation-delay:0.4s;"></div>
    </div>
    <style>@keyframes pulse{0%,80%,100%{transform:scale(0.6);opacity:0.3}40%{transform:scale(1);opacity:1}}</style>
  </div>

  <!-- Auth gate -->
  <div id="dash-auth" class="hidden" style="text-align:center;padding:60px 0;">
    <h2 style="font-family:'Manrope',sans-serif;font-size:20px;font-weight:800;margin-bottom:8px;">Sign in to view your dashboard</h2>
    <p style="font-size:14px;color:var(--text-muted);margin-bottom:24px;">Access your leads, analytics, and profile settings.</p>
    <a href="/edit" style="display:inline-block;padding:14px 28px;border-radius:12px;background:var(--brand);color:#fff;text-decoration:none;font-family:'Manrope',sans-serif;font-size:14px;font-weight:700;">Sign In →</a>
  </div>

  <!-- Dashboard content -->
  <div id="dash-content" class="hidden">

    <!-- Greeting -->
    <div class="trainer-greeting">
      <div class="greeting-row">
        <img id="dash-avatar" class="greeting-avatar" src="" alt="Avatar">
        <div>
          <div class="greeting-name" id="dash-name">Loading...</div>
          <div class="greeting-sub" id="dash-sub">{market.brandName}</div>
        </div>
      </div>
      <div class="url-bar">
        <span class="url-bar-text" id="dash-url">...</span>
        <button class="url-copy-btn" onclick="copyUrl()">Copy Link</button>
      </div>
    </div>

    <!-- Profile Completeness Widget -->
    <ProfileCompleteness />

    <!-- Stats -->
    <div class="stats-section">
      <div class="stats-section-title">This Week</div>
      <div class="stats-grid">
        <div class="stat-card brand-card">
          <div class="stat-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="stat-card-value" id="stat-leads"> - </div>
          <div class="stat-card-label">{t(locale, 'dash.stats_leads')}</div>
          <div class="stat-card-change up" id="stat-leads-change"></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/></svg>
          </div>
          <div class="stat-card-value" id="stat-views"> - </div>
          <div class="stat-card-label">{t(locale, 'dash.stats_views')}</div>
          <div class="stat-card-change up" id="stat-views-change"></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 9.81a19.79 19.79 0 01-3.07-8.67A2 2 0 012 .84h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 8.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div class="stat-card-value" id="stat-wa-taps"> - </div>
          <div class="stat-card-label">{t(locale, 'dash.stats_wa')}</div>
          <div class="stat-card-change up" id="stat-wa-change"></div>
        </div>
        <div class="stat-card">
          <div class="stat-card-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          </div>
          <div class="stat-card-value" id="stat-assess"> - </div>
          <div class="stat-card-label">Assessments</div>
          <div class="stat-card-change up" id="stat-assess-change"></div>
        </div>
      </div>
    </div>

    <!-- WHOOP-style Actionable Insight Banner -->
    <div id="insight-banner" style="display:none;margin:16px 0;background:linear-gradient(135deg,rgba(255,92,0,0.10),rgba(255,92,0,0.04));border:1px solid rgba(255,92,0,0.25);border-radius:14px;padding:14px 16px;">
      <div style="display:flex;align-items:flex-start;gap:10px;">
        <div style="width:32px;height:32px;border-radius:8px;background:rgba(255,92,0,0.15);border:1px solid rgba(255,92,0,0.25);display:flex;align-items:center;justify-content:center;flex-shrink:0;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF5C00" stroke-width="2.5"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        </div>
        <div>
          <div style="font-size:11px;font-weight:700;color:rgba(255,92,0,0.9);letter-spacing:0.05em;text-transform:uppercase;margin-bottom:3px;">Insight</div>
          <div id="insight-text" style="font-size:13px;color:rgba(255,255,255,0.85);line-height:1.5;"></div>
          <div id="insight-action" style="margin-top:8px;"></div>
        </div>
      </div>
    </div>

    <!-- Views chart -->
    <div class="chart-section">
      <div class="chart-header">
        <span class="chart-title">{t(locale, 'dash.stats_views')}</span>
        <select class="chart-period-select" onchange="loadChart(this.value)">
          <option value="7">Last 7 days</option>
          <option value="14">Last 14 days</option>
          <option value="30">Last 30 days</option>
        </select>
      </div>
      <div class="chart-area">
        <div class="chart-bars" id="chart-bars"></div>
      </div>
      <div class="chart-labels" id="chart-labels"></div>
    </div>

    <!-- Leads -->
    <div class="leads-section">
      <div class="leads-header">
        <span class="leads-title">{t(locale, 'dash.stats_leads')}</span>
        <span class="leads-count" id="leads-total-badge">0</span>
      </div>
      <div id="leads-list">
        <div class="empty-state">
          <div class="empty-state-icon">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
          </div>
          <div class="empty-state-text">No leads yet - share your profile link to get started.</div>
        </div>
      </div>
    </div>

    <!-- Onboarding Checklist -->
    <div class="checklist-section" id="checklist-section">
      <div class="checklist-title">Getting Started</div>
      <div id="checklist-list"></div>
    </div>

    <!-- Income Streams (launch version: sessions only) -->
    <div class="income-section" id="income-section">
      <div class="stats-section-title" style="margin-bottom:14px">Your Income</div>
      <div class="income-grid" id="income-grid">
        <div class="income-stream-card active">
          <div class="income-stream-icon">🏋️</div>
          <div class="income-stream-label">Sessions</div>
          <div class="income-stream-value" id="is-sessions">Active</div>
          <div class="income-stream-sub">Your core training income</div>
        </div>
      </div>
    </div>



    <!-- Generate Training Plan - Pro Feature Card -->
    <div class="checklist-section" id="generate-plan-section" style="display:none">
      <div class="checklist-title" style="display:flex;align-items:center;gap:8px;">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#FF5C00" stroke-width="2"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/><polyline points="10 9 9 9 8 9"/></svg>
        Generate a Training Plan
      </div>
      <div style="font-size:13px;color:var(--text-muted);margin-bottom:16px;line-height:1.6;">
        Build a personalised training plan for a client in 30 seconds. Send it as a PDF or share the link directly.
      </div>
      <div style="display:flex;flex-direction:column;gap:10px;">
        <div class="field" style="margin-bottom:0">
          <label style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Client goal</label>
          <input type="text" id="plan-goal" placeholder="e.g. Lose 8kg in 12 weeks" style="background:var(--surface-3);border:1px solid var(--border);border-radius:10px;padding:10px 14px;color:var(--text);font-size:14px;width:100%;outline:none;font-family:'Inter',sans-serif;">
        </div>
        <div class="field" style="margin-bottom:0">
          <label style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Sessions per week</label>
          <div style="display:flex;gap:8px;">
            <button class="toggle-pill active" id="plan-freq-2" onclick="setPlanFreq(2)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--brand);color:var(--text);font-size:13px;font-weight:700;cursor:pointer;">2×</button>
            <button class="toggle-pill" id="plan-freq-3" onclick="setPlanFreq(3)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">3×</button>
            <button class="toggle-pill" id="plan-freq-4" onclick="setPlanFreq(4)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">4×</button>
            <button class="toggle-pill" id="plan-freq-5" onclick="setPlanFreq(5)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">5×</button>
          </div>
        </div>
        <div class="field" style="margin-bottom:0">
          <label style="font-size:11px;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;letter-spacing:0.05em;">Duration</label>
          <div style="display:flex;gap:8px;">
            <button class="toggle-pill active" id="plan-dur-4" onclick="setPlanDur(4)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--brand);color:var(--text);font-size:13px;font-weight:700;cursor:pointer;">4 wk</button>
            <button class="toggle-pill" id="plan-dur-8" onclick="setPlanDur(8)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">8 wk</button>
            <button class="toggle-pill" id="plan-dur-12" onclick="setPlanDur(12)" style="flex:1;padding:8px;border-radius:8px;background:var(--surface-3);border:1px solid var(--border);color:var(--text-muted);font-size:13px;font-weight:700;cursor:pointer;">12 wk</button>
          </div>
        </div>
        <button id="generate-plan-btn" onclick="generatePlan()" style="background:var(--brand);color:#fff;border:none;border-radius:12px;padding:12px 20px;font-size:14px;font-weight:700;cursor:pointer;font-family:'Inter',sans-serif;display:flex;align-items:center;justify-content:center;gap:8px;">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polygon points="5 3 19 12 5 21 5 3"/></svg>
          Generate Plan
        </button>
        <div id="plan-result" style="display:none;background:var(--surface-3);border:1px solid var(--border);border-radius:12px;padding:14px;font-size:13px;color:var(--text-muted);line-height:1.6;"></div>
      </div>
    </div>

    <!-- AI Assistant Channel Settings (Pro only) -->
    <div class="checklist-section" id="ai-settings-section" style="display:none">
      <div class="checklist-title">{t(locale, 'dash.channel_title')}</div>
      <div style="font-size:13px;color:var(--text-muted);margin-bottom:16px;">{t(locale, 'dash.channel_sub')}</div>

      <!-- Channel selector -->
      <div style="display:flex;gap:10px;margin-bottom:20px;" id="ai-channel-selector">
        <button class="ai-channel-btn active" data-channel="dashboard" onclick="selectChannel('dashboard')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
          {t(locale, 'dash.channel_dashboard')}
        </button>
        <button class="ai-channel-btn" data-channel="whatsapp" onclick="selectChannel('whatsapp')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 11.5a8.38 8.38 0 01-.9 3.8 8.5 8.5 0 01-7.6 4.7 8.38 8.38 0 01-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 01-.9-3.8 8.5 8.5 0 014.7-7.6 8.38 8.38 0 013.8-.9h.5a8.48 8.48 0 018 8v.5z"/></svg>
          {t(locale, 'dash.channel_whatsapp')}
        </button>
        <button class="ai-channel-btn" data-channel="telegram" onclick="selectChannel('telegram')">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
          {t(locale, 'dash.channel_telegram')}
        </button>
      </div>

      <!-- Dashboard info -->
      <div id="ai-channel-dashboard" class="ai-channel-info">
        <p style="font-size:13px;color:var(--text-muted);">Your AI assistant is available in the AI Coach tab below. Tap it to start a conversation.</p>
      </div>

      <!-- WhatsApp setup -->
      <div id="ai-channel-whatsapp" class="ai-channel-info" style="display:none">
        <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">Your AI assistant will reply to messages sent to the platform WhatsApp number from your registered WhatsApp number.</p>
        <div style="background:rgba(255,255,255,0.05);border-radius:10px;padding:12px;font-size:13px;">
          <div style="color:rgba(255,255,255,0.5);margin-bottom:4px;">Your registered number</div>
          <div id="wa-registered-number" style="color:rgba(255,255,255,0.9);font-weight:600;">Loading...</div>
        </div>
        <p style="font-size:12px;color:rgba(255,255,255,0.35);margin-top:10px;">To change your number, update it in Edit Profile.</p>
      </div>

      <!-- Telegram setup -->
      <div id="ai-channel-telegram" class="ai-channel-info" style="display:none">
        <p style="font-size:13px;color:var(--text-muted);margin-bottom:12px;">Link your Telegram account to talk to your AI assistant there.</p>
        <div id="tg-linked-state" style="display:none;background:rgba(255,255,255,0.05);border-radius:10px;padding:12px;font-size:13px;">
          <div style="color:rgba(255,255,255,0.5);margin-bottom:4px;">Linked account</div>
          <div id="tg-username" style="color:rgba(255,255,255,0.9);font-weight:600;"></div>
          <button onclick="unlinkTelegram()" style="margin-top:10px;font-size:12px;color:rgba(255,92,0,0.8);background:none;border:none;cursor:pointer;padding:0;">Unlink</button>
        </div>
        <div id="tg-unlinked-state">
          <button class="btn-primary" onclick="generateTelegramLink()" style="width:100%;margin-top:0;">
            Generate Telegram Link
          </button>
          <div id="tg-link-display" style="display:none;margin-top:12px;background:rgba(255,255,255,0.05);border-radius:10px;padding:12px;">
            <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:6px;">Open this link on your phone:</div>
            <a id="tg-link-url" href="#" target="_blank" style="font-size:13px;color:#FF5C00;word-break:break-all;"></a>
            <div style="font-size:11px;color:rgba(255,255,255,0.35);margin-top:8px;">Link expires in 10 minutes. Tap it to open Telegram and complete the connection.</div>
          </div>
        </div>
      </div>
    </div>

  </div><!-- /dash-content -->

</div><!-- /dash-wrap -->

<!-- AI Assistant Panel -->
<div class="ai-panel" id="ai-panel">
  <div class="ai-panel-header">
    <div class="ai-panel-title">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#FF5C00" stroke-width="2"><path d="M12 2a10 10 0 110 20A10 10 0 0112 2z"/><path d="M12 6v6l4 2"/></svg>
      {t(locale, 'dash.ai_title')}
      <span class="ai-panel-badge">Beta</span>
    </div>
    <button class="ai-panel-close" onclick="closeAI()">Done</button>
  </div>
  <div class="ai-messages" id="ai-messages">
    <div class="ai-welcome" id="ai-welcome">
      <div class="ai-welcome-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#FF5C00" stroke-width="1.8"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg>
      </div>
      <div class="ai-welcome-title">Hey, I'm your AI coach</div>
      <div class="ai-welcome-sub">I know your profile, your market, and your goals. Ask me anything - from writing your bio to building a 12-week programme.</div>
    </div>
  </div>
  <div class="ai-quick-prompts" id="ai-chips">
    <button class="ai-chip" onclick="sendChip(this)">Write my bio</button>
    <button class="ai-chip" onclick="sendChip(this)">Build a 12-week plan</button>
    <button class="ai-chip" onclick="sendChip(this)">How to get more leads</button>
    <button class="ai-chip" onclick="sendChip(this)">Price my packages</button>
    <button class="ai-chip" onclick="sendChip(this)">Write a client email</button>
    <button class="ai-chip" onclick="sendChip(this)">Nutrition advice</button>
  </div>
  <div class="ai-input-row">
    <textarea class="ai-input" id="ai-input" placeholder="{t(locale, 'dash.ai_placeholder')}" rows="1"></textarea>
    <button class="ai-send" id="ai-send" onclick="sendAI()">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
    </button>
  </div>
</div>

<!-- Bottom Nav -->
<nav class="bottom-nav">
  <a href="/dashboard" class="bottom-nav-item active">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>
    <span>{t(locale, 'dash.channel_dashboard')}</span>
  </a>
  <a href="/edit" class="bottom-nav-item">
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M11 4H4a2 2 0 00-2 2v14a2 2 0 002 2h14a2 2 0 002-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 013 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
    <span>{t(locale, 'nav_edit')}</span>
  </a>
  <button class="bottom-nav-item" onclick="openAI()" style="background:none;border:none;cursor:pointer;">
