---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';
import { SUPABASE_ANON_KEY } from '../lib/config.ts';
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName;
---
<Base
  title={`Admin CRM - ${brandName}`}
  description="Internal trainer CRM dashboard."
>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html[data-market] {
  --brand-dim: rgba(255,92,0,0.10); --brand-border: rgba(255,92,0,0.25);
  --reps: #00C853; --reps-dim: rgba(0,200,83,0.08); --reps-border: rgba(0,200,83,0.2);
  --surface-2: #111; --surface-3: #1c1c1c; --surface-4: #242424;
  --border: rgba(255,255,255,0.08); --border-hover: rgba(255,255,255,0.14);
  --text: #fff; --text-muted: rgba(255,255,255,0.5); --text-faint: rgba(255,255,255,0.25);
  --danger: #ff4444; --warning: #ffaa00; --success: #00C853; --accent: #8888ff;
  --danger-dim-sm: rgba(255,68,68,0.08); --danger-dim-md: rgba(255,68,68,0.1);
  --danger-dim-lg: rgba(255,68,68,0.15); --danger-dim-xl: rgba(255,68,68,0.18);
  --danger-border-sm: rgba(255,68,68,0.2); --danger-border-md: rgba(255,68,68,0.25);
  --warning-dim-sm: rgba(255,170,0,0.08); --warning-dim-md: rgba(255,170,0,0.1);
  --warning-border: rgba(255,170,0,0.2); --warning-border-sm: rgba(255,170,0,0.25);
  --green-dim-lg: rgba(0,200,83,0.12); --green-dim-xl: rgba(0,200,83,0.2);
  --accent-dim-sm: rgba(100,100,255,0.08); --accent-dim-md: rgba(100,100,255,0.15);
  --accent-border: rgba(100,100,255,0.2);
  --danger-border-lg: rgba(255,68,68,0.3);
  --overlay-dark-lg: rgba(0,0,0,0.7); --bg-tint-xs: rgba(255,255,255,0.02);
}
.btn-success { background: var(--green-dim-lg); border: 1px solid var(--reps-border); color: var(--reps); }
.btn-success:hover { background: var(--green-dim-xl); }
.btn-danger { background: var(--danger-dim-md); border: 1px solid var(--danger-border-md); color: var(--danger); }
.btn-danger:hover { background: var(--danger-dim-xl); }
html { scroll-behavior: smooth; }
body {
  background: var(--surface); color: var(--text);
  font-family: 'DM Sans', sans-serif; font-size: 14px; line-height: 1.6;
  -webkit-font-smoothing: antialiased; min-height: 100vh;
}
.admin-wrap { max-width: 1200px; margin: 0 auto; padding: 24px 20px 80px; }

/* Header */
.admin-header {
  display: flex; align-items: center; justify-content: space-between;
  margin-bottom: 32px; padding-bottom: 20px; border-bottom: 1px solid var(--border);
}
.admin-title {
  font-family: 'DM Sans', sans-serif; font-size: 22px; font-weight: 800;
}
.admin-title span { color: var(--brand); }
.admin-subtitle { font-size: 12px; color: var(--text-muted); margin-top: 2px; }
.admin-actions { display: flex; gap: 10px; }
.btn {
  padding: 9px 16px; border-radius: 10px; font-size: 12px; font-weight: 700;
  cursor: pointer; border: none; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 6px;
}
.btn-primary { background: var(--brand); color: var(--text-on-brand); }
.btn-primary:hover { background: var(--brand-hover); }
.btn-ghost { background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted); }
.btn-ghost:hover { border-color: var(--border-hover); color: var(--text); }

/* KPI row */
.kpi-row { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 12px; margin-bottom: 28px; }
.kpi-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 14px; padding: 16px;
}
.kpi-card.brand { background: var(--brand-dim); border-color: var(--brand-border); }
.kpi-card.green { background: var(--reps-dim); border-color: var(--reps-border); }
.kpi-value {
  font-family: 'DM Sans', sans-serif; font-size: 28px; font-weight: 800;
  letter-spacing: -0.5px;
}
.kpi-card.brand .kpi-value { color: var(--brand); }
.kpi-card.green .kpi-value { color: var(--reps); }
.kpi-label { font-size: 11px; color: var(--text-muted); font-weight: 500; margin-top: 2px; }

/* Filters */
.filters {
  display: flex; gap: 10px; margin-bottom: 16px; flex-wrap: wrap; align-items: center;
}
.filter-input {
  flex: 1; min-width: 200px; background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 10px; padding: 9px 14px; color: var(--text); font-size: 13px; outline: none;
}
.filter-input:focus { border-color: var(--brand-border); }
.filter-input::placeholder { color: var(--text-faint); }
.filter-select {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 10px; padding: 9px 14px; color: var(--text-muted); font-size: 12px;
  outline: none; cursor: pointer;
}
.filter-select:focus { border-color: var(--brand-border); }

/* Table */
.table-wrap {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 16px; overflow: hidden;
}
.table-scroll { overflow-x: auto; }
table { width: 100%; border-collapse: collapse; min-width: 900px; }
thead { background: var(--surface-3); }
th {
  padding: 12px 16px; text-align: left;
  font-size: 10px; font-weight: 700; color: var(--text-faint);
  text-transform: uppercase; letter-spacing: 0.08em;
  border-bottom: 1px solid var(--border); white-space: nowrap;
}
th.sortable { cursor: pointer; user-select: none; }
th.sortable:hover { color: var(--text-muted); }
td {
  padding: 14px 16px; border-bottom: 1px solid var(--border);
  font-size: 13px; vertical-align: middle;
}
tr:last-child td { border-bottom: none; }
tr:hover td { background: var(--bg-tint-xs); }

/* Trainer cell */
.trainer-cell { display: flex; align-items: center; gap: 10px; }
.trainer-avatar {
  width: 36px; height: 36px; border-radius: 50%; flex-shrink: 0;
  background: var(--surface-3); border: 2px solid var(--border);
  object-fit: cover; display: flex; align-items: center; justify-content: center;
  font-family: 'DM Sans', sans-serif; font-weight: 800; font-size: 13px; color: var(--text-muted);
}
.trainer-name { font-weight: 700; font-size: 13px; }
.trainer-email { font-size: 11px; color: var(--text-muted); }

/* Badges */
.badge {
  display: inline-flex; align-items: center; gap: 4px;
  padding: 3px 8px; border-radius: 6px; font-size: 10px; font-weight: 700;
  text-transform: uppercase; letter-spacing: 0.04em; white-space: nowrap;
}
.badge-pro { background: var(--brand-dim); border: 1px solid var(--brand-border); color: var(--brand); }
.badge-free { background: var(--surface-3); border: 1px solid var(--border); color: var(--text-faint); }
.badge-reps { background: var(--reps-dim); border: 1px solid var(--reps-border); color: var(--reps); }
.badge-pending { background: var(--warning-dim-md); border: 1px solid var(--warning-border-sm); color: var(--warning); }
.badge-test { background: var(--danger-dim-md); border: 1px solid var(--danger-border-sm); color: var(--danger); }
.badge-lapsed { background: var(--danger-dim-sm); border: 1px solid var(--danger-border-sm); color: var(--danger); }
.badge-high { background: var(--reps-dim); border: 1px solid var(--reps-border); color: var(--reps); }
.badge-medium { background: var(--warning-dim-md); border: 1px solid var(--warning-border-sm); color: var(--warning); }
.badge-low { background: var(--danger-dim-sm); border: 1px solid var(--danger-border-sm); color: var(--danger); }

/* Tabs */
.tabs {
  display: flex; gap: 4px; margin-bottom: 24px;
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 12px; padding: 4px; width: fit-content;
}
.tab {
  padding: 8px 18px; border-radius: 9px; font-size: 12px; font-weight: 700;
  cursor: pointer; border: none; background: transparent; color: var(--text-muted);
  transition: all 0.2s; display: flex; align-items: center; gap: 6px;
}
.tab:hover { color: var(--text); }
.tab.active { background: var(--surface-3); color: var(--text); border: 1px solid var(--border); }
.tab-badge {
  background: var(--warning); color: var(--bg); border-radius: 10px;
  padding: 1px 6px; font-size: 10px; font-weight: 800;
}

/* Cert review cards */
.cert-card {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 16px; padding: 20px; margin-bottom: 12px;
  display: grid; grid-template-columns: 80px 1fr auto; gap: 16px; align-items: start;
}
.cert-card:hover { border-color: var(--border-hover); }
.cert-card-img { width: 80px; height: 60px; border-radius: 8px; object-fit: cover; border: 1px solid var(--border); cursor: pointer; }
.cert-card-no-img { width: 80px; height: 60px; border-radius: 8px; background: var(--surface-3); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 24px; }
.cert-card-body { min-width: 0; }
.cert-card-name { font-weight: 700; font-size: 14px; margin-bottom: 2px; }
.cert-card-meta { font-size: 12px; color: var(--text-muted); margin-bottom: 8px; }
.cert-card-extracted { background: var(--surface-3); border-radius: 8px; padding: 10px 12px; font-size: 12px; line-height: 1.7; }
.cert-card-extracted strong { color: var(--text-faint); font-size: 10px; text-transform: uppercase; letter-spacing: 0.06em; }
.cert-card-actions { display: flex; flex-direction: column; gap: 8px; min-width: 100px; }

/* Admin secret prompt */
.secret-prompt {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 16px; padding: 24px; max-width: 400px; margin: 40px auto;
  text-align: center;
}
.secret-prompt h3 { font-family: 'DM Sans', sans-serif; font-size: 16px; font-weight: 800; margin-bottom: 8px; }
.secret-prompt p { font-size: 12px; color: var(--text-muted); margin-bottom: 16px; }
.secret-input {
  width: 100%; background: var(--surface-3); border: 1px solid var(--border);
  border-radius: 10px; padding: 10px 14px; color: var(--text); font-size: 13px;
  outline: none; margin-bottom: 12px;
}
.secret-input:focus { border-color: var(--brand-border); }
.kpi-card.warn { background: var(--warning-dim-sm); border-color: var(--warning-border); }
.kpi-card.warn .kpi-value { color: var(--warning); }

/* Profile completion bar */
.completion-wrap { display: flex; align-items: center; gap: 8px; min-width: 120px; }
.completion-bar {
  flex: 1; height: 4px; background: var(--surface-3);
  border-radius: 2px; overflow: hidden;
}
.completion-fill { height: 100%; border-radius: 2px; transition: width 0.3s; }
.completion-pct { font-size: 11px; font-weight: 700; color: var(--text-muted); min-width: 28px; }

/* Action buttons */
.row-actions { display: flex; gap: 6px; }
.action-btn {
  padding: 5px 10px; border-radius: 7px; font-size: 11px; font-weight: 700;
  cursor: pointer; border: none; transition: all 0.2s; text-decoration: none;
  display: inline-flex; align-items: center; gap: 4px;
}
.action-btn.view { background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted); }
.action-btn.view:hover { color: var(--text); border-color: var(--border-hover); }
.action-btn.email { background: var(--accent-dim-sm); border: 1px solid var(--accent-border); color: var(--accent); }
.action-btn.email:hover { background: var(--accent-dim-md); }
.action-btn.delete { background: var(--danger-dim-sm); border: 1px solid var(--danger-border-sm); color: var(--danger); }
.action-btn.delete:hover { background: var(--danger-dim-lg); }

/* Empty state */
.empty-state {
  text-align: center; padding: 60px 20px; color: var(--text-muted);
}
.empty-state h3 { font-size: 16px; font-weight: 700; margin-bottom: 6px; color: var(--text); }

/* Loading */
.loading { text-align: center; padding: 40px; color: var(--text-muted); font-size: 13px; }

/* Toast */
.toast {
  position: fixed; bottom: 24px; left: 50%; transform: translateX(-50%) translateY(100px);
  background: var(--surface-3); border: 1px solid var(--border);
  padding: 12px 20px; border-radius: 12px; font-size: 13px; font-weight: 600;
  transition: transform 0.3s; z-index: 9999; white-space: nowrap;
}
.toast.show { transform: translateX(-50%) translateY(0); }
.toast.success { border-color: var(--reps-border); color: var(--reps); }
.toast.error { border-color: var(--danger-border-lg); color: var(--danger); }

/* Modal */
.modal-overlay {
  position: fixed; inset: 0; background: var(--overlay-dark-lg);
  display: none; align-items: center; justify-content: center;
  z-index: 9000; padding: 20px;
}
.modal-overlay.open { display: flex; }
.modal {
  background: var(--surface-2); border: 1px solid var(--border);
  border-radius: 20px; padding: 28px; max-width: 480px; width: 100%;
  max-height: 80vh; overflow-y: auto;
}
.modal-title { font-family: 'DM Sans', sans-serif; font-size: 18px; font-weight: 800; margin-bottom: 20px; }
.modal-field { margin-bottom: 16px; }
.modal-label { font-size: 11px; font-weight: 700; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.06em; margin-bottom: 6px; }
.modal-value { font-size: 13px; color: var(--text); }
.modal-value.muted { color: var(--text-muted); }
.modal-actions { display: flex; gap: 10px; margin-top: 24px; }
.modal-close { position: absolute; top: 16px; right: 16px; }
</style>

<div class="admin-wrap">
  <div class="admin-header">
    <div>
      <div class="admin-title">Trainer <span>CRM</span></div>
      <div class="admin-subtitle" id="last-updated">Loading...</div>
    </div>
    <div class="admin-actions">
      <button class="btn btn-ghost" onclick="exportCSV()">↓ Export CSV</button>
      <button class="btn btn-primary" onclick="sendWelcomeAll()">✉ Send Welcome Emails</button>
    </div>
  </div>

  <!-- Tabs -->
  <div class="tabs">
    <button class="tab active" id="tab-trainers" onclick="switchTab('trainers')">All Trainers</button>
    <button class="tab" id="tab-queue" onclick="switchTab('queue')">
      Verification Queue
      <span class="tab-badge" id="queue-badge" style="display:none">0</span>
    </button>
  </div>

  <!-- All Trainers panel -->
  <div id="panel-trainers">
  <div class="kpi-row" id="kpi-row">
    <div class="kpi-card"><div class="kpi-value" id="kpi-total"> - </div><div class="kpi-label">Total Trainers</div></div>
    <div class="kpi-card brand"><div class="kpi-value" id="kpi-pro"> - </div><div class="kpi-label">Pro Subscribers</div></div>
    <div class="kpi-card green"><div class="kpi-value" id="kpi-reps"> - </div><div class="kpi-label">REPs Verified</div></div>
    <div class="kpi-card warn"><div class="kpi-value" id="kpi-pending"> - </div><div class="kpi-label">Pending Review</div></div>
    <div class="kpi-card"><div class="kpi-value" id="kpi-complete"> - </div><div class="kpi-label">Profile ≥80%</div></div>
    <div class="kpi-card"><div class="kpi-value" id="kpi-week"> - </div><div class="kpi-label">New This Week</div></div>
  </div>

  <div class="filters">
    <input class="filter-input" id="search" placeholder="Search by name, email, city..." oninput="applyFilters()" />
    <select class="filter-select" id="filter-plan" onchange="applyFilters()">
      <option value="">All Plans</option>
      <option value="pro">Pro</option>
      <option value="free">Free</option>
    </select>
    <select class="filter-select" id="filter-reps" onchange="applyFilters()">
      <option value="">All Verification</option>
      <option value="verified">Verified</option>
      <option value="pending">Pending</option>
      <option value="lapsed">Lapsed</option>
      <option value="unverified">Unverified</option>
    </select>
    <select class="filter-select" id="filter-completion" onchange="applyFilters()">
      <option value="">All Completion</option>
      <option value="high">≥80%</option>
      <option value="low">&lt;50%</option>
    </select>
    <select class="filter-select" id="filter-sort" onchange="applyFilters()">
      <option value="newest">Newest First</option>
      <option value="oldest">Oldest First</option>
      <option value="completion">By Completion</option>
      <option value="name">By Name</option>
    </select>
  </div>

  <div class="table-wrap">
    <div class="table-scroll">
      <table>
        <thead>
          <tr>
            <th>Trainer</th>
            <th>Plan</th>
            <th>Verification</th>
            <th>Profile</th>
            <th>City</th>
            <th>Market</th>
            <th>Joined</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody id="trainer-tbody">
          <tr><td colspan="8" class="loading">Loading trainers...</td></tr>
        </tbody>
      </table>
    </div>
  </div>
  </div><!-- end panel-trainers -->

  <!-- Verification Queue panel -->
  <div id="panel-queue" style="display:none">
    <div class="kpi-row">
      <div class="kpi-card warn"><div class="kpi-value" id="q-kpi-pending"> - </div><div class="kpi-label">Pending Review</div></div>
      <div class="kpi-card green"><div class="kpi-value" id="q-kpi-approved">0</div><div class="kpi-label">Approved Today</div></div>
      <div class="kpi-card"><div class="kpi-value" id="q-kpi-rejected">0</div><div class="kpi-label">Rejected Today</div></div>
    </div>
    <div id="queue-secret-gate">
      <div class="secret-prompt">
        <h3>Admin Access Required</h3>
        <p>Enter your admin secret to review and action verification submissions.</p>
        <input class="secret-input" type="password" id="admin-secret-input" placeholder="Admin secret..." />
        <button class="btn btn-primary" style="width:100%" onclick="unlockQueue()">Unlock Queue</button>
      </div>
    </div>
    <div id="queue-content" style="display:none">
      <div id="queue-list"><div class="loading">Loading verification queue...</div></div>
    </div>
  </div>
</div>

<!-- Cert Image Lightbox -->
<div class="modal-overlay" id="cert-lightbox">
  <div style="max-width:800px;width:100%;position:relative">
    <button class="action-btn view" style="position:absolute;top:-40px;right:0" onclick="closeLightbox()">✕ Close</button>
    <img id="lightbox-img" src="" alt="Certificate" style="width:100%;border-radius:12px;border:1px solid var(--border)" />
  </div>
</div>

<!-- Trainer Detail Modal -->
<div class="modal-overlay" id="detail-modal">
  <div class="modal" style="position:relative">
    <button class="action-btn view modal-close" onclick="closeModal()">✕ Close</button>
    <div class="modal-title" id="modal-name">Trainer Details</div>
    <div id="modal-body"></div>
    <div class="modal-actions">
      <button class="btn btn-primary" id="modal-email-btn">✉ Send Email</button>
      <a class="btn btn-ghost" id="modal-profile-link" href="#" target="_blank">↗ View Profile</a>
    </div>
  </div>
</div>

<div class="toast" id="toast"></div>

<!-- Bulk email confirm modal -->
<div class="modal-overlay" id="welcome-confirm-modal">
  <div class="modal" style="position:relative;max-width:400px">
    <div class="modal-title">Send welcome emails?</div>
    <p id="welcome-confirm-msg" style="font-size:13px;color:var(--text-muted);margin:0 0 20px"></p>
    <div class="modal-actions">
      <button class="btn btn-ghost" onclick="document.getElementById('welcome-confirm-modal').classList.remove('open')">Cancel</button>
      <button class="btn btn-primary" id="welcome-confirm-btn">Send emails</button>
    </div>
  </div>
</div>

<script define:vars={{ ANON_KEY: SUPABASE_ANON_KEY }}>
const EDGE_BASE = 'https://mezhtdbfyvkshpuplqqw.supabase.co/functions/v1';

let allTrainers = [];
let filteredTrainers = [];
let adminSecret = '';
let certReviews = [];

// ── Tab switching ─────────────────────────────────────────────────────────────
function switchTab(tab) {
  document.getElementById('panel-trainers').style.display = tab === 'trainers' ? '' : 'none';
  document.getElementById('panel-queue').style.display = tab === 'queue' ? '' : 'none';
  document.getElementById('tab-trainers').className = 'tab' + (tab === 'trainers' ? ' active' : '');
  document.getElementById('tab-queue').className = 'tab' + (tab === 'queue' ? ' active' : '');
}

function verificationBadge(t) {
  const status = t.verification_status || (t.reps_verified ? 'verified' : 'unverified');
  if (status === 'verified' || t.reps_verified) return '<span class="badge badge-reps">✓ Verified</span>';
  if (status === 'pending') return '<span class="badge badge-pending">⏳ Pending</span>';
  if (status === 'lapsed') return '<span class="badge badge-lapsed">⚠ Lapsed</span>';
  if (status === 'name_mismatch') return '<span class="badge badge-pending">Name Mismatch</span>';
  return '<span class="badge badge-free">Unverified</span>';
}

// ── Completion score ──────────────────────────────────────────────────────────
function completionScore(t) {
  let score = 0;
  if (t.avatar_url) score += 20;
  if (t.bio && t.bio.length > 30) score += 20;
  if (t.reps_verified) score += 15;
  if (t.specialties && t.specialties.length > 0) score += 10;
  if (t.city) score += 10;
  if (t.instagram) score += 10;
  if (t.packages && t.packages.length > 0) score += 10;
  if (t.years_experience) score += 5;
  return score;
}

function completionColor(pct) {
  if (pct >= 80) return '#00C853';
  if (pct >= 50) return '#ffaa00';
  return '#ff4444';
}

function isTestTrainer(t) {
  return (t.email && t.email.includes('xss_test')) ||
         (t.email && t.email === 'not-an-email') ||
         (t.name && t.name.includes('<script>'));
}

// ── Load trainers ─────────────────────────────────────────────────────────────
async function loadTrainers() {
  try {
    const res = await fetch(`${EDGE_BASE}/get-trainer?all=true`, {
      headers: { 'Authorization': 'Bearer ' + ANON_KEY }
    });

    // Fallback: use Supabase REST API directly
    const rest = await fetch(
      'https://mezhtdbfyvkshpuplqqw.supabase.co/rest/v1/trainers?select=*&order=created_at.desc',
      { headers: { 'Authorization': 'Bearer ' + ANON_KEY, 'apikey': ANON_KEY } }
    );
    allTrainers = await rest.json();

    if (!Array.isArray(allTrainers)) {
      allTrainers = [];
    }

    updateKPIs();
    applyFilters();
    document.getElementById('last-updated').textContent =
      'Last updated: ' + new Date().toLocaleTimeString('en-AE');

    // Update queue badge
    const pendingCount = allTrainers.filter(t =>
      t.verification_status === 'pending' && !isTestTrainer(t)
    ).length;
    const badge = document.getElementById('queue-badge');
    if (pendingCount > 0) { badge.textContent = pendingCount; badge.style.display = ''; }
    else { badge.style.display = 'none'; }
  } catch (err) {
    document.getElementById('trainer-tbody').innerHTML =
      '<tr><td colspan="8" class="loading" style="color:#ff4444">Error loading trainers: ' + err.message + '</td></tr>';
  }
}

// ── KPIs ──────────────────────────────────────────────────────────────────────
function updateKPIs() {
  const real = allTrainers.filter(t => !isTestTrainer(t));
  const weekAgo = new Date(Date.now() - 7 * 24 * 60 * 60 * 1000);

  document.getElementById('kpi-total').textContent = real.length;
  document.getElementById('kpi-pro').textContent = real.filter(t => t.plan === 'pro').length;
  document.getElementById('kpi-reps').textContent = real.filter(t => t.reps_verified || t.verification_status === 'verified').length;
  document.getElementById('kpi-pending').textContent = real.filter(t => t.verification_status === 'pending').length;
  document.getElementById('kpi-complete').textContent = real.filter(t => completionScore(t) >= 80).length;
  document.getElementById('kpi-week').textContent = real.filter(t => new Date(t.created_at) > weekAgo).length;
}

// ── Filters ───────────────────────────────────────────────────────────────────
function applyFilters() {
  const search = document.getElementById('search').value.toLowerCase();
  const plan = document.getElementById('filter-plan').value;
  const reps = document.getElementById('filter-reps').value;
  const completion = document.getElementById('filter-completion').value;
  const sort = document.getElementById('filter-sort').value;

  filteredTrainers = allTrainers.filter(t => {
    if (search && !(
      (t.name || '').toLowerCase().includes(search) ||
      (t.email || '').toLowerCase().includes(search) ||
      (t.city || '').toLowerCase().includes(search)
    )) return false;
    if (plan && t.plan !== plan) return false;
    if (reps === 'verified' && !(t.reps_verified || t.verification_status === 'verified')) return false;
    if (reps === 'pending' && t.verification_status !== 'pending') return false;
    if (reps === 'lapsed' && t.verification_status !== 'lapsed') return false;
    if (reps === 'unverified' && (t.reps_verified || ['verified','pending','lapsed'].includes(t.verification_status))) return false;
    const pct = completionScore(t);
    if (completion === 'high' && pct < 80) return false;
    if (completion === 'low' && pct >= 50) return false;
    return true;
  });

  filteredTrainers.sort((a, b) => {
    if (sort === 'oldest') return new Date(a.created_at) - new Date(b.created_at);
    if (sort === 'completion') return completionScore(b) - completionScore(a);
    if (sort === 'name') return (a.name || '').localeCompare(b.name || '');
    return new Date(b.created_at) - new Date(a.created_at); // newest
  });

  renderTable();
}

// ── Render table ──────────────────────────────────────────────────────────────
function renderTable() {
  const tbody = document.getElementById('trainer-tbody');
  if (filteredTrainers.length === 0) {
    tbody.innerHTML = '<tr><td colspan="8"><div class="empty-state"><h3>No trainers found</h3><p>Try adjusting your filters.</p></div></td></tr>';
    return;
  }

  tbody.innerHTML = filteredTrainers.map(t => {
    const pct = completionScore(t);
    const color = completionColor(pct);
    const initials = (t.name || '?').split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
    const isTest = isTestTrainer(t);
    const joined = new Date(t.created_at).toLocaleDateString('en-AE', { day: 'numeric', month: 'short', year: '2-digit' });
    const market = (t.market || 'ae').toUpperCase();

    return `<tr>
      <td>
        <div class="trainer-cell">
          ${t.avatar_url
            ? `<img class="trainer-avatar" src="${t.avatar_url}" alt="${initials}">`
            : `<div class="trainer-avatar">${initials}</div>`}
          <div>
            <div class="trainer-name">${sanitize(t.name || 'Unknown')} ${isTest ? '<span class="badge badge-test">TEST</span>' : ''}</div>
            <div class="trainer-email">${sanitize(t.email || ' - ')}</div>
          </div>
        </div>
      </td>
      <td>
        <span class="badge ${t.plan === 'pro' ? 'badge-pro' : 'badge-free'}">
          ${t.plan === 'pro' ? '★ Pro' : 'Free'}
        </span>
      </td>
      <td>${verificationBadge(t)}</td>
      <td>
        <div class="completion-wrap">
          <div class="completion-bar">
            <div class="completion-fill" style="width:${pct}%;background:${color}"></div>
          </div>
          <span class="completion-pct" style="color:${color}">${pct}%</span>
        </div>
      </td>
      <td style="color:var(--text-muted)">${sanitize(t.city || ' - ')}</td>
      <td style="color:var(--text-faint);font-size:11px;font-weight:700">${market}</td>
      <td style="color:var(--text-muted);white-space:nowrap">${joined}</td>
      <td>
        <div class="row-actions">
          <button class="action-btn view" onclick="openDetail('${t.id}')">View</button>
          <button class="action-btn email" onclick="sendEmail('${t.id}','${sanitize(t.email || '')}','${sanitize(t.name || '')}')">Email</button>
        </div>
      </td>
    </tr>`;
  }).join('');
}

// ── Detail modal ──────────────────────────────────────────────────────────────
function openDetail(id) {
  const t = allTrainers.find(x => x.id === id);
  if (!t) return;

  const pct = completionScore(t);
  const missing = [];
  if (!t.avatar_url) missing.push('Profile photo');
  if (!t.bio || t.bio.length < 30) missing.push('Bio');
  if (!t.reps_verified) missing.push('REPs verification');
  if (!t.specialties || t.specialties.length === 0) missing.push('Specialties');
  if (!t.city) missing.push('City');
  if (!t.instagram) missing.push('Instagram');

  document.getElementById('modal-name').textContent = t.name || 'Unknown Trainer';
  document.getElementById('modal-profile-link').href = window.location.origin + '/' + (t.slug || '');
  document.getElementById('modal-email-btn').onclick = () => sendEmail(t.id, t.email, t.name);

  document.getElementById('modal-body').innerHTML = `
    <div class="modal-field"><div class="modal-label">Email</div><div class="modal-value">${sanitize(t.email || ' - ')}</div></div>
    <div class="modal-field"><div class="modal-label">Phone</div><div class="modal-value ${t.phone ? '' : 'muted'}">${sanitize(t.phone || 'Not provided')}</div></div>
    <div class="modal-field"><div class="modal-label">Plan</div><div class="modal-value">${t.plan === 'pro' ? '★ Pro' : 'Free'}</div></div>
    <div class="modal-field"><div class="modal-label">REPs Status</div><div class="modal-value">${t.reps_verified ? '✓ Verified (Level ' + (t.reps_level || '?') + ')' : 'Not verified'}</div></div>
    <div class="modal-field"><div class="modal-label">City</div><div class="modal-value ${t.city ? '' : 'muted'}">${sanitize(t.city || 'Not set')}</div></div>
    <div class="modal-field"><div class="modal-label">Joined</div><div class="modal-value">${new Date(t.created_at).toLocaleDateString('en-AE', {day:'numeric',month:'long',year:'numeric'})}</div></div>
    <div class="modal-field"><div class="modal-label">Profile Completion</div>
      <div style="display:flex;align-items:center;gap:10px;margin-top:4px">
        <div class="completion-bar" style="flex:1;height:6px"><div class="completion-fill" style="width:${pct}%;background:${completionColor(pct)}"></div></div>
        <span style="font-weight:700;color:${completionColor(pct)}">${pct}%</span>
      </div>
    </div>
    ${missing.length > 0 ? `<div class="modal-field"><div class="modal-label">Missing</div><div class="modal-value muted">${missing.join(', ')}</div></div>` : ''}
    ${t.bio ? `<div class="modal-field"><div class="modal-label">Bio</div><div class="modal-value muted" style="font-size:12px;line-height:1.6">${sanitize(t.bio)}</div></div>` : ''}
    ${t.instagram ? `<div class="modal-field"><div class="modal-label">Instagram</div><div class="modal-value"><a href="https://instagram.com/${t.instagram}" target="_blank" style="color:var(--brand)">@${sanitize(t.instagram)}</a></div></div>` : ''}
  `;

  document.getElementById('detail-modal').classList.add('open');
}

function closeModal() {
  document.getElementById('detail-modal').classList.remove('open');
}

// ── Actions ───────────────────────────────────────────────────────────────────
async function sendEmail(id, email, name) {
  if (!email || email === 'not-an-email' || email.includes('example.com')) {
    showToast('Invalid email address', 'error');
    return;
  }
  closeModal();
  showToast('Sending welcome email to ' + name + '...', '');
  try {
    const res = await fetch(`${EDGE_BASE}/lifecycle-email`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + ANON_KEY },
      body: JSON.stringify({ trainer_id: id, type: 'welcome', force: true })
    });
    const data = await res.json();
    if (data.ok) showToast('Email sent to ' + name, 'success');
    else showToast('Email failed: ' + (data.error || 'Unknown error'), 'error');
  } catch (e) {
    showToast('Email failed: ' + e.message, 'error');
  }
}

async function sendWelcomeAll() {
  const real = allTrainers.filter(t => !isTestTrainer(t) && t.email && t.email.includes('@'));
  if (real.length === 0) { showToast('No real trainers to email', 'error'); return; }
  document.getElementById('welcome-confirm-msg').textContent = `Send welcome emails to ${real.length} trainer(s)?`;
  const modal = document.getElementById('welcome-confirm-modal');
  modal.classList.add('open');
  document.getElementById('welcome-confirm-btn').onclick = async () => {
    modal.classList.remove('open');
    showToast('Sending ' + real.length + ' emails...', '');
    for (const t of real) {
      await sendEmail(t.id, t.email, t.name);
      await new Promise(r => setTimeout(r, 500));
    }
  };
}

function exportCSV() {
  const headers = ['Name', 'Email', 'Plan', 'REPs', 'City', 'Completion%', 'Joined'];
  const rows = filteredTrainers.map(t => [
    t.name || '', t.email || '', t.plan || '', t.reps_verified ? 'Yes' : 'No',
    t.city || '', completionScore(t), t.created_at?.substring(0, 10) || ''
  ]);
  const csv = [headers, ...rows].map(r => r.map(v => '"' + String(v).replace(/"/g, '""') + '"').join(',')).join('\n');
  const a = document.createElement('a');
  a.href = 'data:text/csv;charset=utf-8,' + encodeURIComponent(csv);
  a.download = 'trainedby-trainers-' + new Date().toISOString().substring(0, 10) + '.csv';
  a.click();
}

// ── Helpers ───────────────────────────────────────────────────────────────────
function sanitize(str) {
  return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function timeAgo(date) {
  const diff = (Date.now() - date.getTime()) / 1000;
  if (diff < 60) return 'Just now';
  if (diff < 3600) return Math.floor(diff / 60) + 'm ago';
  if (diff < 86400) return Math.floor(diff / 3600) + 'h ago';
  if (diff < 604800) return Math.floor(diff / 86400) + 'd ago';
  return date.toLocaleDateString('en-AE', { day: 'numeric', month: 'short' });
}

function showToast(msg, type) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.className = 'toast show' + (type ? ' ' + type : '');
  setTimeout(() => t.classList.remove('show'), 3000);
}

// ── Verification Queue ────────────────────────────────────────────────────────
function unlockQueue() {
  const input = document.getElementById('admin-secret-input');
  adminSecret = input.value.trim();
  if (!adminSecret) { showToast('Enter your admin secret', 'error'); return; }
  document.getElementById('queue-secret-gate').style.display = 'none';
  document.getElementById('queue-content').style.display = '';
  loadQueue();
}

async function loadQueue() {
  const listEl = document.getElementById('queue-list');
  listEl.innerHTML = '<div class="loading">Loading queue...</div>';
  try {
    const res = await fetch(
      'https://mezhtdbfyvkshpuplqqw.supabase.co/rest/v1/cert_reviews?final_status=eq.pending&order=created_at.desc&select=*,trainers(name,email,market)',
      { headers: { 'Authorization': 'Bearer ' + ANON_KEY, 'apikey': ANON_KEY } }
    );
    certReviews = await res.json();
    if (!Array.isArray(certReviews) || certReviews.length === 0) {
      listEl.innerHTML = '<div class="empty-state"><h3>Queue is clear</h3><p>No certificates pending review.</p></div>';
      document.getElementById('q-kpi-pending').textContent = '0';
      return;
    }
    document.getElementById('q-kpi-pending').textContent = certReviews.length;
    renderQueue(certReviews);
  } catch (e) {
    listEl.innerHTML = '<div class="loading" style="color:#ff4444">Error loading queue: ' + e.message + '</div>';
  }
}

function renderQueue(reviews) {
  const listEl = document.getElementById('queue-list');
  listEl.innerHTML = reviews.map(r => {
    const trainer = r.trainers || {};
    const trainerName = sanitize(trainer.name || 'Unknown Trainer');
    const trainerEmail = sanitize(trainer.email || ' - ');
    const market = (trainer.market || 'ae').toUpperCase();
    const submitted = new Date(r.created_at).toLocaleDateString('en-AE', { day: 'numeric', month: 'short', year: '2-digit', hour: '2-digit', minute: '2-digit' });
    const confidenceBadge = r.claude_confidence ? `<span class="badge badge-${r.claude_confidence}">${r.claude_confidence}</span>` : '';
    const imgEl = r.cert_image_url
      ? `<img class="cert-card-img" src="${r.cert_image_url}" alt="Certificate" onclick="openLightbox('${r.cert_image_url}')" />`
      : `<div class="cert-card-no-img">📄</div>`;
    const extractedInfo = [
      r.extracted_name ? `<div><strong>Name on cert</strong><br>${sanitize(r.extracted_name)}</div>` : '',
      r.cert_number ? `<div><strong>Cert number</strong><br>${sanitize(r.cert_number)}</div>` : '',
      r.issuing_body ? `<div><strong>Issuing body</strong><br>${sanitize(r.issuing_body)}</div>` : '',
      r.expiry_date ? `<div><strong>Expiry</strong><br>${r.expiry_date}</div>` : '',
      r.claude_reasoning ? `<div><strong>Claude notes</strong><br>${sanitize(r.claude_reasoning)}</div>` : '',
    ].filter(Boolean).join('');
    return `<div class="cert-card" id="cert-card-${r.id}">
      ${imgEl}
      <div class="cert-card-body">
        <div class="cert-card-name">${trainerName} <span style="color:var(--text-faint);font-size:11px;font-weight:400">${market}</span></div>
        <div class="cert-card-meta">${trainerEmail} · Submitted ${submitted} · ${confidenceBadge}</div>
        ${extractedInfo ? `<div class="cert-card-extracted">${extractedInfo}</div>` : '<div style="color:var(--text-faint);font-size:12px">No data extracted by Claude.</div>'}
      </div>
      <div class="cert-card-actions">
        <button class="btn btn-success" onclick="actionCert('${r.id}','${r.trainer_id}','approve')">✓ Approve</button>
        <button class="btn btn-danger" onclick="actionCert('${r.id}','${r.trainer_id}','reject')">✕ Reject</button>
      </div>
    </div>`;
  }).join('');
}

async function actionCert(reviewId, trainerId, action) {
  if (!adminSecret) { showToast('Admin secret required', 'error'); return; }
  showToast(action === 'approve' ? 'Approving...' : 'Rejecting...', '');
  try {
    const res = await fetch(`${EDGE_BASE}/admin-verify`, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + ANON_KEY, 'x-admin-secret': adminSecret },
      body: JSON.stringify({ action, cert_review_id: reviewId, trainer_id: trainerId }),
    });
    const data = await res.json();
    if (data.ok) {
      showToast(data.message || (action === 'approve' ? 'Approved' : 'Rejected'), 'success');
      const card = document.getElementById('cert-card-' + reviewId);
      if (card) { card.style.opacity = '0.4'; card.style.pointerEvents = 'none'; setTimeout(() => card.remove(), 600); }
      const pending = Math.max(0, parseInt(document.getElementById('q-kpi-pending').textContent || '0') - 1);
      document.getElementById('q-kpi-pending').textContent = pending;
      const badge = document.getElementById('queue-badge');
      const newCount = Math.max(0, parseInt(badge.textContent || '0') - 1);
      if (newCount > 0) { badge.textContent = newCount; } else { badge.style.display = 'none'; }
      const kpiKey = action === 'approve' ? 'q-kpi-approved' : 'q-kpi-rejected';
      document.getElementById(kpiKey).textContent = (parseInt(document.getElementById(kpiKey).textContent || '0') + 1).toString();
    } else {
      showToast('Error: ' + (data.error || 'Unknown'), 'error');
    }
  } catch (e) { showToast('Request failed: ' + e.message, 'error'); }
}

function openLightbox(url) {
  document.getElementById('lightbox-img').src = url;
  document.getElementById('cert-lightbox').classList.add('open');
}
function closeLightbox() {
  document.getElementById('cert-lightbox').classList.remove('open');
}

// Close modals on overlay click
document.getElementById('detail-modal').addEventListener('click', function(e) {
  if (e.target === this) closeModal();
});
document.getElementById('cert-lightbox').addEventListener('click', function(e) {
  if (e.target === this) closeLightbox();
});

loadTrainers();
setInterval(loadTrainers, 60000);
</script>
