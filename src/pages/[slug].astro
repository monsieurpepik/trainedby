      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
      Profile
    </a>
  </nav>

  <script>
    // Load the full profile page JS dynamically
    // The profile.astro getSlug() reads window.__TRAINER_SLUG__ first (set above),
    // then falls back to location.pathname, then query params.
    // We load profile rendering logic from a shared module.

    const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lemh0ZGJmeXZrc2hwdXBscXF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MzE4NDIsImV4cCI6MjA5MDUwNzg0Mn0.zJG9xodJS70Wl2IJWiLxk2bSL7eukg5uUbLfF7jvQAo';

    function getSlug() {
      // Priority: injected server-side > pathname > query param
      if (window.__TRAINER_SLUG__) return window.__TRAINER_SLUG__;
      const path = location.pathname.replace(/^\//, '').trim();
      if (path && path !== 'index.html' && path !== 'profile') return path;
      const q = new URLSearchParams(location.search);
      return q.get('trainer') || q.get('slug') || '';
    }

    async function loadTrainer() {
      const slug = getSlug();
      if (!slug) { showErr('No trainer specified'); return; }

      try {
        const r = await fetch(
          `${SUPABASE_URL}/functions/v1/get-trainer?slug=${encodeURIComponent(slug)}`,
          { headers: { 'Authorization': `Bearer ${SUPABASE_KEY}`, 'apikey': SUPABASE_KEY } }
        );
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const resp = await r.json();
        if (!resp || resp.error) throw new Error('Trainer not found');
        // get-trainer returns { trainer, packages }
        const trainerData = resp.trainer || resp;
        const pkgs = resp.packages || [];
        renderProfile(trainerData, pkgs);
      } catch (e) {
        showErr('Trainer not found');
      }
    }

    function showErr(msg = 'Trainer not found') {
      const mount = document.getElementById('profile-mount');
      const loading = document.getElementById('tb-loading');
      if (loading) loading.style.display = 'none';
      if (mount) {
        mount.style.display = 'block';
        mount.innerHTML = `
      <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80vh;gap:24px;padding:32px;text-align:center;font-family:'DM Sans',system-ui,sans-serif">
        <div style="font-size:64px;font-weight:200;letter-spacing:-0.02em;color:#111111;line-height:1">404</div>
        <h1 style="font-size:22px;font-weight:300;color:#111111">Trainer not found</h1>
        <p style="color:#6B6460;max-width:360px;line-height:1.6;font-size:13.5px;font-weight:300">This trainer profile doesn't exist or may have been removed.</p>
        <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">
          <a href="/find" style="background:#1A1411;color:#fff;padding:12px 28px;border-radius:13px;text-decoration:none;font-weight:500;font-size:14px;letter-spacing:0.04em">Find a Trainer</a>
          <a href="/" style="background:transparent;border:1px solid rgba(0,0,0,0.10);color:#7A7068;padding:12px 28px;border-radius:13px;text-decoration:none;font-weight:300;font-size:14px">Go Home</a>
        </div>
      </div>`;
      }
    }

    // Premium gradient avatar fallback - generates a branded canvas image with initials
    function makeAvatarFallback(name) {
      const initials = (name || '?').split(' ').map(w => w[0] || '').join('').toUpperCase().slice(0, 2) || '?';
      const brandColor = getComputedStyle(document.documentElement).getPropertyValue('--brand').trim() || '#D4622A';
      const r = parseInt(brandColor.slice(1,3), 16) || 255;
      const g = parseInt(brandColor.slice(3,5), 16) || 92;
      const b = parseInt(brandColor.slice(5,7), 16) || 0;
      const canvas = document.createElement('canvas');
      canvas.width = 800; canvas.height = 480;
      const ctx = canvas.getContext('2d');
      // Dark base
      ctx.fillStyle = '#080808';
      ctx.fillRect(0, 0, 800, 480);
      // Brand gradient overlay
      const grad = ctx.createLinearGradient(0, 0, 800, 480);
      grad.addColorStop(0, `rgba(${r},${g},${b},0.40)`);
      grad.addColorStop(0.6, `rgba(${Math.round(r*0.5)},${Math.round(g*0.5)},${Math.round(b*0.5)},0.15)`);
      grad.addColorStop(1, 'rgba(8,8,8,0.95)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, 800, 480);
      // Subtle radial glow behind initials
      const radial = ctx.createRadialGradient(400, 200, 0, 400, 200, 180);
      radial.addColorStop(0, `rgba(${r},${g},${b},0.22)`);
      radial.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = radial;
      ctx.fillRect(0, 0, 800, 480);
      // Circle border
      ctx.beginPath();
      ctx.arc(400, 200, 92, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${r},${g},${b},0.55)`;
      ctx.lineWidth = 2;
      ctx.stroke();
      // Initials
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 76px Manrope, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(initials, 400, 200);
      return canvas.toDataURL('image/png');
    }

    // Apply avatar fallback to background element
    function applyAvatarFallback(name) {
      const bg = document.getElementById('bg');
      if (bg) {
        const dataUrl = makeAvatarFallback(name);
        bg.style.backgroundImage = `url('${dataUrl}')`;
        bg.style.backgroundSize = 'cover';
      }
      // Also hide any broken img tags inside the hero
      const heroImg = document.querySelector('#profile-mount img[data-hero]');
      if (heroImg) heroImg.style.display = 'none';
    }

    function esc(s) {
      return String(s == null ? '' : s)
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    function renderProfile(t, packages) {
      window.__TRAINER_ID__ = t.id;
      const loading = document.getElementById('tb-loading');
      const mount = document.getElementById('profile-mount');
      if (loading) loading.style.display = 'none';
      if (!mount) return;
      mount.style.display = 'block';

      // Field name mapping
      const displayName = t.name || t.full_name || '';
      const photoUrl = t.avatar_url || t.profile_photo_url || '';
      const specialties = Array.isArray(t.specialties) ? t.specialties : (t.specialties ? [t.specialties] : ['Personal Trainer']);
      const rating = t.avg_rating ? parseFloat(t.avg_rating).toFixed(1) : null;
      const reviewCount = t.review_count || 0;
      const isVerified = t.reps_verified || t.is_verified || t.verification_status === 'verified';
      const city = t.city || '';
      const country = t.country || '';
      const location = [city, country].filter(Boolean).join(', ');
      const bio = t.bio || '';
      const instagram = t.instagram || t.instagram_handle || '';
      const whatsapp = t.whatsapp || t.phone || '';
      const certifications = Array.isArray(t.certifications) ? t.certifications : [];
      const experience = t.experience_years || t.years_experience || null;
      const clients = t.total_clients || t.client_count || null;

      // Deduplicate packages by name
      const _rawPkgs = (Array.isArray(packages) ? packages : []).filter(Boolean);
      const _seenPkgNames = new Set();
      const pkgList = _rawPkgs.filter(p => {
        if (_seenPkgNames.has(p.name)) return false;
        _seenPkgNames.add(p.name);
        return true;
      });

      // Update compact header name
      const chName = document.getElementById('ch-trainer-name');
      if (chName) chName.textContent = displayName;

      // ── Build stats (only non-null values) ──────────────────────────────
      const statItems = [];
      if (rating !== null && reviewCount > 0) {
        statItems.push({ num: rating, label: 'Rating' });
        statItems.push({ num: reviewCount, label: reviewCount === 1 ? 'Review' : 'Reviews' });
      }
      if (experience) statItems.push({ num: experience + 'y', label: 'Experience' });
      const goalRate = t.goal_achievement_rate || null;
      if (goalRate) statItems.push({ num: goalRate + '%', label: 'Goal Rate' });
      if (clients) statItems.push({ num: clients + '+', label: 'Clients' });
      const statCols = statItems.length || 1;

      // ── CTA label (payment or free enquiry) ─────────────────────────────
      const ctaLabel = window.__PAYMENT_ENABLED__ ? 'Book a Session' : 'Request a Session';

      // ── Package price renderer ──────────────────────────────────────────
      const currSym = window.__CURRENCY_SYMBOL__;
      function fmtPkgPrice(p) {
        if (!p.price) return '';
        const sym = currSym || p.currency || '';
        return sym ? `${esc(sym)} ${esc(p.price)}` : `${esc(p.price)}`;
      }

      // ── Tags for identity strip ──────────────────────────────────────────
      const tagsRaw = [...specialties.slice(0, 3)];
      if (isVerified) tagsRaw.unshift('Verified');
      if (certifications.length > 0 && tagsRaw.length < 4) tagsRaw.push(certifications[0]);
      const cappedTags = [...new Set(tagsRaw)].slice(0, 4);

      mount.innerHTML = `
        <!-- 1. HERO ────────────────────────────────────────────────────── -->
        <div class="tb-hero">
          ${photoUrl ? `<img class="tb-hero-img" src="${photoUrl}" alt="${esc(displayName)}" onerror="this.style.display='none'">` : ''}
          <div class="tb-hero-fade"></div>
          <div class="tb-hero-controls">
            <button class="tb-hero-btn" onclick="history.length>1?history.back():location.href='/find'" aria-label="Back">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            ${'share' in navigator ? `<button class="tb-hero-btn" onclick="shareProfile('${esc(displayName)}')" aria-label="Share">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            </button>` : '<span></span>'}
          </div>
          ${photoUrl ? `
          <div class="tb-hero-name-block">
            <div class="tb-hero-name">${esc(displayName)}</div>
            ${specialties[0] ? `<div class="tb-hero-tagline">${esc(specialties[0])}${location ? ' · ' + esc(location) : ''}</div>` : ''}
          </div>` : ''}
          <div id="hero-sentinel"></div>
        </div>

        <!-- 2. IDENTITY STRIP ───────────────────────────────────────────── -->
        <div class="tb-identity">
          ${cappedTags.map(tag => `<span class="tb-tag">${esc(tag)}</span>`).join('')}
          ${location ? `<span class="tb-location">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            ${esc(location)}
          </span>` : ''}
        </div>

        <!-- 3. STATS ROW ────────────────────────────────────────────────── -->
        ${statItems.length > 0 ? `
        <div class="tb-stats" style="grid-template-columns:repeat(${statCols},1fr)">
          ${statItems.map(s => `
          <div class="tb-stat-item">
            <div class="tb-stat-num">${s.num}</div>
            <div class="tb-stat-label">${s.label}</div>
          </div>`).join('')}
        </div>` : ''}

        <!-- 4. CTA ──────────────────────────────────────────────────────── -->
        <div class="tb-cta">
          ${whatsapp ? `
          <a href="https://wa.me/${whatsapp.replace(/\D/g,'')}?text=${encodeURIComponent('Hi ' + esc(displayName) + ', I found your profile on TrainedBy and I\'d like to book a session.')}"
             target="_blank" rel="noopener" class="tb-btn-primary" style="animation:wa-pulse 2s ease infinite">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.65)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            ${ctaLabel}
          </a>` : `
          <button class="tb-btn-primary" onclick="alert('Booking coming soon!')">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(255,255,255,0.65)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
            ${ctaLabel}
          </button>`}
          <button class="tb-btn-secondary" onclick="
  const ph = '${whatsapp ? whatsapp.replace(/\D/g,'') : ''}';
  if(ph) window.open('https://wa.me/'+ph+'?text='+encodeURIComponent('Hi, I\\'d like to get in touch.'),'_blank');
  else alert('Contact coming soon!');
">Send a message</button>
        </div>

        <!-- 5. PACKAGES ─────────────────────────────────────────────────── -->
        ${pkgList.length > 0 ? `
        <div class="tb-sessions">
          <div class="tb-sessions-header">
            <span class="tb-section-label">Sessions</span>
            <a href="javascript:void(0)" class="tb-see-all">See all →</a>
          </div>
          <div class="tb-sessions-scroll">
            ${pkgList.map(p => `
            <div class="tb-pkg-card">
              <div class="tb-pkg-name">${esc(p.name || p.title || 'Package')}</div>
              ${p.sessions ? `<div class="tb-pkg-detail">${p.sessions} session${p.sessions > 1 ? 's' : ''}</div>` : ''}
              ${p.description ? `<div class="tb-pkg-detail">${esc(p.description)}</div>` : ''}
              ${p.price ? `<div class="tb-pkg-price">${fmtPkgPrice(p)}</div>` : ''}
              ${whatsapp ? `
              <button class="tb-pkg-book"
                data-wa="${whatsapp.replace(/\D/g,'')}"
                data-msg="${esc('Hi ' + displayName + ', I\'m interested in the ' + (p.name || 'package') + '.')}"
                onclick="var b=this;window.open('https://wa.me/'+b.dataset.wa+'?text='+encodeURIComponent(b.dataset.msg),'_blank')">
                Book
              </button>` : ''}
            </div>`).join('')}
          </div>
        </div>` : ''}

        <!-- 6. ABOUT ────────────────────────────────────────────────────── -->
        ${bio ? `
        <div class="tb-about">
          <div class="tb-section-label" style="margin-bottom:12px">About</div>
          <div class="tb-about-text" id="tb-about-text">${esc(bio)}</div>
          <button class="tb-read-more" id="tb-read-more" onclick="
            var el=document.getElementById('tb-about-text');
            var btn=document.getElementById('tb-read-more');
            if(el.classList.contains('expanded')){el.classList.remove('expanded');btn.textContent='Read more';}
            else{el.classList.add('expanded');btn.textContent='Read less';}
          ">Read more</button>
        </div>` : ''}

        <!-- 7. REVIEWS SHELL ─────────────────────────────────────────────── -->
        <div class="tb-reviews">
          <div class="tb-section-label" style="margin-bottom:12px">Reviews</div>
          <div id="reviewsContent" class="tb-reviews-loading">Loading reviews...</div>
        </div>
      `;

      // Load reviews asynchronously after rendering
      loadReviews(t.id);

      // Set up IntersectionObserver for compact header
      const sentinel = document.getElementById('hero-sentinel');
      if (sentinel) {
        const obs = new IntersectionObserver(([entry]) => {
          const header = document.getElementById('tb-compact-header');
          if (header) header.classList.toggle('visible', !entry.isIntersecting);
        }, { threshold: 0 });
        obs.observe(sentinel);
      }
    }

    // Web Share API
    function shareProfile(name) {
      if (navigator.share) {
        navigator.share({
          title: name + ' - Verified Personal Trainer',
          text: 'Check out ' + name + "'s verified trainer profile",
          url: location.href
        }).catch(() => {});
      } else {
        // Fallback: copy to clipboard
        navigator.clipboard.writeText(location.href).then(() => {
          const btn = document.getElementById('share-btn');
          if (btn) { btn.textContent = 'Link copied!'; setTimeout(() => { btn.textContent = 'Share this profile'; }, 2000); }
        });
      }
    }

    // ── Reviews ──────────────────────────────────────────────────────────────
    async function loadReviews(trainerId) {
      if (!trainerId) return;
      try {
        const r = await fetch(
          `${SUPABASE_URL}/rest/v1/reviews?trainer_id=eq.${trainerId}&verified=eq.true&order=created_at.desc&limit=8`,
          { headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}` } }
        );
        const reviews = await r.json();
        const el = document.getElementById('reviewsContent');
        if (!el) return;
        el.classList.remove('tb-reviews-loading');
        if (!Array.isArray(reviews) || reviews.length === 0) {
          el.innerHTML = `<div style="text-align:center;padding:20px 16px;border:1px dashed rgba(0,0,0,0.08);border-radius:12px;color:var(--text-muted);font-size:13px">No reviews yet — be the first!</div>`;
          return;
        }
        const avg = reviews.reduce((a,b) => a + b.rating, 0) / reviews.length;
        const starColor = '#F59E0B';
        const starEmpty = 'rgba(0,0,0,0.12)';
        let starsHtml = '';
        for (let i = 1; i <= 5; i++) starsHtml += `<span style="color:${i<=Math.round(avg)?starColor:starEmpty};font-size:14px">&#9733;</span>`;
        let html = `<div style="display:flex;align-items:center;gap:14px;padding:14px;background:var(--review-card-bg);border-radius:10px;margin-bottom:12px"><div style="font-size:36px;font-weight:200;letter-spacing:-0.02em;color:var(--text-primary);line-height:1">${avg.toFixed(1)}</div><div><div style="display:flex;gap:2px;margin-bottom:4px">${starsHtml}</div><div style="font-size:12px;color:var(--text-muted)">${reviews.length} verified review${reviews.length>1?'s':''}</div></div></div>`;
        reviews.forEach(rv => {
          let rvStars = '';
          for (let i=1;i<=5;i++) rvStars += `<span style="color:${i<=rv.rating?starColor:starEmpty};font-size:12px">&#9733;</span>`;
          const initials = (rv.client_name||'?').substring(0,2).toUpperCase();
          html += `<div style="background:var(--review-card-bg);border-radius:10px;padding:14px;margin-bottom:8px"><div style="display:flex;align-items:center;gap:10px;margin-bottom:8px"><div style="width:32px;height:32px;border-radius:50%;background:rgba(0,0,0,0.06);display:flex;align-items:center;justify-content:center;font-size:11px;font-weight:600;color:var(--text-secondary);flex-shrink:0">${initials}</div><div><div style="font-size:13px;font-weight:400;color:var(--text-primary)">${rv.client_name||'Client'}</div><div style="font-size:10px;color:#22c55e;font-weight:500;margin-top:1px">&#10003; Verified</div></div><div style="display:flex;gap:2px;margin-left:auto">${rvStars}</div></div><div style="font-size:13px;line-height:1.7;color:var(--text-secondary);font-weight:300">${rv.review_text||''}</div>${rv.goal_achieved?`<div style="display:inline-flex;align-items:center;gap:4px;margin-top:8px;padding:3px 9px;background:rgba(34,197,94,0.08);border:1px solid rgba(34,197,94,0.2);border-radius:20px;font-size:11px;font-weight:500;color:#22c55e">${rv.goal_achieved}</div>`:''}</div>`;
        });
        el.innerHTML = html;
      } catch(e) {
        const el = document.getElementById('reviewsContent');
        if (el) { el.classList.remove('tb-reviews-loading'); el.innerHTML = `<div style="text-align:center;padding:20px;color:var(--text-muted);font-size:13px">Could not load reviews.</div>`; }
      }
    }

    let _selectedRating = 0;
    function setRating(v) {
      _selectedRating = v;
      const stars = document.querySelectorAll('#starPicker span');
      stars.forEach((s, i) => { s.style.color = i < v ? '#F59E0B' : 'rgba(0,0,0,0.15)'; });
    }

    async function submitReview() {
      const name = (document.getElementById('rvName').value || '').trim();
      const text = (document.getElementById('rvText').value || '').trim();
      const goal = (document.getElementById('rvGoal').value || '').trim();
      const btn = document.getElementById('rvSubmitBtn');
      if (!name) { showRvMsg('Please enter your name.', '#ff5555'); return; }
      if (!_selectedRating) { showRvMsg('Please select a star rating.', '#ff5555'); return; }
      if (text.length < 10) { showRvMsg('Please write at least 10 characters.', '#ff5555'); return; }
      const consentEl = document.getElementById('rvConsent');
      if (!consentEl.checked) {
        showRvMsg('Please confirm your consent to submit a review.', '#ff5555');
        document.getElementById('rvConsentLabel')?.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      btn.disabled = true; btn.textContent = 'Submitting...';
      try {
        const trainerId = window.__TRAINER_ID__;
        const payload = {
          trainer_id: trainerId,
          client_name: name,
          client_avatar_initials: name.split(' ').map(w=>w[0]).slice(0,2).join('').toUpperCase(),
          rating: _selectedRating,
          review_text: text,
          goal_achieved: goal || null,
          verified: false,
          featured: false,
          consent: true,
        };
        const r = await fetch(`${SUPABASE_URL}/rest/v1/reviews`, {
          method: 'POST',
          headers: { 'apikey': SUPABASE_KEY, 'Authorization': `Bearer ${SUPABASE_KEY}`, 'Content-Type': 'application/json', 'Prefer': 'return=minimal' },
          body: JSON.stringify(payload),
        });
        if (r.ok || r.status === 201) {
          showRvMsg('Thank you! Your review will appear once verified.', '#22c55e');
          document.getElementById('writeReviewForm').style.display = 'none';
          document.getElementById('writeReviewToggle').style.display = 'none';
        } else {
          showRvMsg('Something went wrong. Please try again.', '#ff5555');
        }
      } catch(e) {
        showRvMsg('Network error. Please try again.', '#ff5555');
      } finally {
        btn.disabled = false; btn.textContent = 'Submit Review';
      }
    }

    function showRvMsg(text, color) {
      const el = document.getElementById('rvMsg');
      if (!el) return;
      el.textContent = text; el.style.color = color; el.style.display = 'block';
    }

    // Kick off on load
    loadTrainer();
  </script>
</Base>
