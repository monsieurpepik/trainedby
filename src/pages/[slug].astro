---
/**
 * Dynamic trainer profile route
 * Serves clean URLs: /sarah-al-mansoori → renders the full profile page
 * The slug is injected into window.__TRAINER_SLUG__ so getSlug() in the
 * profile JS picks it up correctly without changing the URL.
 */
import Base from "../layouts/Base.astro";
import { getMarket } from "../lib/market.ts";

const { slug } = Astro.params;
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName;

// Validate slug - only alphanumeric and hyphens
if (!slug || !/^[a-z0-9-]+$/i.test(slug)) {
  return Astro.redirect('/find', 302);
}

// Reserved routes - never treat these as trainer slugs
const RESERVED = new Set([
  'find', 'join', 'pricing', 'blog', 'dashboard', 'edit',
  'admin', 'superadmin', 'for-trainers', 'privacy',
  'terms', 'cookie-policy', 'landing', 'index', 'profile',
  'sitemap.xml', 'robots.txt', 'favicon.ico', 'manifest.webmanifest',
]);
if (RESERVED.has(slug.toLowerCase())) {
  return Astro.redirect('/find', 302);
}

// Verify trainer exists before rendering (SSR - runs on server)
const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
const ANON_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lemh0ZGJmeXZrc2hwdXBscXF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MzE4NDIsImV4cCI6MjA5MDUwNzg0Mn0.zJG9xodJS70Wl2IJWiLxk2bSL7eukg5uUbLfF7jvQAo';

let trainerName = '';
let trainerSpecialty = '';
let trainerPhoto = '';
let trainerExists = false;

try {
  const res = await fetch(
    `${SUPABASE_URL}/rest/v1/trainers?slug=eq.${encodeURIComponent(slug)}&select=name,specialties,avatar_url&limit=1`,
    { headers: { 'apikey': ANON_KEY, 'Authorization': `Bearer ${ANON_KEY}` } }
  );
  if (res.ok) {
    const data = await res.json();
    if (Array.isArray(data) && data.length > 0) {
      trainerExists = true;
      trainerName = data[0].name || '';
      trainerSpecialty = Array.isArray(data[0].specialties)
        ? data[0].specialties[0]
        : (data[0].specialties || 'Personal Trainer');
      trainerPhoto = data[0].avatar_url || '';
    }
  }
} catch (e) {
  // On network error, still render - client JS will handle the error state
  trainerExists = true;
}

if (!trainerExists) {
  return new Response(null, { status: 404 });
}

const pageTitle = trainerName
  ? `${trainerName} - Verified Trainer on ${brandName}`
  : `Trainer Profile - ${brandName}`;
const pageDesc = trainerName
  ? `Book sessions with ${trainerName}, a verified ${trainerSpecialty} on ${brandName}.`
  : `Verified personal trainer profile on ${brandName}`;
const pageImage = trainerPhoto || 'https://images.unsplash.com/photo-1571902943202-507ec2618e8f?w=1200&q=85';
---
<Base
  title={pageTitle}
  description={pageDesc}
  ogImage={pageImage}
>
  <!-- Inject the slug server-side so client getSlug() picks it up immediately -->
  <script define:vars={{ slug }}>
    window.__TRAINER_SLUG__ = slug;
  </script>

  <!-- Full profile page content - identical to profile.astro but slug-aware -->
  <style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
  :root{
    --orange: var(--brand, #FF5C00);
    --orange-dim: var(--brand-dim, rgba(255,92,0,0.15));
    --green:#22c55e;--green-dim:rgba(34,197,94,0.15);
    --white:#ffffff;--white-60:rgba(255,255,255,0.6);
    --white-30:rgba(255,255,255,0.3);--white-10:rgba(255,255,255,0.1);
    --white-06:rgba(255,255,255,0.06);
    --black:#000000;
    /* Glassmorphism tokens */
    --glass:rgba(12,12,12,0.65);
    --glass-light:rgba(255,255,255,0.04);
    --glass-border:rgba(255,255,255,0.10);
    --glass-border-hover:rgba(255,255,255,0.18);
    --blur:blur(24px);
    --blur-sm:blur(12px);
    --radius:16px;--radius-sm:10px;--radius-lg:24px;
    --font-display: var(--font-display, 'Manrope', sans-serif);
    --font-body: var(--font-body, 'Inter', sans-serif);
    /* Dynamic avatar color - set by JS after image loads */
    --avatar-color: 255,92,0;
  }
  html,body{height:100%;width:100%;overflow-x:hidden}
  body{font-family:var(--font-body);background:#0a0a0a;color:var(--white);-webkit-font-smoothing:antialiased}

  /* Dynamic avatar-derived background */
  #bg{position:fixed;inset:0;z-index:0;background:#0a0a0a;background-size:cover;background-position:center top;transition:background-image 0.4s ease}
  #bg::after{content:'';position:absolute;inset:0;background:linear-gradient(to bottom,rgba(0,0,0,0.2) 0%,rgba(0,0,0,0.55) 40%,rgba(0,0,0,0.88) 70%,rgba(0,0,0,0.98) 100%)}
  /* Ambient color bloom from avatar */
  #bg-bloom{position:fixed;inset:0;z-index:0;pointer-events:none;
    background:radial-gradient(ellipse 80% 60% at 50% 0%, rgba(var(--avatar-color),0.18) 0%, transparent 70%);
    transition:background 1.2s ease;}
  #root{position:relative;z-index:1;min-height:100vh}
  .loading-state{display:flex;align-items:center;justify-content:center;min-height:100vh;flex-direction:column;gap:16px}
  .spinner{width:40px;height:40px;border:3px solid rgba(255,255,255,0.1);border-top-color:var(--orange);border-radius:50%;animation:spin 0.8s linear infinite}
  @keyframes spin{to{transform:rotate(360deg)}}

  /* ── Mobile responsive ────────────────────────────────────────────── */
  #profile-mount > div {
    padding-bottom: max(80px, calc(80px + env(safe-area-inset-bottom)));
  }
  @media(max-width:480px){
    #profile-mount > div { padding-left:12px; padding-right:12px; }
  }

  /* ── WhatsApp CTA pulse animation ─────────────────────────────────── */
  @keyframes wa-pulse {
    0%,100%{box-shadow:0 0 0 0 rgba(37,211,102,0.5)}
    50%{box-shadow:0 0 0 10px rgba(37,211,102,0)}
  }
  .wa-cta-pulse { animation: wa-pulse 2.5s ease infinite; }
  </style>

  <div id="bg"></div>
  <div id="bg-bloom"></div>
  <div id="root">
    <div class="loading-state" id="loading-state">
      <div class="spinner"></div>
    </div>
    <div id="profile-mount" style="display:none"></div>
  </div>

  <script>
    // Load the full profile page JS dynamically
    // The profile.astro getSlug() reads window.__TRAINER_SLUG__ first (set above),
    // then falls back to location.pathname, then query params.
    // We load profile rendering logic from a shared module.

    const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
    const SUPABASE_KEY = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lemh0ZGJmeXZrc2hwdXBscXF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQ5MzE4NDIsImV4cCI6MjA5MDUwNzg0Mn0.zJG9xodJS70Wl2IJWiLxk2bSL7eukg5uUbLfF7jvQAo';

    function getSlug() {
      // Priority: injected server-side > pathname > query param
      if (window.__TRAINER_SLUG__) return window.__TRAINER_SLUG__;
      const path = location.pathname.replace(/^\//, '').trim();
      if (path && path !== 'index.html' && path !== 'profile') return path;
      const q = new URLSearchParams(location.search);
      return q.get('trainer') || q.get('slug') || '';
    }

    async function loadTrainer() {
      const slug = getSlug();
      if (!slug) { showErr('No trainer specified'); return; }

      try {
        const r = await fetch(
          `${SUPABASE_URL}/functions/v1/get-trainer?slug=${encodeURIComponent(slug)}`,
          { headers: { 'Authorization': `Bearer ${SUPABASE_KEY}`, 'apikey': SUPABASE_KEY } }
        );
        if (!r.ok) throw new Error(`HTTP ${r.status}`);
        const resp = await r.json();
        if (!resp || resp.error) throw new Error('Trainer not found');
        // get-trainer returns { trainer, packages }
        const trainerData = resp.trainer || resp;
        const pkgs = resp.packages || [];
        renderProfile(trainerData, pkgs);
      } catch (e) {
        showErr('Trainer not found');
      }
    }

    function showErr(msg = 'Trainer not found') {
      const mount = document.getElementById('profile-mount');
      const loading = document.getElementById('loading-state');
      if (loading) loading.style.display = 'none';
      if (mount) {
        mount.style.display = 'block';
        mount.innerHTML = `
          <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;min-height:80vh;gap:24px;padding:32px;text-align:center">
            <div style="font-size:64px;font-weight:900;line-height:1;background:linear-gradient(135deg,#FF5C00,#ff8c42);-webkit-background-clip:text;-webkit-text-fill-color:transparent">404</div>
            <h1 style="font-size:24px;font-weight:700">Trainer not found</h1>
            <p style="color:rgba(255,255,255,0.6);max-width:400px;line-height:1.6">This trainer profile doesn't exist or may have been removed.</p>
            <div style="display:flex;gap:12px;flex-wrap:wrap;justify-content:center">
              <a href="/find" style="background:#FF5C00;color:#fff;padding:12px 28px;border-radius:10px;text-decoration:none;font-weight:700">Find a Trainer</a>
              <a href="/" style="background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.8);padding:12px 28px;border-radius:10px;text-decoration:none;font-weight:600">Go Home</a>
            </div>
            <div style="padding:14px 20px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:10px;max-width:400px;font-size:13px;color:rgba(255,255,255,0.45);line-height:1.6">
              <strong style="color:rgba(255,255,255,0.65)">Looking for a specific trainer?</strong> Try searching by name or specialty on the Find page.
            </div>
          </div>`;
      }
    }

    // Premium gradient avatar fallback - generates a branded canvas image with initials
    function makeAvatarFallback(name) {
      const initials = (name || '?').split(' ').map(w => w[0] || '').join('').toUpperCase().slice(0, 2) || '?';
      const brandColor = getComputedStyle(document.documentElement).getPropertyValue('--brand').trim() || '#FF5C00';
      const r = parseInt(brandColor.slice(1,3), 16) || 255;
      const g = parseInt(brandColor.slice(3,5), 16) || 92;
      const b = parseInt(brandColor.slice(5,7), 16) || 0;
      const canvas = document.createElement('canvas');
      canvas.width = 800; canvas.height = 480;
      const ctx = canvas.getContext('2d');
      // Dark base
      ctx.fillStyle = '#080808';
      ctx.fillRect(0, 0, 800, 480);
      // Brand gradient overlay
      const grad = ctx.createLinearGradient(0, 0, 800, 480);
      grad.addColorStop(0, `rgba(${r},${g},${b},0.40)`);
      grad.addColorStop(0.6, `rgba(${Math.round(r*0.5)},${Math.round(g*0.5)},${Math.round(b*0.5)},0.15)`);
      grad.addColorStop(1, 'rgba(8,8,8,0.95)');
      ctx.fillStyle = grad;
      ctx.fillRect(0, 0, 800, 480);
      // Subtle radial glow behind initials
      const radial = ctx.createRadialGradient(400, 200, 0, 400, 200, 180);
      radial.addColorStop(0, `rgba(${r},${g},${b},0.22)`);
      radial.addColorStop(1, 'rgba(0,0,0,0)');
      ctx.fillStyle = radial;
      ctx.fillRect(0, 0, 800, 480);
      // Circle border
      ctx.beginPath();
      ctx.arc(400, 200, 92, 0, Math.PI * 2);
      ctx.strokeStyle = `rgba(${r},${g},${b},0.55)`;
      ctx.lineWidth = 2;
      ctx.stroke();
      // Initials
      ctx.fillStyle = '#ffffff';
      ctx.font = 'bold 76px Manrope, system-ui, sans-serif';
      ctx.textAlign = 'center';
      ctx.textBaseline = 'middle';
      ctx.fillText(initials, 400, 200);
      return canvas.toDataURL('image/png');
    }

    // Apply avatar fallback to background element
    function applyAvatarFallback(name) {
      const bg = document.getElementById('bg');
      if (bg) {
        const dataUrl = makeAvatarFallback(name);
        bg.style.backgroundImage = `url('${dataUrl}')`;
        bg.style.backgroundSize = 'cover';
      }
      // Also hide any broken img tags inside the hero
      const heroImg = document.querySelector('#profile-mount img[data-hero]');
      if (heroImg) heroImg.style.display = 'none';
    }

    function renderProfile(t, packages) {
      const loading = document.getElementById('loading-state');
      const mount = document.getElementById('profile-mount');
      if (loading) loading.style.display = 'none';
      if (!mount) return;
      mount.style.display = 'block';

      // Field name mapping: get-trainer uses name/avatar_url/specialties/instagram/reps_verified
      const displayName = t.name || t.full_name || '';
      const photoUrl = t.avatar_url || t.profile_photo_url || '';

      // Set background image - premium gradient+initials fallback if image fails or missing
      const bg = document.getElementById('bg');
      if (photoUrl) {
        const testImg = new Image();
        testImg.onload = () => { if (bg) bg.style.backgroundImage = `url('${photoUrl}')`; };
        testImg.onerror = () => applyAvatarFallback(displayName);
        testImg.src = photoUrl;
      } else {
        setTimeout(() => applyAvatarFallback(displayName), 50);
      }

      // Extract dominant color from avatar for ambient bloom effect
      if (photoUrl) {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.onload = function() {
          try {
            const canvas = document.createElement('canvas');
            canvas.width = 8; canvas.height = 8; // tiny sample
            const ctx = canvas.getContext('2d');
            ctx.drawImage(img, 0, 0, 8, 8);
            const d = ctx.getImageData(0, 0, 8, 8).data;
            let r = 0, g = 0, b = 0, count = 0;
            for (let i = 0; i < d.length; i += 4) {
              // Skip very dark or very light pixels
              const brightness = (d[i] + d[i+1] + d[i+2]) / 3;
              if (brightness > 30 && brightness < 230) {
                r += d[i]; g += d[i+1]; b += d[i+2]; count++;
              }
            }
            if (count > 0) {
              r = Math.round(r/count); g = Math.round(g/count); b = Math.round(b/count);
              document.documentElement.style.setProperty('--avatar-color', `${r},${g},${b}`);
            }
          } catch(e) { /* CORS or canvas error - use default */ }
        };
        img.src = photoUrl;
      }

      const brand = (window.__BRAND__ && window.__BRAND__.name) ? window.__BRAND__.name : (window.__BRAND__ || 'TrainedBy');
      const specialties = Array.isArray(t.specialties) ? t.specialties : (t.specialties ? [t.specialties] : ['Personal Trainer']);
      const rating = t.avg_rating ? parseFloat(t.avg_rating).toFixed(1) : '5.0';
      const reviews = t.review_count || 0;
      const isPro = t.plan === 'pro' || t.plan === 'elite';
      const isVerified = t.reps_verified || t.is_verified || t.verification_status === 'verified';
      const city = t.city || '';
      const country = t.country || '';
      const location = [city, country].filter(Boolean).join(', ');
      const bio = t.bio || '';
      const instagram = t.instagram || t.instagram_handle || '';
      const whatsapp = t.whatsapp || t.phone || '';
      const certifications = Array.isArray(t.certifications) ? t.certifications : [];
      // Deduplicate packages by name (guard against duplicate DB rows)
      const _rawPkgs = Array.isArray(packages) ? packages : [];
      const _seenPkgNames = new Set();
      const pkgList = _rawPkgs.filter(p => {
        if (_seenPkgNames.has(p.name)) return false;
        _seenPkgNames.add(p.name);
        return true;
      });
      const priceFrom = pkgList[0]?.price || null;
      const priceCurrency = pkgList[0]?.currency || '';

      document.title = `${displayName} - Verified Trainer on ${brand}`;

      mount.innerHTML = `
        <div style="max-width:680px;margin:0 auto;padding:24px 16px 80px">

          <!-- Back nav -->
          <a href="/find" style="display:inline-flex;align-items:center;gap:8px;color:rgba(255,255,255,0.6);text-decoration:none;font-size:14px;margin-bottom:24px;transition:color 0.2s" onmouseover="this.style.color='#fff'" onmouseout="this.style.color='rgba(255,255,255,0.6)'">
            ← Back to results
          </a>

          <!-- Hero card -->
          <div style="background:rgba(10,10,10,0.72);backdrop-filter:blur(28px);-webkit-backdrop-filter:blur(28px);border:1px solid rgba(255,255,255,0.10);border-radius:24px;overflow:hidden;margin-bottom:16px;box-shadow:0 8px 48px rgba(0,0,0,0.5)">
            <div style="position:relative;height:240px;background:linear-gradient(135deg,#1a1a1a,#0a0a0a)">
              ${photoUrl ? `<img data-hero="1" src="${photoUrl}" alt="${displayName}" style="width:100%;height:100%;object-fit:cover;object-position:top" onerror="this.style.display='none';applyAvatarFallback('${displayName.replace(/'/g, "\\'")}')">` : ''}
              <div style="position:absolute;inset:0;background:linear-gradient(to bottom,transparent 30%,rgba(0,0,0,0.75) 100%)"></div>
              ${isVerified ? `<div style="position:absolute;top:16px;right:16px;background:rgba(34,197,94,0.18);border:1px solid rgba(34,197,94,0.35);color:#22c55e;padding:5px 12px;border-radius:20px;font-size:11px;font-weight:700;backdrop-filter:blur(12px);letter-spacing:0.03em">✓ Verified</div>` : ''}
              ${isPro ? `<div style="position:absolute;top:16px;left:16px;background:linear-gradient(135deg,rgba(197,162,39,0.25),rgba(245,208,107,0.15));border:1px solid rgba(197,162,39,0.4);color:#f5d06b;padding:5px 12px;border-radius:20px;font-size:11px;font-weight:800;backdrop-filter:blur(12px);letter-spacing:0.05em">PRO</div>` : ''}
            </div>
            <div style="padding:22px">
              <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;flex-wrap:wrap">
                <div>
                  <h1 style="font-family:var(--font-display,'Manrope',sans-serif);font-size:26px;font-weight:900;margin-bottom:4px;letter-spacing:-0.03em">${displayName}</h1>
                  <p style="color:rgba(255,255,255,0.55);font-size:14px;font-family:var(--font-body,'Inter',sans-serif)">${specialties.join(' · ')}${location ? ' · ' + location : ''}</p>
                </div>
                <div style="text-align:right">
                  <div style="font-family:var(--font-display,'Manrope',sans-serif);font-size:22px;font-weight:900;color:var(--brand,#FF5C00);letter-spacing:-0.02em">${priceFrom ? `From ${priceCurrency} ${priceFrom}` : ''}</div>
                  <div style="font-size:12px;color:rgba(255,255,255,0.4);font-family:var(--font-body,'Inter',sans-serif)">per session</div>
                </div>
              </div>

              ${reviews > 0 ? `
              <div style="display:flex;align-items:center;gap:6px;margin-top:12px">
                <span style="color:#f59e0b;font-size:16px">${'★'.repeat(Math.round(parseFloat(rating)))}${'☆'.repeat(5-Math.round(parseFloat(rating)))}</span>
                <span style="font-weight:700">${rating}</span>
                <span style="color:rgba(255,255,255,0.5);font-size:13px">(${reviews} reviews)</span>
              </div>` : ''}

              ${bio ? `<p style="margin-top:16px;color:rgba(255,255,255,0.8);line-height:1.6;font-size:15px">${bio}</p>` : ''}
            </div>
          </div>

          <!-- Certifications -->
          ${certifications.length > 0 ? `
          <div style="background:rgba(10,10,10,0.65);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:20px;margin-bottom:16px;box-shadow:0 4px 24px rgba(0,0,0,0.3)">
            <h2 style="font-family:var(--font-display,'Manrope',sans-serif);font-size:15px;font-weight:800;margin-bottom:14px;letter-spacing:-0.01em">Certifications</h2>
            <div style="display:flex;flex-wrap:wrap;gap:8px">
              ${certifications.map(c => `<span style="background:rgba(34,197,94,0.1);border:1px solid rgba(34,197,94,0.3);color:#22c55e;padding:6px 14px;border-radius:20px;font-size:13px;font-weight:600">${c}</span>`).join('')}
            </div>
          </div>` : ''}

          <!-- Packages -->
          ${pkgList.length > 0 ? `
          <div style="background:rgba(10,10,10,0.65);backdrop-filter:blur(24px);-webkit-backdrop-filter:blur(24px);border:1px solid rgba(255,255,255,0.09);border-radius:20px;padding:20px;margin-bottom:16px;box-shadow:0 4px 24px rgba(0,0,0,0.3)">
            <h2 style="font-family:var(--font-display,'Manrope',sans-serif);font-size:15px;font-weight:800;margin-bottom:14px;letter-spacing:-0.01em">Training Packages</h2>
            <div style="display:flex;flex-direction:column;gap:10px">
              ${pkgList.map(p => `
              <div style="display:flex;align-items:center;justify-content:space-between;padding:14px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);border-radius:12px">
                <div>
                  <div style="font-weight:700;font-size:15px">${p.name || p.title || 'Package'}</div>
                  ${p.description ? `<div style="color:rgba(255,255,255,0.5);font-size:13px;margin-top:2px">${p.description}</div>` : ''}
                </div>
                <div style="font-family:var(--font-display,'Manrope',sans-serif);font-size:18px;font-weight:900;color:var(--brand,#FF5C00);white-space:nowrap;letter-spacing:-0.02em">${p.price ? `${p.currency || ''} ${p.price}`.trim() : ''}</div>
              </div>`).join('')}
            </div>
          </div>` : ''}

          <!-- CTA buttons -->
          <div style="display:flex;flex-direction:column;gap:12px;margin-top:8px">
            ${whatsapp ? `
            <a href="https://wa.me/${whatsapp.replace(/\D/g,'')}?text=Hi ${encodeURIComponent(displayName)}, I found your profile on ${brand} and I'd like to book a session."
               target="_blank" rel="noopener" class="wa-cta-pulse"
               style="display:flex;align-items:center;justify-content:center;gap:10px;background:#25D366;color:#fff;padding:16px;border-radius:14px;text-decoration:none;font-weight:700;font-size:16px">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              Book via WhatsApp
            </a>` : ''}
            ${instagram ? `
            <a href="https://instagram.com/${instagram.replace('@','')}"
               target="_blank" rel="noopener"
               style="display:flex;align-items:center;justify-content:center;gap:10px;background:linear-gradient(135deg,#833ab4,#fd1d1d,#fcb045);color:#fff;padding:16px;border-radius:14px;text-decoration:none;font-weight:700;font-size:16px">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
              View on Instagram
            </a>` : ''}
            <a href="/find"
               style="display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,0.06);border:1px solid rgba(255,255,255,0.12);color:rgba(255,255,255,0.8);padding:14px;border-radius:14px;text-decoration:none;font-weight:600;font-size:15px">
              ← Browse all trainers
            </a>
            ${'share' in navigator ? `
            <button onclick="shareProfile('${displayName}')" id="share-btn"
               style="display:flex;align-items:center;justify-content:center;gap:8px;background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.08);color:rgba(255,255,255,0.5);padding:12px;border-radius:14px;font-weight:600;font-size:14px;cursor:pointer;width:100%;font-family:inherit">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
              Share this profile
            </button>` : ''}
          </div>

          <!-- Powered by footer -->
          <div style="text-align:center;margin-top:40px;padding-top:24px;border-top:1px solid rgba(255,255,255,0.08)">
            <a href="/" style="color:rgba(255,255,255,0.3);text-decoration:none;font-size:13px">
              Powered by <strong style="color:rgba(255,255,255,0.5)">${brand}</strong>
            </a>
          </div>
        </div>`;
    }

    // Web Share API
    function shareProfile(name) {
      if (navigator.share) {
        navigator.share({
          title: name + ' - Verified Personal Trainer',
          text: 'Check out ' + name + "'s verified trainer profile",
          url: location.href
        }).catch(() => {});
      } else {
        // Fallback: copy to clipboard
        navigator.clipboard.writeText(location.href).then(() => {
          const btn = document.getElementById('share-btn');
          if (btn) { btn.textContent = 'Link copied!'; setTimeout(() => { btn.textContent = 'Share this profile'; }, 2000); }
        });
      }
    }

    // Kick off on load
    loadTrainer();
  </script>
</Base>
