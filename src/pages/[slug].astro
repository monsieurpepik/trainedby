  border-top: 1px solid var(--border);
}
.tb-about-text {
  font-weight: 300;
  font-size: 13.5px;
  color: #4A4440;
  line-height: 1.68;
  overflow: hidden;
  display: -webkit-box;
  -webkit-line-clamp: 3;
  -webkit-box-orient: vertical;
}
.tb-about-text.expanded {
  display: block;
  -webkit-line-clamp: unset;
}
.tb-read-more {
  display: inline-block;
  margin-top: 8px;
  font-size: 13px;
  font-weight: 400;
  color: #9A9290;
  background: none;
  border: none;
  padding: 0;
  cursor: pointer;
  font-family: var(--font);
}

/* ── Reviews shell ──────────────────────────────────────────────── */
.tb-reviews {
  padding: 20px;
  border-top: 1px solid var(--border);
}
.tb-reviews-loading {
  color: var(--text-muted);
  font-size: 13px;
  text-align: center;
  padding: 20px 0;
}
</style>

