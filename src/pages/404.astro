---
import Base from "../layouts/Base.astro";
import { getMarket } from "../lib/market.ts";
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName ?? 'TrainedBy';
---
<Base title={`Page Not Found - ${brandName}`} description={`The page you're looking for doesn't exist on ${brandName}.`}>
  <style>
    :root{
      --brand-light:#ff8c42;
      --text-dim:rgba(240,240,240,0.55);
      --text-subtle:rgba(240,240,240,0.45);
      --text-secondary:rgba(240,240,240,0.7);
      --surface-overlay:rgba(255,255,255,0.04);
      --ghost-bg:rgba(255,255,255,0.06);
      --ghost-border:rgba(255,255,255,0.12);
      --ghost-text:rgba(240,240,240,0.8);
      --ghost-hover:rgba(255,255,255,0.1);
    }
    *,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
    body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);-webkit-font-smoothing:antialiased}
    .container{
      display:flex;flex-direction:column;align-items:center;justify-content:center;
      min-height:100vh;padding:32px;text-align:center;gap:24px;
    }
    .code{font-size:96px;font-weight:900;line-height:1;background:linear-gradient(135deg,var(--brand),var(--brand-light));-webkit-background-clip:text;-webkit-text-fill-color:transparent}
    h1{font-size:28px;font-weight:800}
    p{color:var(--text-dim);max-width:420px;line-height:1.6;font-size:16px}
    .hint{
      margin-top:8px;padding:16px 24px;
      background:var(--surface-overlay);border:1px solid var(--border);
      border-radius:12px;max-width:420px;font-size:14px;color:var(--text-subtle);
      line-height:1.6;
    }
    .hint strong{color:var(--text-secondary)}
    .actions{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-top:8px}
    .btn-primary{
      background:var(--brand);color:var(--text);padding:14px 28px;border-radius:12px;
      text-decoration:none;font-weight:700;font-size:15px;transition:opacity 0.2s;
    }
    .btn-primary:hover{opacity:0.85}
    .btn-ghost{
      background:var(--ghost-bg);border:1px solid var(--ghost-border);
      color:var(--ghost-text);padding:14px 28px;border-radius:12px;
      text-decoration:none;font-weight:600;font-size:15px;transition:background 0.2s;
    }
    .btn-ghost:hover{background:var(--ghost-hover)}
  </style>

  <div class="container">
    <div class="code">404</div>
    <h1>Page not found</h1>
    <p>The page you're looking for doesn't exist, or the trainer profile may have been removed.</p>
    <div class="actions">
      <a href="/find" class="btn-primary">Find a Trainer</a>
      <a href="/" class="btn-ghost">Go Home</a>
    </div>
    <div class="hint">
      <strong>Looking for a specific trainer?</strong> Try searching by name or specialty on the Find page. If you followed a link that should work, the trainer may have updated their profile URL.
    </div>
  </div>
</Base>
