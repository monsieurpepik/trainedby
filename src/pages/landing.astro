  <script>
    // Nav scroll effect
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Hero search
    window.doSearch = function() {
      const q = (document.getElementById('hero-search') as HTMLInputElement).value.trim();
      if (q) window.location.href = '/find?q=' + encodeURIComponent(q);
      else window.location.href = '/find';
    };
    document.getElementById('hero-search')?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') window.doSearch();
    });

    // Load featured trainers from Supabase
    (async function() {
      const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
      const ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      try {
        const res = await fetch(
          `${SUPABASE_URL}/rest/v1/trainers?select=slug,full_name,specialty,location,profile_photo_url,reps_verified,packages&plan=eq.pro&is_active=eq.true&order=created_at.desc&limit=8`,
          { headers: { 'apikey': ANON_KEY, 'Authorization': 'Bearer ' + ANON_KEY } }
        );
        const trainers = await res.json();
        if (!Array.isArray(trainers) || trainers.length === 0) return;

        const grid = document.getElementById('featured-trainers');
        if (!grid) return;
        grid.innerHTML = '';

        trainers.forEach((t: any) => {
          const initials = (t.full_name || 'T').split(' ').map((n: string) => n[0]).join('').slice(0,2).toUpperCase();
          const specialty = Array.isArray(t.specialty) ? t.specialty[0] : (t.specialty || 'Personal Training');
          const location = t.location || '';
          const packages = Array.isArray(t.packages) ? t.packages : [];
          const lowestPrice = packages.length > 0
            ? Math.min(...packages.map((p: any) => p.price || 0).filter((p: number) => p > 0))
            : null;

          const card = document.createElement('a');
          card.href = '/' + t.slug;
          card.className = 'trainer-card';
          card.innerHTML = `
            <div class="trainer-card-img">
              ${t.profile_photo_url
                ? `<img src="${t.profile_photo_url}" alt="${t.full_name}" style="width:100%;height:100%;object-fit:cover">`
                : `<span>${initials}</span>`}
              ${t.reps_verified ? '<span class="verified-badge">✓ Verified</span>' : ''}
            </div>
            <div class="trainer-card-body">
              <div class="trainer-card-name">${t.full_name || 'Trainer'}</div>
              <div class="trainer-card-meta">${specialty}${location ? ' · ' + location : ''}</div>
              <div class="trainer-card-price">${lowestPrice ? 'From ' + lowestPrice : 'Contact for pricing'} <span>/ session</span></div>
            </div>
          `;
          grid.appendChild(card);
        });
      } catch(e) {
        // Silently fail — skeleton loaders remain
      }
    })();
  </script>
