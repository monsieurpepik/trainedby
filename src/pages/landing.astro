---
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';
const market = getMarket(Astro.url.hostname);
const brandName = market.brandName || 'TrainedBy';

// Market-aware hero card static fallback (replaced by JS after trainer data loads)
const heroFallback: Record<string, { name: string; meta: string; price: string; slug: string }> = {
  ae: { name: 'Sarah Al-Mansoori', meta: 'Strength & HIIT · Dubai Marina',   price: `${market.currencySymbol} 350`, slug: 'sarah-al-mansoori' },
  uk: { name: 'Emily Johnson',     meta: 'Weight Loss · London',              price: `${market.currencySymbol} 85`,  slug: 'emily-johnson-uk' },
  com:{ name: 'Michael Chen',      meta: 'Strength & Conditioning · NYC',     price: `${market.currencySymbol} 90`,  slug: 'michael-chen-nyc' },
  fr: { name: 'Sophie Martin',     meta: 'Yoga & Bien-être · Paris',          price: `${market.currencySymbol} 70`,  slug: 'sophie-martin-fr' },
  it: { name: 'Luca Ferrari',      meta: 'Forza e Condizionamento · Milano',  price: `${market.currencySymbol} 65`,  slug: 'luca-ferrari-it' },
  es: { name: 'Pablo García',      meta: 'Rendimiento Atlético · Barcelona',  price: `${market.currencySymbol} 60`,  slug: 'pablo-garcia' },
  mx: { name: 'Carlos Mendoza',    meta: 'Fuerza Funcional · CDMX',           price: `${market.currencySymbol} 900`, slug: 'carlos-mendoza-mx' },
  in: { name: 'Priya Singh',       meta: 'Yoga & Wellness · Mumbai',          price: `${market.currencySymbol} 3500`,slug: 'priya-singh-in' },
};
const hero = heroFallback[market.market] ?? heroFallback['ae'];

// Trust strip copy per locale
const trustCertSuffix: Record<string, string> = { fr: 'certifiés uniquement', it: 'certificati', es: 'certificados' };
const trustChecked: Record<string, string>    = { fr: 'Antécédents vérifiés', it: 'Precedenti verificati', es: 'Antecedentes verificados' };
const trustBrowse: Record<string, string>     = { fr: 'Gratuit à parcourir', it: 'Gratuito da sfogliare', es: 'Gratis explorar' };
const m = market.market;
const trustSuffix  = trustCertSuffix[m]  ?? 'Certified only';
const trustCheck   = trustChecked[m]     ?? 'Background checked';
const trustFree    = trustBrowse[m]      ?? 'Free to browse';

// Urgency chip: next active club with open spots
let nextClub: { starts_at: string; spots_left: number } | null = null;
try {
  const SUPA_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? 'https://mezhtdbfyvkshpuplqqw.supabase.co';
  const SUPA_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
  const res = await fetch(
    `${SUPA_URL}/rest/v1/clubs?select=starts_at,max_members,club_members(id)&status=eq.active&starts_at=gte.${new Date().toISOString()}&order=starts_at.asc&limit=1`,
    { headers: { apikey: SUPA_KEY, Authorization: `Bearer ${SUPA_KEY}` } }
  );
  const rows = await res.json();
  if (Array.isArray(rows) && rows.length > 0) {
    const row = rows[0];
    const joined = Array.isArray(row.club_members) ? row.club_members.length : 0;
    const maxMembers = row.max_members ?? 50;
    const spotsLeft = maxMembers - joined;
    if (spotsLeft > 0) {
      nextClub = {
        starts_at: new Date(row.starts_at).toLocaleDateString('en-GB', { day: 'numeric', month: 'long' }),
        spots_left: spotsLeft,
      };
    }
  }
} catch (_) {}
---

<Base
  title={`Accountability Clubs Led by Real Coaches — ${brandName}`}
  description={`Join a 30-day coach-led transformation club. One daily mission. A community that sees your streak. The accountability layer your routine was missing.`}
>
  <Fragment slot="head">
  </Fragment>

  <style>

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:        #EDECEA;
      --surface:   #F7F5F3;
      --surface-2: #E8E5E2;
      --surface-3: #D5D1CE;
      --text:      #1A1411;
      --text-2:    #6B6460;
      --border:    rgba(0,0,0,0.07);
      --brand:     #FF5C00;
      --green:     #00C853;
      --danger:    #E53935;
      --reps:      #00C853;
      --reps-dim:  rgba(0,200,83,0.1);
      --danger-dim: rgba(229,57,53,0.1);
      --text-muted: #6B6460;
      --text-faint: rgba(26,20,17,0.4);
      --max: 1100px;
    }
    body {
      background: #EDECEA !important;
      color: #1A1411 !important;
      font-family: 'Manrope', system-ui, sans-serif;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* NAV */
    .nav {
      background: var(--bg);
      border-bottom: 1px solid rgba(0,0,0,0.06);
      height: 60px;
      display: flex;
      align-items: center;
      padding: 0 40px;
      gap: 32px;
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      z-index: 100;
    }
    .nav-logo {
      font-weight: 800;
      font-size: 17px;
      color: var(--text);
      letter-spacing: -0.03em;
      margin-right: auto;
      text-decoration: none;
    }
    .nav-link {
      font-size: 13px;
      color: var(--text-2);
      font-weight: 500;
      text-decoration: none;
    }
    .nav-link.trainer { color: var(--brand); font-weight: 700; } /* orange — trainer-facing */
    .nav-cta {
      background: var(--text);
      color: #fff;
      padding: 8px 18px;
      border-radius: 100px;
      font-size: 12px;
      font-weight: 700;
      text-decoration: none;
    }
    @media (max-width: 640px) {
      .nav { padding: 0 20px; }
      .nav-link:not(.trainer) { display: none; }
    }

    /* Hero — mobile first */
    .hero {
      padding: 48px 24px;
      background: var(--bg);
      margin-top: 60px;
    }
    .hero-eyebrow {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 5px 12px;
      border-radius: 100px;
      background: var(--surface);
      font-size: 11px;
      font-weight: 700;
      color: var(--text-2);
      margin-bottom: 20px;
    }
    .hero-eyebrow-dot {
      width: 6px; height: 6px; border-radius: 50%; background: var(--green);
    }
    .hero-h1 {
      font-size: 36px;
      font-weight: 800;
      letter-spacing: -0.04em;
      line-height: 1.05;
      color: var(--text);
      margin-bottom: 16px;
      font-family: 'Manrope', system-ui, sans-serif;
    }
    .hero-h1 em {
      font-style: italic;
      font-family: Georgia, 'Times New Roman', serif;
      font-weight: 400;
    }
    .hero-sub {
      font-size: 15px;
      color: var(--text-2);
      line-height: 1.65;
      margin-bottom: 28px;
      max-width: 420px;
    }
    .hero-actions {
      display: flex;
      gap: 10px;
      align-items: center;
      flex-wrap: wrap;
      margin-bottom: 28px;
    }
    .btn-dark {
      background: var(--text);
      color: #fff;
      padding: 12px 22px;
      border-radius: 100px;
      font-size: 13px;
      font-weight: 700;
      text-decoration: none;
      display: inline-block;
    }
    .hero-right { display: none; } /* hidden on mobile */

    /* Stats grid */
    .stats-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
    }
    .stat-card {
      background: var(--surface);
      border-radius: 16px;
      padding: 20px;
    }
    .stat-card.featured { background: var(--text); }
    .stat-val {
      font-size: 30px;
      font-weight: 800;
      color: var(--text);
      letter-spacing: -0.05em;
      line-height: 1;
      margin-bottom: 4px;
    }
    .stat-card.featured .stat-val { color: #fff; }
    .stat-label { font-size: 12px; color: var(--text-2); font-weight: 500; }
    .stat-card.featured .stat-label { color: rgba(255,255,255,0.55); }

    /* Desktop hero split — 2 columns */
    @media (min-width: 768px) {
      .hero {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 48px;
        align-items: center;
        padding: 72px 40px 64px;
        max-width: 1000px;
        margin: 60px auto 0;
      }
      .hero-right { display: block; }
      .hero-h1 { font-size: 48px; }
    }

    /* SEARCH BAR */
    .search-wrap { width: 100%; max-width: 640px; position: relative; margin-bottom: 24px; }
    .search-bar { width: 100%; padding: 18px 140px 18px 56px; border-radius: 100px; border: 1px solid var(--border); background: var(--surface); color: var(--text); font-size: 15px; font-family: inherit; outline: none; transition: border-color 0.2s, box-shadow 0.2s; }
    .search-bar:focus { border-color: rgba(0,0,0,0.15); box-shadow: 0 0 0 3px rgba(0,0,0,0.04); }
    .search-bar::placeholder { color: var(--text-2); }
    .search-icon { position: absolute; left: 20px; top: 50%; transform: translateY(-50%); color: var(--text-2); pointer-events: none; }
    .search-btn { position: absolute; right: 8px; top: 50%; transform: translateY(-50%); padding: 10px 22px; border-radius: 100px; background: var(--text); color: #fff; font-size: 13px; font-weight: 700; border: none; cursor: pointer; transition: background 0.2s; white-space: nowrap; }
    .search-btn:hover { background: #333; }

    /* QUICK FILTERS */
    .quick-filters { display: flex; gap: 8px; flex-wrap: wrap; justify-content: center; margin-bottom: 56px; }
    .qf-pill { padding: 8px 16px; border-radius: 100px; border: 1px solid var(--border); background: var(--surface); color: var(--text-2); font-size: 13px; font-weight: 600; cursor: pointer; text-decoration: none; transition: all 0.15s; }
    .qf-pill:hover { border-color: rgba(0,0,0,0.15); color: var(--text); background: var(--surface-2); }

    /* TRUST STRIP */
    .trust-strip { display: flex; align-items: center; gap: 24px; flex-wrap: wrap; justify-content: center; }
    .trust-item { display: flex; align-items: center; gap: 7px; font-size: 12px; color: var(--text-2); font-weight: 600; }
    .trust-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--reps); flex-shrink: 0; }

    /* SECTION STRUCTURE */
    .section { padding: 80px 24px; max-width: var(--max); margin: 0 auto; }
    .section-eyebrow { font-size: 11px; font-weight: 600; color: var(--text-2); letter-spacing: 0; margin-bottom: 14px; }
    .section-title { font-family: 'Manrope', system-ui, sans-serif; font-size: clamp(26px, 4vw, 44px); font-weight: 900; letter-spacing: -1.5px; line-height: 1.1; margin-bottom: 16px; }
    .section-sub { font-size: 15px; color: var(--text-2); line-height: 1.7; max-width: 480px; }

    /* FEATURED TRAINERS */
    .trainer-strip {
      background: #FAFAF9;
      border-top: 1px solid rgba(0,0,0,0.06);
      padding: 40px;
    }
    .trainers-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; margin-top: 40px; }
    /* EDITORIAL TRAINER CARD */
    .ecard {
  border-radius: 16px;
  overflow: hidden;
  position: relative;
  cursor: pointer;
  display: block;
  text-decoration: none;
  color: inherit;
}
.ecard-bg {
  position: absolute; inset: 0;
  background-size: cover; background-position: center top;
  transition: transform 0.4s ease;
  background-color: #2c1810;
}
.ecard:hover .ecard-bg { transform: scale(1.04); }
.ecard-overlay {
  position: absolute; inset: 0;
  background: linear-gradient(to bottom, transparent 30%, rgba(0,0,0,0.15) 55%, rgba(0,0,0,0.72) 100%);
}
.ecard-top {
  position: absolute; top: 14px; left: 14px; right: 14px;
  display: flex; justify-content: space-between; align-items: flex-start;
  z-index: 2;
}
.ecard-badge {
  display: inline-flex; align-items: center; gap: 5px;
  background: rgba(255,255,255,0.16);
  backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);
  border: 1px solid rgba(255,255,255,0.22);
  border-radius: 100px; padding: 5px 10px;
  font-size: 10px; font-weight: 600; color: #fff;
}
.ecard-badge-dot { width: 5px; height: 5px; border-radius: 50%; background: #00C853; flex-shrink: 0; }
.ecard-bottom {
  position: absolute; bottom: 0; left: 0; right: 0;
  padding: 18px 18px 20px;
  z-index: 2;
}
.ecard-name {
  font-weight: 700; font-size: 17px; color: #fff;
  letter-spacing: -0.03em; line-height: 1.2; margin-bottom: 4px;
}
.ecard-meta { font-size: 12px; color: rgba(255,255,255,0.65); margin-bottom: 14px; }
.ecard-row { display: flex; align-items: center; justify-content: space-between; gap: 12px; }
.ecard-price { font-size: 13px; font-weight: 600; color: rgba(255,255,255,0.9); letter-spacing: -0.02em; }
.ecard-price span { font-size: 11px; font-weight: 400; color: rgba(255,255,255,0.5); }
.ecard-cta {
  background: #fff; color: #111; border: none; border-radius: 100px;
  padding: 9px 18px; font-family: 'Manrope', system-ui;
  font-size: 12px; font-weight: 700; letter-spacing: -0.01em;
  cursor: pointer; flex-shrink: 0; white-space: nowrap;
  text-decoration: none; display: inline-block;
}
.ecard-hero { aspect-ratio: 3/4; }
.ecard-grid { aspect-ratio: 2/3; }
.ecard-fallback-a { background: linear-gradient(160deg, #2c1810 0%, #7a3010 30%, #c55a1e 60%, #e8824a 85%, #f5a875 100%); }
.ecard-fallback-b { background: linear-gradient(160deg, #0f0c08 0%, #3d2010 35%, #8a4a1e 65%, #cc7040 100%); }
.ecard-fallback-c { background: linear-gradient(160deg, #0a0e12 0%, #1a2a3a 35%, #2e4a6a 65%, #4a7090 100%); }
/* Slide indicator dots */
.card-dots { display: flex; gap: 5px; justify-content: center; margin-top: 14px; }
.card-dot { height: 3px; border-radius: 100px; }
.card-dot-on { width: 22px; background: var(--text); }
.card-dot-off { width: 6px; background: var(--surface-3); }
    .t-card {
      background: var(--bg);
      border: 1px solid var(--border);
      border-radius: 16px;
      padding: 14px;
      min-width: 160px;
    }
    .t-avatar {
      width: 44px; height: 44px; border-radius: 50%;
      background: var(--surface);
      display: flex; align-items: center; justify-content: center;
      font-size: 16px; font-weight: 800; color: var(--text);
      margin-bottom: 8px;
    }
    .t-name { font-weight: 700; font-size: 13px; color: var(--text); margin-bottom: 2px; }
    .t-spec { font-size: 11px; color: var(--text-2); margin-bottom: 6px; }
    .t-rating { font-size: 11px; color: var(--text); font-weight: 600; }

    /* TRANSFORMATIONS */
    .transforms-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 16px; margin-top: 40px; }
    .transform-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; }
    .transform-header { padding: 20px 20px 0; }
    .transform-trainer { display: flex; align-items: center; gap: 10px; margin-bottom: 14px; }
    .transform-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--surface-2); display: flex; align-items: center; justify-content: center; font-family: 'Manrope', system-ui, sans-serif; font-weight: 900; font-size: 14px; color: var(--text); flex-shrink: 0; }
    .transform-trainer-name { font-weight: 700; font-size: 13px; }
    .transform-trainer-cert { font-size: 11px; color: var(--green); font-weight: 600; }
    .transform-title { font-family: 'Manrope', system-ui, sans-serif; font-weight: 800; font-size: 17px; letter-spacing: -0.3px; margin-bottom: 10px; }
    .transform-body { font-size: 13px; color: var(--text-2); line-height: 1.65; margin-bottom: 16px; }
    .transform-stats { display: flex; gap: 0; border-top: 1px solid var(--border); }
    .transform-stat { flex: 1; padding: 14px 16px; text-align: center; border-right: 1px solid var(--border); }
    .transform-stat:last-child { border-right: none; }
    .transform-stat-val { font-family: 'Manrope', system-ui, sans-serif; font-weight: 900; font-size: 18px; color: var(--text); letter-spacing: -0.5px; }
    .transform-stat-label { font-size: 10px; color: var(--text-2); margin-top: 2px; font-weight: 600; }

    /* BLOG PREVIEW */
    .blog-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 40px; }
    .blog-grid .featured { grid-column: 1 / -1; }
    .blog-card { background: var(--surface); border: 1px solid var(--border); border-radius: 16px; padding: 28px; text-decoration: none; color: inherit; display: block; transition: border-color 0.2s, transform 0.2s; }
    .blog-card:hover { border-color: rgba(0,0,0,0.14); }
    .blog-card.featured { display: block; }
    .blog-card.featured .blog-title { font-size: 26px; }
    .blog-cat { display: inline-block; padding: 4px 12px; border-radius: 100px; background: var(--surface-2); border: 1px solid var(--border); color: var(--text); font-size: 11px; font-weight: 700; letter-spacing: 0.3px; margin-bottom: 14px; }
    .blog-title { font-family: 'Manrope', system-ui, sans-serif; font-weight: 800; font-size: 20px; letter-spacing: -0.5px; line-height: 1.25; margin-bottom: 10px; }
    .blog-card:not(.featured) .blog-title { font-size: 16px; }
    .blog-excerpt { font-size: 14px; color: var(--text-2); line-height: 1.65; margin-bottom: 16px; }
    .blog-author { display: flex; align-items: center; gap: 8px; font-size: 12px; color: var(--text-2); }
    .blog-author-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--green); }
    @media (max-width: 720px) { .blog-grid { grid-template-columns: 1fr; } }

    /* FOR TRAINERS BANNER */
    .trainer-banner { margin: 0 24px; border-radius: 20px; background: #1A1411; border: none; padding: 56px 48px; display: flex; align-items: center; justify-content: space-between; gap: 32px; flex-wrap: wrap; }
    .trainer-banner-eyebrow { font-size: 11px; font-weight: 600; color: var(--brand); letter-spacing: 0; margin-bottom: 12px; }
    .trainer-banner-title { font-family: 'Manrope', system-ui, sans-serif; font-size: clamp(22px, 3vw, 36px); font-weight: 900; letter-spacing: -1px; line-height: 1.15; margin-bottom: 12px; color: #ffffff; }
    .trainer-banner-sub { font-size: 15px; color: rgba(255,255,255,0.6); line-height: 1.6; max-width: 420px; }
    .trainer-banner-actions { display: flex; gap: 12px; flex-wrap: wrap; flex-shrink: 0; }
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 14px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; border: none; cursor: pointer; white-space: nowrap; }
    .btn-primary:hover { background: #e05200; }
    .btn-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: transparent; color: rgba(255,255,255,0.75); font-size: 14px; font-weight: 600; text-decoration: none; border: 1px solid rgba(255,255,255,0.2); transition: border-color 0.2s, transform 0.2s; white-space: nowrap; }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.45); }

    /* FOOTER */
    footer { border-top: 1px solid var(--border); padding: 48px 32px; display: flex; align-items: center; justify-content: space-between; flex-wrap: wrap; gap: 20px; max-width: var(--max); margin: 0 auto; }
    .footer-logo { font-family: 'Manrope', system-ui, sans-serif; font-weight: 900; font-size: 18px; color: var(--text); text-decoration: none; }
    .footer-links { display: flex; gap: 24px; flex-wrap: wrap; }
    .footer-links a { color: var(--text-2); text-decoration: none; font-size: 13px; transition: color 0.2s; }
    .footer-links a:hover { color: var(--text); }
    .footer-copy { font-size: 12px; color: rgba(26,20,17,0.4); }

    /* SKELETON LOADER */
    .skeleton { background: linear-gradient(90deg, var(--surface-2) 25%, var(--surface) 50%, var(--surface-2) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
    @keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
  </style>

  <!-- NAV -->
  <nav class="nav" id="nav">
    <a href="/landing" class="nav-logo" data-i18n="brand">{brandName}</a>
    <a href="/find" class="nav-link">Find a Club</a>
    <a href="/blog" class="nav-link">Stories</a>
    <a href="/for-trainers" class="nav-link trainer">For Coaches →</a>
    <a href="/find" class="nav-cta">Find Your Club →</a>
  </nav>

  <!-- HERO -->
  <section class="hero" style="text-align:center;align-items:center;">
    <div class="hero-left" style="text-align:center;">
      <div class="hero-eyebrow" style="justify-content:center;">
        <span style="font-size:12px;color:var(--text-2);line-height:1.7;">
          You've started over enough times.<br>
          <span style="color:var(--brand);font-weight:700;">What you're missing isn't the plan.</span>
        </span>
      </div>
      <h1 class="hero-h1" style="font-style:normal;">
        <em style="color:#7c3aed;font-style:normal;font-family:'Manrope',system-ui,sans-serif;font-weight:900;">30 days.</em><br>
        One coach.<br>
        A community that<br>sees your streak.
      </h1>
      <p class="hero-sub" style="margin-left:auto;margin-right:auto;">
        Join a coach-led accountability club. One daily mission. Your streak is public. The group notices when you miss — and celebrates when you don't.
      </p>

      {nextClub && (
        <div style="display:inline-block;background:rgba(255,92,0,0.08);border:1px solid rgba(255,92,0,0.2);border-radius:10px;padding:10px 18px;margin-bottom:20px;">
          <div style="font-size:12px;color:var(--brand);font-weight:600;">🔥 Next cohort: {nextClub.starts_at} — {nextClub.spots_left} spots remaining</div>
        </div>
      )}

      <div class="hero-actions" style="justify-content:center;">
        <a href="/find" class="btn-dark">Find your club →</a>
        <a href="#how-it-works" style="font-size:13px;color:var(--text-2);font-weight:600;text-decoration:none;" onclick="document.getElementById('how-it-works').scrollIntoView({behavior:'smooth'});return false;">How it works</a>
      </div>

      <!-- Social proof strip -->
      <div style="margin-top:20px;font-size:12px;color:var(--text-muted);" id="social-proof-strip">
        Members checking in today across active clubs
      </div>
    </div>
  </section>

  <!-- FEATURED TRAINERS -->
  <div class="trainer-strip">
    <div class="section" style="padding-top:0;padding-bottom:0;">
      <p class="section-eyebrow">Verified Trainers</p>
      <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:8px">
        <h2 class="section-title" style="margin-bottom:0">Top trainers<br>near you.</h2>
        <a href="/find" style="font-size:14px;font-weight:700;color:var(--text);text-decoration:none">See all trainers →</a>
      </div>
      <p class="section-sub">Hand-picked, {market.certificationBody}-verified trainers with proven track records.</p>
      <div class="trainers-grid" id="featured-trainers">
        <div id="trainers-empty-state" style="grid-column:1/-1;text-align:center;padding:48px 0;display:none">
          <p style="font-size:15px;color:var(--text-2);margin-bottom:16px">No trainers listed yet.</p>
          <a href="/for-trainers" style="display:inline-flex;align-items:center;gap:8px;padding:12px 24px;background:var(--text);color:#fff;border-radius:100px;font-size:13px;font-weight:700;text-decoration:none">
            Be the first verified trainer →
          </a>
        </div>
      </div>
    </div>
  </div>

  <!-- PULL QUOTE -->
  <div style="border-top:1px solid var(--border);background:var(--surface);">
    <div class="section" style="padding:64px 24px;text-align:center;">
      <blockquote style="max-width:680px;margin:0 auto;">
        <p style="font-size:clamp(20px,3vw,28px);font-weight:700;letter-spacing:-0.03em;line-height:1.35;color:var(--text);margin-bottom:24px;">"The difference between a random trainer and a verified one isn't just a badge. It's accountability. It's the knowledge that someone checked."</p>
        <footer style="font-size:13px;color:var(--text-2);font-weight:600;">{market.certificationBody} — {market.market === 'fr' ? 'Organisme officiel de certification des coachs sportifs' : market.market === 'it' ? 'Ente ufficiale di certificazione dei personal trainer' : market.market === 'es' || market.market === 'mx' ? 'Organismo oficial de certificación de entrenadores' : 'The official certification body for personal trainers'}</footer>
      </blockquote>
    </div>
  </div>

  <!-- BLOG PREVIEW — EN markets only -->
  {(market.market === 'ae' || market.market === 'uk' || market.market === 'com' || market.market === 'in') && (
  <div style="border-top:1px solid var(--border);">
    <div class="section">
      <p class="section-eyebrow">From the community</p>
      <div style="display:flex;align-items:flex-end;justify-content:space-between;flex-wrap:wrap;gap:12px;margin-bottom:8px">
        <h2 class="section-title" style="margin-bottom:0">Written by trainers<br>who actually train.</h2>
        <a href="/blog" style="font-size:14px;font-weight:700;color:var(--text);text-decoration:none">Read all →</a>
      </div>
      <p class="section-sub">No sponsored content. No generic listicles. Written by {market.certificationBody}-verified trainers from their own practice.</p>
      <div class="blog-grid" id="blog-preview">
        <a href="/blog" class="blog-card featured">
          <div>
            <span class="blog-cat">Training Science</span>
            <div class="blog-title">Why most people plateau after 3 months — and what actually breaks it</div>
            <p class="blog-excerpt">The first three months of training are almost always productive. Then something stops working. Here's the physiology behind the plateau and the four interventions that consistently restart progress.</p>
            <div class="blog-author">
              <div class="blog-author-dot"></div>
              <span>By a {market.certificationBody} Level 4 Trainer · 6 min read</span>
            </div>
          </div>
        </a>
        <a href="/blog" class="blog-card">
          <span class="blog-cat">Nutrition</span>
          <div class="blog-title">The only meal timing advice that actually matters</div>
          <p class="blog-excerpt">Forget the 6-meal-a-day myth. Here's what the research says about when to eat — and why most of it is irrelevant if you're not getting the basics right first.</p>
          <div class="blog-author">
            <div class="blog-author-dot"></div>
            <span>Nutrition Coach · 4 min read</span>
          </div>
        </a>
        <a href="/blog" class="blog-card">
          <span class="blog-cat">Mindset</span>
          <div class="blog-title">What I tell every new client in the first session</div>
          <p class="blog-excerpt">After hundreds of first sessions, I've learned that the conversation that happens before the first rep is the one that determines everything. Here's what I say — and why.</p>
          <div class="blog-author">
            <div class="blog-author-dot"></div>
            <span>Strength Coach · 5 min read</span>
          </div>
        </a>
      </div>
    </div>
  </div>
  )}

  <!-- FOR TRAINERS BANNER -->
  <div style="padding:60px 0;border-top:1px solid var(--border);">
    <div class="trainer-banner" style="max-width:calc(var(--max) - 48px);margin:0 auto">
      <div class="trainer-banner-text">
        <div class="trainer-banner-eyebrow">For Trainers</div>
        <div class="trainer-banner-title">Build your practice<br>on a platform that<br>works as hard as you do.</div>
        <p class="trainer-banner-sub">Verified profile, digital products, lead management, and an AI assistant — all in one place. Free to start.</p>
      </div>
      <div class="trainer-banner-actions">
        <a href="/for-trainers" class="btn-primary">See how it works →</a>
        <a href="/join" class="btn-ghost">Create your profile</a>
      </div>
    </div>
  </div>

  <!-- FOOTER -->
  <footer>
    <a href="/landing" class="footer-logo">{brandName}</a>
    <div class="footer-links">
      <a href="/find">Find a Trainer</a>
      <a href="/blog">Stories</a>
<a href="/for-trainers">For Trainers</a>
      <a href="/join">Join as Trainer</a>
      <a href="/privacy">Privacy</a>
      <a href="/terms">Terms</a>
      <a href="/cookie-policy">Cookies</a>
    </div>
    <div class="footer-copy">© {new Date().getFullYear()} {brandName}</div>
  </footer>

  <script>
    // Nav scroll effect
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => {
      nav?.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Hero search
    window.doSearch = function() {
      const q = (document.getElementById('hero-search') as HTMLInputElement).value.trim();
      if (q) window.location.href = '/find?q=' + encodeURIComponent(q);
      else window.location.href = '/find';
    };
    document.getElementById('hero-search')?.addEventListener('keydown', (e: KeyboardEvent) => {
      if (e.key === 'Enter') window.doSearch();
    });

    // Load featured trainers from Supabase
    (async function() {
      const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
      const ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY;

      try {
        const marketCode = document.documentElement.dataset.market || 'ae';
        const res = await fetch(
          `${SUPABASE_URL}/rest/v1/trainers?select=slug,name,specialties,city,avatar_url,reps_verified,session_packages(name,price)&plan=eq.pro&accepting_clients=eq.true&market=eq.${marketCode}&order=created_at.desc&limit=8`,
          { headers: { 'apikey': ANON_KEY, 'Authorization': 'Bearer ' + ANON_KEY } }
        );
        const data = await res.json();
        if (!Array.isArray(data) || data.length === 0) {
          const empty = document.getElementById('trainers-empty-state');
          if (empty) empty.style.display = 'block';
          return;
        }

        const countEl = document.getElementById('stat-trainer-count');
        if (countEl && data && data.length) {
          countEl.textContent = data.length >= 10 ? data.length + '+' : String(data.length);
        }

        const grid = document.getElementById('featured-trainers');
        if (!grid) return;
        grid.innerHTML = '';

        data.forEach((t: any) => {
          const specialty = Array.isArray(t.specialties) ? t.specialties[0] : (t.specialties || 'Personal Training');
          const location = t.city || '';
          const packages = Array.isArray(t.session_packages) ? t.session_packages : [];
          const lowestPrice = packages.length > 0
            ? Math.min(...packages.map((p: any) => p.price || 0).filter((p: number) => p > 0))
            : null;
          const fallbacks = ['ecard-fallback-a', 'ecard-fallback-b', 'ecard-fallback-c'];
          const fallback = fallbacks[grid.children.length % 3];
          const bgStyle = t.avatar_url ? `background-image:url(${t.avatar_url})` : '';
          const bgClass = t.avatar_url ? 'ecard-bg' : `ecard-bg ${fallback}`;

          const card = document.createElement('a');
          card.className = 'ecard ecard-grid';
          card.href = '/' + t.slug;
          card.innerHTML = `
  <div class="${bgClass}" style="${bgStyle}"></div>
  <div class="ecard-overlay"></div>
  <div class="ecard-top">
    ${t.reps_verified ? '<div class="ecard-badge"><div class="ecard-badge-dot"></div>Verified</div>' : ''}
  </div>
  <div class="ecard-bottom">
    <div class="ecard-name" style="font-size:15px">${t.name || 'Trainer'}</div>
    <div class="ecard-meta">${specialty}${location ? ' · ' + location : ''}</div>
    <div class="ecard-price" style="font-size:12px">
      ${lowestPrice ? lowestPrice + ' <span>/ session</span>' : 'Contact for pricing'}
    </div>
  </div>
`;
          grid.appendChild(card);
        });
        if (typeof (window as any)._heroRotate === 'function') (window as any)._heroRotate(data);
      } catch(e) {
        // Silently fail — empty state handled in Task 5
      }
    })();

    // Rotate hero card through loaded trainers
    window._heroRotate = function(trainers: any[]) {
      if (!trainers || trainers.length === 0) return;
      let idx = 0;
      const fallbacks = ['ecard-fallback-a','ecard-fallback-b','ecard-fallback-c'];
      function show(t: any) {
        const bg = document.getElementById('hero-card-bg');
        const name = document.getElementById('hero-card-name');
        const meta = document.getElementById('hero-card-meta');
        const price = document.getElementById('hero-card-price');
        const link = document.getElementById('hero-trainer-card');
        if (!bg || !name || !meta || !price || !link) return;
        if (t.avatar_url) {
          (bg as HTMLElement).style.backgroundImage = `url(${t.avatar_url})`;
          bg.className = 'ecard-bg';
        } else {
          bg.className = 'ecard-bg ' + fallbacks[idx % 3];
          (bg as HTMLElement).style.backgroundImage = '';
        }
        name.textContent = t.name || '';
        const specialty = Array.isArray(t.specialties) ? t.specialties[0] : (t.specialties || 'Personal Training');
        meta.textContent = specialty + (t.city ? ' · ' + t.city : '');
        const packages = Array.isArray(t.session_packages) ? t.session_packages : [];
        const lowest = packages.length > 0 ? Math.min(...packages.map((p: any) => p.price || 0).filter(Boolean)) : null;
        price.innerHTML = lowest ? `${lowest} <span>/ session</span>` : 'Contact for pricing';
        if (link instanceof HTMLAnchorElement) link.href = '/' + t.slug;
      }
      show(trainers[0]);
      if (trainers.length > 1) {
        setInterval(() => {
          idx = (idx + 1) % trainers.length;
          show(trainers[idx]);
          document.querySelectorAll('.card-dot').forEach((d, i) => {
            d.className = 'card-dot ' + (i === idx % 3 ? 'card-dot-on' : 'card-dot-off');
          });
        }, 4000);
      }
    };
  </script>
</Base>
