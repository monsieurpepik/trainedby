---
import Base from '../layouts/Base.astro';
---

<Base
  title="TrainedBy.ae — Stop Trading Time for Money"
  description="The UAE's only operating system for personal trainers. REPs-verified profiles, digital products, affiliate income, and a Grand Slam Offer builder — all in one place."
>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --brand: #FF5C00;
      --brand-dim: rgba(255,92,0,0.10);
      --brand-border: rgba(255,92,0,0.25);
      --brand-glow: rgba(255,92,0,0.15);
      --reps: #00C853;
      --gold: #F5C842;
      --surface: #0a0a0a;
      --surface-2: #111111;
      --surface-3: #1a1a1a;
      --surface-4: #222222;
      --border: rgba(255,255,255,0.07);
      --border-2: rgba(255,255,255,0.12);
      --text: #f2f2f2;
      --text-2: #888888;
      --text-3: #444444;
      --max: 1100px;
    }
    body { background: var(--surface); color: var(--text); font-family: 'Manrope', -apple-system, sans-serif; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

    /* NAV */
    .nav { position: fixed; top: 0; left: 0; right: 0; z-index: 100; padding: 0 32px; height: 60px; display: flex; align-items: center; gap: 32px; transition: background 0.3s, border-color 0.3s; border-bottom: 1px solid transparent; }
    .nav.scrolled { background: rgba(10,10,10,0.94); backdrop-filter: blur(16px); border-color: var(--border); }
    .nav-logo { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 20px; color: var(--brand); text-decoration: none; letter-spacing: -0.5px; margin-right: auto; }
    .nav-links { display: flex; gap: 28px; }
    .nav-links a { color: var(--text-2); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
    .nav-links a:hover { color: var(--text); }
    .nav-cta { display: inline-flex; align-items: center; gap: 6px; padding: 9px 18px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 13px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; }
    .nav-cta:hover { background: #e05200; transform: translateY(-1px); }
    @media (max-width: 640px) { .nav-links { display: none; } .nav { padding: 0 20px; } }

    /* BUTTONS */
    .btn-primary { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: var(--brand); color: #fff; font-size: 15px; font-weight: 700; text-decoration: none; transition: background 0.2s, transform 0.2s; border: none; cursor: pointer; }
    .btn-primary:hover { background: #e05200; transform: translateY(-2px); }
    .btn-ghost { display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px; border-radius: 100px; background: transparent; color: var(--text); font-size: 15px; font-weight: 600; text-decoration: none; border: 1px solid var(--border-2); transition: border-color 0.2s, transform 0.2s; }
    .btn-ghost:hover { border-color: rgba(255,255,255,0.25); transform: translateY(-2px); }

    /* HERO */
    .hero { min-height: 100vh; display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; padding: 120px 24px 80px; position: relative; overflow: hidden; }
    .hero::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 80% 60% at 50% 40%, rgba(255,92,0,0.08) 0%, transparent 70%); pointer-events: none; }
    .hero-eyebrow { display: inline-flex; align-items: center; gap: 8px; padding: 6px 14px; border-radius: 100px; border: 1px solid var(--brand-border); background: var(--brand-dim); font-size: 12px; font-weight: 700; color: var(--brand); letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 32px; }
    .hero-headline { font-family: 'Manrope', sans-serif; font-size: clamp(42px, 8vw, 88px); font-weight: 900; line-height: 1.0; letter-spacing: -3px; max-width: 860px; margin-bottom: 24px; }
    .hero-headline em { font-style: normal; color: var(--brand); }
    .hero-sub { font-size: clamp(15px, 2vw, 18px); color: var(--text-2); max-width: 520px; line-height: 1.7; margin-bottom: 16px; }
    .hero-guarantee { display: inline-flex; align-items: center; gap: 8px; padding: 8px 16px; border-radius: 100px; border: 1px solid rgba(0,200,83,0.25); background: rgba(0,200,83,0.06); font-size: 12px; font-weight: 600; color: #00C853; margin-bottom: 36px; }
    .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; justify-content: center; margin-bottom: 80px; }

    /* HERO INCOME CARDS */
    .hero-income-wrap { display: flex; gap: 16px; flex-wrap: wrap; justify-content: center; max-width: 760px; }
    .income-card { background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 16px; padding: 20px 24px; text-align: left; min-width: 200px; flex: 1; }
    .income-card.highlight { border-color: var(--brand-border); background: linear-gradient(135deg, rgba(255,92,0,0.08) 0%, var(--surface-2) 100%); }
    .income-label { font-size: 11px; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.8px; margin-bottom: 8px; }
    .income-value { font-family: 'Manrope', sans-serif; font-weight: 900; font-size: 28px; letter-spacing: -1px; line-height: 1; margin-bottom: 4px; }
    .income-value.brand { color: var(--brand); }
    .income-desc { font-size: 11px; color: var(--text-2); line-height: 1.5; }
    .income-badge { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; border-radius: 20px; background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.2); color: #00C853; font-size: 9px; font-weight: 700; margin-top: 8px; }
    @media (max-width: 640px) { .hero-income-wrap { gap: 10px; } .income-card { min-width: 140px; padding: 14px 16px; } .income-value { font-size: 22px; } }

    /* PROOF BAR */
    .proof-bar { border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); padding: 32px 24px; display: flex; align-items: center; justify-content: center; gap: 56px; flex-wrap: wrap; }
    .proof-item { text-align: center; }
    .proof-num { font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 30px; color: var(--text); letter-spacing: -1px; }
    .proof-label { font-size: 12px; color: var(--text-2); margin-top: 3px; }

    /* SECTION */
    .section { padding: 100px 24px; max-width: var(--max); margin: 0 auto; }
    .section-eyebrow { font-size: 11px; font-weight: 700; color: var(--brand); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 16px; }
    .section-title { font-family: 'Manrope', sans-serif; font-size: clamp(30px, 5vw, 54px); font-weight: 900; letter-spacing: -2px; line-height: 1.05; margin-bottom: 20px; }
    .section-sub { font-size: 16px; color: var(--text-2); line-height: 1.7; max-width: 520px; }

    /* PROBLEM / SOLUTION */
    .split-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }
    .split-col { padding: 48px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; }
    .split-col.problem { border-color: rgba(255,60,60,0.15); background: rgba(255,40,40,0.03); }
    .split-col.solution { border-color: var(--brand-border); background: var(--brand-dim); }
    .split-label { font-size: 11px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; margin-bottom: 20px; }
    .split-label.red { color: rgba(255,80,80,0.8); }
    .split-label.orange { color: var(--brand); }
    .split-item { display: flex; align-items: flex-start; gap: 12px; margin-bottom: 16px; font-size: 14px; line-height: 1.6; color: var(--text-2); }
    .split-icon { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 800; flex-shrink: 0; margin-top: 2px; }
    .split-icon.x { background: rgba(255,60,60,0.15); color: rgba(255,80,80,0.9); }
    .split-icon.check { background: rgba(255,92,0,0.15); color: var(--brand); }
    @media (max-width: 720px) { .split-grid { grid-template-columns: 1fr; } .split-col { padding: 28px; } }

    /* FEATURES */
    .features-grid { display: flex; flex-direction: column; gap: 2px; }
    .feature-row { display: grid; grid-template-columns: 1fr 1fr; border: 1px solid var(--border); border-radius: 16px; overflow: hidden; background: var(--surface-2); }
    .feature-row.reverse { direction: rtl; }
    .feature-row.reverse > * { direction: ltr; }
    .feature-text { padding: 56px 48px; display: flex; flex-direction: column; justify-content: center; }
    .feature-tag { display: inline-block; padding: 4px 12px; background: var(--brand-dim); border: 1px solid var(--brand-border); border-radius: 100px; color: var(--brand); font-size: 11px; font-weight: 700; letter-spacing: 0.5px; margin-bottom: 20px; width: fit-content; }
    .feature-title { font-family: 'Manrope',sans-serif; font-weight: 800; font-size: clamp(22px, 3vw, 32px); letter-spacing: -1px; line-height: 1.15; margin-bottom: 16px; }
    .feature-desc { font-size: 15px; color: var(--text-2); line-height: 1.7; margin-bottom: 16px; }
    .feature-proof { font-size: 13px; color: var(--brand); font-weight: 600; }
    .feature-visual { background: var(--surface-3); display: flex; align-items: center; justify-content: center; min-height: 320px; padding: 40px; position: relative; overflow: hidden; }
    .feature-visual::before { content: ''; position: absolute; inset: 0; background: radial-gradient(ellipse 70% 70% at 50% 50%, rgba(255,92,0,0.05) 0%, transparent 70%); }
    @media (max-width: 720px) { .feature-row { grid-template-columns: 1fr; } .feature-row.reverse { direction: ltr; } .feature-text { padding: 36px 28px; } .feature-visual { min-height: 200px; } }

    /* MOCKUP */
    .mockup-box { background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 12px; padding: 16px; position: relative; z-index: 1; width: 220px; }
    .m-reps { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.2); border-radius: 20px; color: #00C853; font-size: 9px; font-weight: 700; margin-bottom: 10px; }
    .m-avatar-row { display: flex; align-items: center; gap: 8px; margin-bottom: 10px; }
    .m-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--surface-4); display: flex; align-items: center; justify-content: center; font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 14px; color: var(--brand); flex-shrink: 0; }
    .m-name { font-family: 'Manrope',sans-serif; font-weight: 700; font-size: 12px; }
    .m-sub { font-size: 10px; color: var(--text-2); }
    .m-pkg { background: var(--surface-3); border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; margin-bottom: 6px; }
    .m-pkg-row { display: flex; justify-content: space-between; }
    .m-pkg-name { font-size: 10px; font-weight: 600; }
    .m-pkg-price { font-size: 11px; font-weight: 800; color: var(--brand); }
    .m-pkg-meta { font-size: 9px; color: var(--text-2); margin-top: 2px; }
    .m-guarantee { background: rgba(0,200,83,0.08); border: 1px solid rgba(0,200,83,0.2); border-radius: 8px; padding: 8px 10px; margin-bottom: 8px; font-size: 9px; color: #00C853; font-weight: 600; }
    .m-chart { height: 60px; display: flex; align-items: flex-end; gap: 4px; margin-bottom: 12px; }
    .m-bar { flex: 1; background: var(--surface-4); border-radius: 3px 3px 0 0; }
    .m-bar.hi { background: var(--brand); }
    .m-stat-row { display: flex; justify-content: space-between; }
    .m-stat-v { font-family: 'Manrope',sans-serif; font-weight: 800; font-size: 16px; color: var(--brand); }
    .m-stat-l { font-size: 9px; color: var(--text-2); text-transform: uppercase; }
    .m-result { background: var(--surface-3); border-radius: 8px; padding: 8px 10px; margin-bottom: 6px; }
    .m-result-label { font-size: 9px; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.3px; }
    .m-result-val { font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 20px; color: var(--brand); }
    .m-result-desc { font-size: 9px; color: var(--text-2); }
    .m-cta { width: 100%; padding: 7px; background: var(--brand); border-radius: 6px; color: #fff; font-size: 10px; font-weight: 700; text-align: center; border: none; margin-top: 8px; }
    .m-product { background: var(--surface-3); border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; margin-bottom: 6px; display: flex; justify-content: space-between; align-items: center; }
    .m-product-name { font-size: 10px; font-weight: 600; }
    .m-product-price { font-size: 11px; font-weight: 800; color: var(--brand); }
    .m-product-badge { font-size: 8px; color: var(--text-2); margin-top: 2px; }
    .m-affiliate-row { display: flex; align-items: center; gap: 6px; padding: 6px 8px; background: rgba(245,200,66,0.06); border: 1px solid rgba(245,200,66,0.15); border-radius: 6px; margin-bottom: 6px; }
    .m-affiliate-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--gold); flex-shrink: 0; }
    .m-affiliate-name { font-size: 9px; font-weight: 600; color: var(--gold); flex: 1; }
    .m-affiliate-pct { font-size: 9px; font-weight: 800; color: var(--gold); }

    /* INCOME CALCULATOR */
    .calc-wrap { background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 20px; padding: 40px; max-width: 680px; margin: 0 auto; }
    .calc-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-bottom: 16px; }
    .calc-field { display: flex; flex-direction: column; gap: 8px; }
    .calc-label { font-size: 12px; font-weight: 600; color: var(--text-2); }
    .calc-input { background: var(--surface-3); border: 1px solid var(--border-2); border-radius: 10px; padding: 12px 14px; color: var(--text); font-family: 'Manrope',sans-serif; font-size: 15px; font-weight: 600; outline: none; transition: border-color 0.2s; }
    .calc-input:focus { border-color: var(--brand); }
    .calc-divider { height: 1px; background: var(--border); margin: 24px 0; }
    .calc-results { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 12px; }
    .calc-result { background: var(--surface-3); border: 1px solid var(--border); border-radius: 12px; padding: 16px; text-align: center; }
    .calc-result.total { border-color: var(--brand-border); background: var(--brand-dim); }
    .calc-result-label { font-size: 10px; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 8px; }
    .calc-result-value { font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 22px; letter-spacing: -1px; color: var(--text); }
    .calc-result.total .calc-result-value { color: var(--brand); font-size: 26px; }
    @media (max-width: 640px) { .calc-row { grid-template-columns: 1fr; } .calc-results { grid-template-columns: 1fr; } .calc-wrap { padding: 24px; } }

    /* STACK */
    .stack-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16px; }
    .stack-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 28px; transition: border-color 0.2s, transform 0.2s; }
    .stack-card:hover { border-color: var(--border-2); transform: translateY(-3px); }
    .stack-card.gold { border-color: rgba(245,200,66,0.2); background: rgba(245,200,66,0.03); }
    .stack-icon { width: 44px; height: 44px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; margin-bottom: 16px; }
    .stack-icon.orange { background: var(--brand-dim); border: 1px solid var(--brand-border); }
    .stack-icon.green { background: rgba(0,200,83,0.08); border: 1px solid rgba(0,200,83,0.2); }
    .stack-icon.gold-bg { background: rgba(245,200,66,0.08); border: 1px solid rgba(245,200,66,0.2); }
    .stack-icon.blue { background: rgba(0,120,255,0.08); border: 1px solid rgba(0,120,255,0.2); }
    .stack-card-title { font-family: 'Manrope',sans-serif; font-weight: 800; font-size: 18px; letter-spacing: -0.5px; margin-bottom: 8px; }
    .stack-card-desc { font-size: 14px; color: var(--text-2); line-height: 1.6; margin-bottom: 12px; }
    .stack-card-value { font-size: 12px; font-weight: 700; color: var(--brand); }
    @media (max-width: 720px) { .stack-grid { grid-template-columns: 1fr; } }

    /* HOW IT WORKS */
    .how-wrap { display: grid; grid-template-columns: 1fr 1fr; gap: 80px; align-items: start; }
    .how-steps { display: flex; flex-direction: column; }
    .how-step { display: flex; gap: 20px; padding: 28px 0; border-bottom: 1px solid var(--border); }
    .how-step:last-child { border-bottom: none; }
    .how-num { font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 13px; color: var(--brand); min-width: 24px; padding-top: 2px; }
    .how-title { font-family: 'Manrope',sans-serif; font-weight: 700; font-size: 17px; margin-bottom: 6px; }
    .how-desc { font-size: 14px; color: var(--text-2); line-height: 1.6; }
    .how-visual { position: sticky; top: 100px; background: var(--surface-2); border: 1px solid var(--border-2); border-radius: 16px; padding: 40px; display: flex; align-items: center; justify-content: center; min-height: 400px; }
    @media (max-width: 720px) { .how-wrap { grid-template-columns: 1fr; gap: 40px; } .how-visual { display: none; } }

    /* TESTIMONIALS */
    .testimonials-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .testimonial-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 28px; }
    .testimonial-quote { font-size: 15px; color: var(--text-2); line-height: 1.7; margin-bottom: 20px; font-style: italic; }
    .testimonial-author { display: flex; align-items: center; gap: 12px; }
    .t-avatar { width: 38px; height: 38px; border-radius: 50%; background: var(--surface-3); display: flex; align-items: center; justify-content: center; font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 14px; color: var(--brand); flex-shrink: 0; }
    .t-name { font-family: 'Manrope',sans-serif; font-weight: 700; font-size: 14px; }
    .t-role { font-size: 12px; color: var(--text-2); }
    .t-reps { display: inline-flex; align-items: center; gap: 4px; padding: 2px 8px; background: rgba(0,200,83,0.1); border: 1px solid rgba(0,200,83,0.2); border-radius: 20px; color: #00C853; font-size: 9px; font-weight: 700; margin-top: 4px; }
    @media (max-width: 860px) { .testimonials-grid { grid-template-columns: 1fr; } }

    /* PRICING */
    .pricing-header { text-align: center; margin-bottom: 56px; }
    .pricing-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 16px; }
    .pricing-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 32px 28px; display: flex; flex-direction: column; transition: border-color 0.2s, transform 0.2s; position: relative; }
    .pricing-card:hover { border-color: var(--border-2); transform: translateY(-4px); }
    .pricing-card.featured { border-color: var(--brand-border); background: linear-gradient(160deg, rgba(255,92,0,0.07) 0%, var(--surface-2) 60%); }
    .pricing-popular { position: absolute; top: -12px; left: 50%; transform: translateX(-50%); padding: 4px 16px; background: var(--brand); color: #fff; border-radius: 100px; font-size: 11px; font-weight: 700; white-space: nowrap; }
    .pricing-tier { font-size: 12px; font-weight: 700; color: var(--text-2); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 12px; }
    .pricing-price { font-family: 'Manrope',sans-serif; font-weight: 900; font-size: 40px; letter-spacing: -2px; line-height: 1; margin-bottom: 4px; }
    .pricing-price span { font-size: 16px; font-weight: 500; color: var(--text-2); letter-spacing: 0; }
    .pricing-desc { font-size: 13px; color: var(--text-2); line-height: 1.5; margin-bottom: 24px; padding-bottom: 24px; border-bottom: 1px solid var(--border); }
    .pricing-features { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 28px; flex: 1; }
    .pricing-features li { display: flex; align-items: flex-start; gap: 10px; font-size: 13px; color: var(--text-2); line-height: 1.4; }
    .pricing-features li::before { content: '✓'; color: var(--brand); font-weight: 700; font-size: 13px; flex-shrink: 0; margin-top: 1px; }
    .pricing-features li.muted::before { content: '–'; color: var(--text-3); }
    .pricing-features li.muted { color: var(--text-3); }
    .pricing-guarantee { display: flex; align-items: center; gap: 8px; padding: 10px 14px; background: rgba(0,200,83,0.06); border: 1px solid rgba(0,200,83,0.15); border-radius: 10px; font-size: 11px; color: #00C853; font-weight: 600; margin-bottom: 16px; }
    .pricing-btn { display: block; text-align: center; padding: 13px; border-radius: 100px; font-size: 14px; font-weight: 700; text-decoration: none; transition: all 0.2s; border: none; cursor: pointer; }
    .pricing-btn-primary { background: var(--brand); color: #fff; }
    .pricing-btn-primary:hover { background: #e05200; }
    .pricing-btn-ghost { background: transparent; color: var(--text); border: 1px solid var(--border-2); }
    .pricing-btn-ghost:hover { border-color: rgba(255,255,255,0.25); }
    @media (max-width: 860px) { .pricing-grid { grid-template-columns: 1fr; max-width: 380px; margin: 0 auto; } }

    /* FAQ */
    .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 0; }
    .faq-item { padding: 28px 0; border-bottom: 1px solid var(--border); }
    .faq-item:nth-child(odd) { padding-right: 48px; border-right: 1px solid var(--border); }
    .faq-item:nth-child(even) { padding-left: 48px; }
    .faq-q { font-family: 'Manrope',sans-serif; font-weight: 700; font-size: 16px; margin-bottom: 10px; }
    .faq-a { font-size: 14px; color: var(--text-2); line-height: 1.7; }
    @media (max-width: 720px) { .faq-grid { grid-template-columns: 1fr; } .faq-item:nth-child(odd) { padding-right: 0; border-right: none; } .faq-item:nth-child(even) { padding-left: 0; } }

    /* BOTTOM CTA */
