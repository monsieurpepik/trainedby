  <script>
    // Nav scroll effect
    const nav = document.getElementById('nav');
    window.addEventListener('scroll', () => { nav?.classList.toggle('scrolled', window.scrollY > 40); }, { passive: true });

    // Income Calculator
    function calcIncome() {
      const clients = parseFloat((document.getElementById('c-clients') as HTMLInputElement).value) || 0;
      const pkg = parseFloat((document.getElementById('c-pkg') as HTMLInputElement).value) || 0;
      const digital = parseFloat((document.getElementById('c-digital') as HTMLInputElement).value) || 0;
      const affiliate = parseFloat((document.getElementById('c-affiliate') as HTMLInputElement).value) || 0;
      const sessions = clients * pkg;
      const digitalIncome = clients * 0.3 * digital;
      const affiliateIncome = clients * affiliate * 0.25;
      const passive = digitalIncome + affiliateIncome;
      const total = sessions + passive;
      const uplift = sessions > 0 ? Math.round((passive / sessions) * 100) : 0;
      const fmt = (n: number) => 'AED ' + Math.round(n).toLocaleString('en-AE');
      (document.getElementById('r-sessions') as HTMLElement).textContent = fmt(sessions);
      (document.getElementById('r-passive') as HTMLElement).textContent = fmt(passive);
      (document.getElementById('r-total') as HTMLElement).textContent = fmt(total);
      const badge = document.getElementById('r-uplift') as HTMLElement;
      if (badge) {
        badge.textContent = uplift > 0 ? `+${uplift}% passive income on top of sessions` : 'Enter your details to see your number';
        badge.style.color = uplift > 0 ? '#00C853' : 'var(--text-2)';
      }
      const totalEl = document.getElementById('r-total') as HTMLElement;
      if (totalEl) { totalEl.style.transform = 'scale(1.04)'; setTimeout(() => totalEl.style.transform = 'scale(1)', 200); }
    }
    ['c-clients','c-pkg','c-digital','c-affiliate'].forEach(id => {
      document.getElementById(id)?.addEventListener('input', calcIncome);
    });
    calcIncome();

    // Dynamic scarcity counter
    (function() {
      const base = 87; const max = 100;
      let current = Math.min(base + Math.floor(Math.random() * 3), max - 1);
      const el = document.getElementById('spots-counter');
      if (!el) return;
      el.textContent = current + '/' + max;
      setInterval(() => {
        if (current < max - 1) {
          current++;
          el.textContent = current + '/' + max;
          el.style.color = '#FF5C00';
          setTimeout(() => el.style.color = '#fff', 800);
        }
      }, 45000 + Math.random() * 60000);
    })();
  </script>
