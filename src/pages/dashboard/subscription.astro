---
import Base from '../../layouts/Base.astro';
import { SubscriptionSettings } from '../../components/video/SubscriptionSettings';
const SUPABASE_URL = import.meta.env.PUBLIC_SUPABASE_URL ?? '';
const SUPABASE_ANON_KEY = import.meta.env.PUBLIC_SUPABASE_ANON_KEY ?? '';
---
<Base title="Subscription Settings — TrainedBy" description="Set your monthly subscription price">
<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  body { background: #0f0e0d; color: #fff; font-family: 'Manrope', system-ui, sans-serif; min-height: 100vh; }
</style>
<SubscriptionSettings
  client:load
  supabaseUrl={SUPABASE_URL}
  supabaseAnonKey={SUPABASE_ANON_KEY}
/>
</Base>
