---
// Root index — serves as the homepage for all domains.
// Detects market and renders the landing page content directly
// (no redirect needed — better for SEO and performance).
import Base from '../layouts/Base.astro';
import { getMarket } from '../lib/market.ts';

const market = getMarket(Astro.url.hostname);

// Redirect to /landing — the landing page is the full homepage
// We use a meta refresh + JS redirect for instant client-side navigation
// while still serving a crawlable page for SEO.
---
<Base
  title={market.siteTitle}
  description={market.metaDescription}
  canonical={`https://${market.domain}/`}
>
  <meta http-equiv="refresh" content="0;url=/landing" />
  <script is:inline>window.location.replace('/landing');</script>
  <noscript>
    <a href="/landing" style="color:#FF5C00;font-family:sans-serif;">
      Click here to enter the site
    </a>
  </noscript>
</Base>
