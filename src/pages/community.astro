---
import Base from '../layouts/Base.astro';
---
<Base
  title="TrainedBy Community — Trainer Tips, Transformations & Insights"
  description="Real advice from verified personal trainers. Workout tips, client transformations, nutrition insights, and training knowledge from the TrainedBy community."
>
<style>
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
:root {
  --brand: #FF5C00; --brand-dim: rgba(255,92,0,0.10); --brand-border: rgba(255,92,0,0.25);
  --reps: #00C853; --reps-dim: rgba(0,200,83,0.08); --reps-border: rgba(0,200,83,0.2);
  --surface: #0a0a0a; --surface-2: #111; --surface-3: #1c1c1c; --surface-4: #242424;
  --border: rgba(255,255,255,0.08); --text: #fff;
  --text-muted: rgba(255,255,255,0.5); --text-faint: rgba(255,255,255,0.25);
}
html { scroll-behavior: smooth; }
body { background: var(--surface); color: var(--text); font-family: 'Inter', sans-serif; font-size: 15px; line-height: 1.7; -webkit-font-smoothing: antialiased; overflow-x: hidden; }

/* Nav */
.nav { position: sticky; top: 0; z-index: 100; background: rgba(10,10,10,0.92); backdrop-filter: blur(16px); border-bottom: 1px solid var(--border); padding: 0 24px; display: flex; align-items: center; justify-content: space-between; height: 60px; }
.nav-brand { font-weight: 800; font-size: 18px; color: var(--text); text-decoration: none; display: flex; align-items: center; gap: 8px; }
.nav-brand span { color: var(--brand); }
.nav-links { display: flex; gap: 24px; align-items: center; }
.nav-links a { color: var(--text-muted); text-decoration: none; font-size: 14px; font-weight: 500; transition: color 0.2s; }
.nav-links a:hover, .nav-links a.active { color: var(--text); }
.nav-cta { background: var(--brand); color: #fff; padding: 8px 18px; border-radius: 8px; font-size: 14px; font-weight: 600; text-decoration: none; transition: opacity 0.2s; }
.nav-cta:hover { opacity: 0.88; color: #fff; }

/* Hero */
.hero { padding: 64px 24px 40px; text-align: center; max-width: 720px; margin: 0 auto; }
.hero-badge { display: inline-flex; align-items: center; gap: 6px; background: var(--brand-dim); border: 1px solid var(--brand-border); color: var(--brand); font-size: 12px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; padding: 5px 12px; border-radius: 100px; margin-bottom: 20px; }
.hero h1 { font-size: clamp(28px, 5vw, 44px); font-weight: 800; line-height: 1.15; margin-bottom: 16px; }
.hero p { color: var(--text-muted); font-size: 17px; line-height: 1.6; margin-bottom: 32px; }
.hero-stats { display: flex; gap: 32px; justify-content: center; flex-wrap: wrap; }
.hero-stat { text-align: center; }
.hero-stat strong { display: block; font-size: 24px; font-weight: 800; color: var(--brand); }
.hero-stat span { font-size: 12px; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.06em; }

/* Filter bar */
.filter-bar { max-width: 1100px; margin: 0 auto 32px; padding: 0 24px; display: flex; gap: 10px; align-items: center; flex-wrap: wrap; }
.filter-btn { background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted); padding: 7px 16px; border-radius: 100px; font-size: 13px; font-weight: 600; cursor: pointer; transition: all 0.2s; white-space: nowrap; }
.filter-btn:hover { border-color: rgba(255,255,255,0.2); color: var(--text); }
.filter-btn.active { background: var(--brand); border-color: var(--brand); color: #fff; }
.filter-search { flex: 1; min-width: 200px; background: var(--surface-3); border: 1px solid var(--border); color: var(--text); padding: 8px 14px; border-radius: 100px; font-size: 13px; outline: none; transition: border-color 0.2s; }
.filter-search:focus { border-color: rgba(255,92,0,0.4); }
.filter-search::placeholder { color: var(--text-faint); }

/* Feed layout */
.feed-layout { max-width: 1100px; margin: 0 auto; padding: 0 24px 80px; display: grid; grid-template-columns: 1fr 320px; gap: 32px; }
@media (max-width: 900px) { .feed-layout { grid-template-columns: 1fr; } .sidebar { display: none; } }

/* Post card */
.post-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; transition: border-color 0.2s, transform 0.2s; margin-bottom: 20px; }
.post-card:hover { border-color: rgba(255,255,255,0.14); transform: translateY(-1px); }
.post-header { padding: 20px 20px 0; display: flex; align-items: center; gap: 12px; }
.post-avatar { width: 44px; height: 44px; border-radius: 50%; background: var(--surface-4); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 16px; color: var(--brand); flex-shrink: 0; overflow: hidden; }
.post-avatar img { width: 100%; height: 100%; object-fit: cover; }
.post-author-info { flex: 1; min-width: 0; }
.post-author-name { font-weight: 700; font-size: 14px; display: flex; align-items: center; gap: 6px; }
.post-verified { width: 16px; height: 16px; background: var(--reps); border-radius: 50%; display: inline-flex; align-items: center; justify-content: center; flex-shrink: 0; }
.post-verified svg { width: 9px; height: 9px; fill: #fff; }
.post-meta { font-size: 12px; color: var(--text-faint); }
.post-category { background: var(--brand-dim); border: 1px solid var(--brand-border); color: var(--brand); font-size: 11px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; padding: 3px 8px; border-radius: 100px; white-space: nowrap; }

.post-body { padding: 16px 20px; }
.post-title { font-size: 17px; font-weight: 700; line-height: 1.35; margin-bottom: 10px; color: var(--text); }
.post-excerpt { color: var(--text-muted); font-size: 14px; line-height: 1.65; }
.post-image { width: 100%; aspect-ratio: 16/9; object-fit: cover; background: var(--surface-3); display: block; margin-top: 14px; border-radius: 10px; }
.post-image-placeholder { width: 100%; height: 200px; background: linear-gradient(135deg, var(--surface-3), var(--surface-4)); border-radius: 10px; margin-top: 14px; display: flex; align-items: center; justify-content: center; }
.post-tags { display: flex; gap: 6px; flex-wrap: wrap; margin-top: 12px; }
.post-tag { background: var(--surface-4); color: var(--text-faint); font-size: 11px; padding: 3px 9px; border-radius: 100px; font-weight: 500; }

.post-footer { padding: 14px 20px; border-top: 1px solid var(--border); display: flex; align-items: center; gap: 20px; }
.post-action { display: flex; align-items: center; gap: 6px; color: var(--text-faint); font-size: 13px; font-weight: 500; cursor: pointer; transition: color 0.2s; background: none; border: none; padding: 0; }
.post-action:hover { color: var(--text-muted); }
.post-action.liked { color: var(--brand); }
.post-action svg { width: 16px; height: 16px; }
.post-read-more { margin-left: auto; color: var(--brand); font-size: 13px; font-weight: 600; text-decoration: none; }
.post-read-more:hover { text-decoration: underline; }

/* Transformation card */
.transformation-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; overflow: hidden; margin-bottom: 20px; }
.transformation-header { padding: 16px 20px 0; display: flex; align-items: center; gap: 10px; }
.transformation-badge { background: linear-gradient(135deg, #FF5C00, #FF8C00); color: #fff; font-size: 11px; font-weight: 800; letter-spacing: 0.08em; text-transform: uppercase; padding: 4px 10px; border-radius: 100px; }
.transformation-images { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; margin-top: 14px; }
.transformation-img { aspect-ratio: 3/4; background: var(--surface-3); display: flex; align-items: center; justify-content: center; font-size: 12px; color: var(--text-faint); }
.transformation-img.before { border-radius: 0 0 0 0; }
.transformation-img.after { border-radius: 0 0 0 0; }
.transformation-label { text-align: center; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; padding: 6px; background: var(--surface-3); color: var(--text-faint); }
.transformation-stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1px; background: var(--border); margin-top: 2px; }
.transformation-stat { background: var(--surface-2); padding: 12px; text-align: center; }
.transformation-stat strong { display: block; font-size: 18px; font-weight: 800; color: var(--brand); }
.transformation-stat span { font-size: 10px; color: var(--text-faint); text-transform: uppercase; letter-spacing: 0.06em; }
.transformation-body { padding: 16px 20px; }

/* Sidebar */
.sidebar { }
.sidebar-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 20px; }
.sidebar-title { font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 16px; }
.top-contributor { display: flex; align-items: center; gap: 10px; padding: 10px 0; border-bottom: 1px solid var(--border); }
.top-contributor:last-child { border-bottom: none; padding-bottom: 0; }
.tc-avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--surface-4); display: flex; align-items: center; justify-content: center; font-weight: 800; font-size: 13px; color: var(--brand); flex-shrink: 0; }
.tc-info { flex: 1; min-width: 0; }
.tc-name { font-size: 13px; font-weight: 600; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.tc-posts { font-size: 11px; color: var(--text-faint); }
.trending-tag { display: inline-flex; align-items: center; gap: 6px; background: var(--surface-3); border: 1px solid var(--border); color: var(--text-muted); font-size: 12px; font-weight: 500; padding: 5px 12px; border-radius: 100px; margin: 4px 4px 4px 0; cursor: pointer; transition: all 0.2s; text-decoration: none; }
.trending-tag:hover { border-color: rgba(255,92,0,0.3); color: var(--brand); }
.join-cta { background: linear-gradient(135deg, var(--brand-dim), rgba(255,92,0,0.05)); border: 1px solid var(--brand-border); border-radius: 16px; padding: 20px; text-align: center; }
.join-cta h3 { font-size: 16px; font-weight: 700; margin-bottom: 8px; }
.join-cta p { font-size: 13px; color: var(--text-muted); margin-bottom: 16px; line-height: 1.5; }
.join-cta a { display: block; background: var(--brand); color: #fff; padding: 10px 20px; border-radius: 8px; font-size: 14px; font-weight: 700; text-decoration: none; transition: opacity 0.2s; }
.join-cta a:hover { opacity: 0.88; }

/* Loading skeleton */
.skeleton { background: linear-gradient(90deg, var(--surface-3) 25%, var(--surface-4) 50%, var(--surface-3) 75%); background-size: 200% 100%; animation: shimmer 1.5s infinite; border-radius: 8px; }
@keyframes shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }
.skeleton-card { background: var(--surface-2); border: 1px solid var(--border); border-radius: 16px; padding: 20px; margin-bottom: 20px; }

/* Empty state */
.empty-state { text-align: center; padding: 60px 20px; color: var(--text-muted); }
.empty-state svg { width: 48px; height: 48px; opacity: 0.3; margin-bottom: 16px; }
.empty-state h3 { font-size: 18px; font-weight: 700; margin-bottom: 8px; color: var(--text); }
.empty-state p { font-size: 14px; line-height: 1.6; }

/* Write post button */
.write-post-btn { display: flex; align-items: center; gap: 10px; background: var(--surface-2); border: 1px solid var(--border); border-radius: 100px; padding: 12px 20px; cursor: pointer; width: 100%; margin-bottom: 24px; transition: border-color 0.2s; color: var(--text-faint); font-size: 14px; }
.write-post-btn:hover { border-color: rgba(255,92,0,0.3); color: var(--text-muted); }
.write-post-btn .avatar { width: 36px; height: 36px; border-radius: 50%; background: var(--surface-4); flex-shrink: 0; }

/* Post modal */
.modal-overlay { position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(4px); z-index: 1000; display: flex; align-items: center; justify-content: center; padding: 20px; opacity: 0; pointer-events: none; transition: opacity 0.2s; }
.modal-overlay.open { opacity: 1; pointer-events: all; }
.modal { background: var(--surface-2); border: 1px solid var(--border); border-radius: 20px; width: 100%; max-width: 560px; max-height: 90vh; overflow-y: auto; }
.modal-header { padding: 20px 24px; border-bottom: 1px solid var(--border); display: flex; align-items: center; justify-content: space-between; }
.modal-header h2 { font-size: 18px; font-weight: 700; }
.modal-close { background: var(--surface-3); border: none; color: var(--text-muted); width: 32px; height: 32px; border-radius: 50%; cursor: pointer; font-size: 18px; display: flex; align-items: center; justify-content: center; }
.modal-body { padding: 24px; }
.form-group { margin-bottom: 18px; }
.form-label { display: block; font-size: 12px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--text-muted); margin-bottom: 8px; }
.form-input, .form-textarea, .form-select { width: 100%; background: var(--surface-3); border: 1px solid var(--border); color: var(--text); padding: 10px 14px; border-radius: 10px; font-size: 14px; outline: none; transition: border-color 0.2s; font-family: inherit; }
.form-input:focus, .form-textarea:focus, .form-select:focus { border-color: rgba(255,92,0,0.4); }
.form-textarea { resize: vertical; min-height: 120px; line-height: 1.6; }
.form-select option { background: var(--surface-3); }
.category-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; }
.category-option { background: var(--surface-3); border: 1px solid var(--border); border-radius: 8px; padding: 8px 10px; text-align: center; font-size: 12px; font-weight: 600; cursor: pointer; transition: all 0.2s; color: var(--text-muted); }
.category-option:hover { border-color: rgba(255,92,0,0.3); color: var(--text); }
.category-option.selected { background: var(--brand-dim); border-color: var(--brand); color: var(--brand); }
.form-submit { width: 100%; background: var(--brand); color: #fff; border: none; padding: 13px; border-radius: 10px; font-size: 15px; font-weight: 700; cursor: pointer; transition: opacity 0.2s; }
.form-submit:hover { opacity: 0.88; }
.form-submit:disabled { opacity: 0.5; cursor: not-allowed; }
.trainer-id-note { font-size: 12px; color: var(--text-faint); margin-top: 6px; }
</style>

<!-- Nav -->
<nav class="nav">
  <a href="/landing" class="nav-brand">Trained<span>By</span></a>
  <div class="nav-links">
    <a href="/find">Find a Trainer</a>
    <a href="/blog">Blog</a>
    <a href="/community" class="active">Community</a>
    <a href="/join" class="nav-cta">Join Free</a>
  </div>
</nav>

<!-- Hero -->
<section class="hero">
  <div class="hero-badge">
    <svg width="10" height="10" viewBox="0 0 10 10" fill="currentColor"><circle cx="5" cy="5" r="5"/></svg>
    Trainer Community
  </div>
  <h1>Real Knowledge from<br>Verified Trainers</h1>
  <p>Tips, transformations, and training insights from REPs-verified coaches. No influencers. No fluff.</p>
  <div class="hero-stats">
    <div class="hero-stat"><strong id="post-count">—</strong><span>Posts</span></div>
    <div class="hero-stat"><strong id="trainer-count">—</strong><span>Contributors</span></div>
    <div class="hero-stat"><strong id="like-count">—</strong><span>Likes</span></div>
  </div>
</section>

<!-- Filter bar -->
<div class="filter-bar">
  <button class="filter-btn active" data-cat="all">All</button>
  <button class="filter-btn" data-cat="tip">Training Tips</button>
  <button class="filter-btn" data-cat="transformation">Transformations</button>
  <button class="filter-btn" data-cat="nutrition">Nutrition</button>
  <button class="filter-btn" data-cat="business">Business</button>
  <button class="filter-btn" data-cat="mindset">Mindset</button>
  <input class="filter-search" type="text" placeholder="Search posts..." id="search-input">
</div>

<!-- Main layout -->
<div class="feed-layout">
  <!-- Feed -->
  <div>
    <!-- Write post prompt (shown when trainer is logged in) -->
    <div class="write-post-btn" id="write-post-trigger" style="display:none" onclick="openModal()">
      <div class="avatar"></div>
      <span>Share a tip, transformation, or insight...</span>
    </div>

    <!-- Posts feed -->
    <div id="posts-feed">
      <!-- Skeleton loaders -->
      <div class="skeleton-card">
        <div style="display:flex;gap:12px;margin-bottom:14px"><div class="skeleton" style="width:44px;height:44px;border-radius:50%"></div><div style="flex:1"><div class="skeleton" style="height:14px;width:60%;margin-bottom:8px"></div><div class="skeleton" style="height:12px;width:40%"></div></div></div>
        <div class="skeleton" style="height:18px;width:80%;margin-bottom:10px"></div>
        <div class="skeleton" style="height:14px;width:100%;margin-bottom:6px"></div>
        <div class="skeleton" style="height:14px;width:75%"></div>
      </div>
      <div class="skeleton-card">
        <div style="display:flex;gap:12px;margin-bottom:14px"><div class="skeleton" style="width:44px;height:44px;border-radius:50%"></div><div style="flex:1"><div class="skeleton" style="height:14px;width:55%;margin-bottom:8px"></div><div class="skeleton" style="height:12px;width:35%"></div></div></div>
        <div class="skeleton" style="height:18px;width:70%;margin-bottom:10px"></div>
        <div class="skeleton" style="height:200px;border-radius:10px"></div>
      </div>
    </div>
  </div>

  <!-- Sidebar -->
  <aside class="sidebar">
    <!-- Top contributors -->
    <div class="sidebar-card">
      <div class="sidebar-title">Top Contributors</div>
      <div id="top-contributors">
        <div class="skeleton" style="height:56px;margin-bottom:8px"></div>
        <div class="skeleton" style="height:56px;margin-bottom:8px"></div>
        <div class="skeleton" style="height:56px"></div>
      </div>
    </div>

    <!-- Trending tags -->
    <div class="sidebar-card">
      <div class="sidebar-title">Trending Topics</div>
      <div id="trending-tags">
        <a href="#" class="trending-tag">#fatloss</a>
        <a href="#" class="trending-tag">#musclebuilding</a>
        <a href="#" class="trending-tag">#nutrition</a>
        <a href="#" class="trending-tag">#hiit</a>
        <a href="#" class="trending-tag">#transformation</a>
        <a href="#" class="trending-tag">#dubai</a>
        <a href="#" class="trending-tag">#mindset</a>
        <a href="#" class="trending-tag">#mobility</a>
      </div>
    </div>

    <!-- Join CTA -->
    <div class="join-cta">
      <h3>Are you a trainer?</h3>
      <p>Join TrainedBy, get verified, and share your expertise with thousands of clients.</p>
      <a href="/join">Create Your Profile →</a>
    </div>
  </aside>
</div>

<!-- Post creation modal -->
<div class="modal-overlay" id="post-modal">
  <div class="modal">
    <div class="modal-header">
      <h2>Share with the Community</h2>
      <button class="modal-close" onclick="closeModal()">×</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label class="form-label">Category</label>
        <div class="category-grid">
          <div class="category-option selected" data-val="tip" onclick="selectCategory(this)">💪 Training Tip</div>
          <div class="category-option" data-val="transformation" onclick="selectCategory(this)">🔥 Transformation</div>
          <div class="category-option" data-val="nutrition" onclick="selectCategory(this)">🥗 Nutrition</div>
          <div class="category-option" data-val="business" onclick="selectCategory(this)">💼 Business</div>
          <div class="category-option" data-val="mindset" onclick="selectCategory(this)">🧠 Mindset</div>
          <div class="category-option" data-val="other" onclick="selectCategory(this)">✨ Other</div>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Title</label>
        <input class="form-input" id="post-title" type="text" placeholder="e.g. Why most people fail at fat loss (and how to fix it)">
      </div>
      <div class="form-group">
        <label class="form-label">Your Post</label>
        <textarea class="form-textarea" id="post-content" placeholder="Share your knowledge, experience, or insight..."></textarea>
      </div>
      <div class="form-group">
        <label class="form-label">Tags (comma separated)</label>
        <input class="form-input" id="post-tags" type="text" placeholder="e.g. fatloss, nutrition, cardio">
      </div>
      <div class="form-group">
        <label class="form-label">Your Trainer ID</label>
        <input class="form-input" id="post-trainer-id" type="text" placeholder="From your dashboard profile URL">
        <p class="trainer-id-note">Find this in your dashboard → Profile → copy the URL slug</p>
      </div>
      <button class="form-submit" id="post-submit-btn" onclick="submitPost()">Publish Post</button>
    </div>
  </div>
</div>

<script>
const SUPABASE_URL = 'https://mezhtdbfyvkshpuplqqw.supabase.co';
const SUPABASE_ANON = 'eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Im1lemh0ZGJmeXZrc2hwdXBscXF3Iiwicm9sZSI6ImFub24iLCJpYXQiOjE3NDQ1NjA1NzcsImV4cCI6MjA2MDEzNjU3N30.YVkNmqTJBfzHFQbVmqYzpqKi_EJkBrHiOh-Lq2zFUGo';

let allPosts = [];
let activeCategory = 'all';
let selectedCategory = 'tip';

async function loadPosts() {
  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/community_posts?select=*,trainers(name,reps_verified,city,avatar_url)&order=created_at.desc&limit=30`, {
      headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${SUPABASE_ANON}` }
    });
    allPosts = await res.json();
    if (!Array.isArray(allPosts)) allPosts = [];
    renderPosts(allPosts);
    updateStats(allPosts);
    renderTopContributors(allPosts);
  } catch (e) {
    renderEmptyState();
  }
}

function updateStats(posts) {
  document.getElementById('post-count').textContent = posts.length;
  const trainers = new Set(posts.map(p => p.trainer_id).filter(Boolean));
  document.getElementById('trainer-count').textContent = trainers.size;
  const likes = posts.reduce((sum, p) => sum + (p.like_count || 0), 0);
  document.getElementById('like-count').textContent = likes;
}

function renderTopContributors(posts) {
  const counts = {};
  for (const p of posts) {
    if (!p.trainer_id) continue;
    if (!counts[p.trainer_id]) counts[p.trainer_id] = { name: p.trainers?.name || 'Trainer', posts: 0, verified: p.trainers?.reps_verified };
    counts[p.trainer_id].posts++;
  }
  const sorted = Object.entries(counts).sort((a, b) => b[1].posts - a[1].posts).slice(0, 5);
  const el = document.getElementById('top-contributors');
  if (sorted.length === 0) { el.innerHTML = '<p style="color:var(--text-faint);font-size:13px">No posts yet</p>'; return; }
  el.innerHTML = sorted.map(([id, d]) => `
    <div class="top-contributor">
      <div class="tc-avatar">${(d.name || 'T').charAt(0).toUpperCase()}</div>
      <div class="tc-info">
        <div class="tc-name">${d.name}${d.verified ? ' ✓' : ''}</div>
        <div class="tc-posts">${d.posts} post${d.posts !== 1 ? 's' : ''}</div>
      </div>
    </div>
  `).join('');
}

function renderEmptyState() {
  document.getElementById('posts-feed').innerHTML = `
    <div class="empty-state">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 013 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      <h3>No posts yet</h3>
      <p>Be the first to share a training tip, transformation, or insight with the community.</p>
    </div>
  `;
}

function renderPosts(posts) {
  const feed = document.getElementById('posts-feed');
  if (!posts || posts.length === 0) { renderEmptyState(); return; }

  const filtered = activeCategory === 'all' ? posts : posts.filter(p => p.category === activeCategory);
  if (filtered.length === 0) {
    feed.innerHTML = `<div class="empty-state"><h3>No posts in this category yet</h3><p>Be the first to post here.</p></div>`;
    return;
  }

  feed.innerHTML = filtered.map(post => {
    const trainer = post.trainers || {};
    const initials = (trainer.name || 'T').split(' ').map(w => w[0]).join('').substring(0, 2).toUpperCase();
    const timeAgo = getTimeAgo(post.created_at);
    const tags = (post.tags || []).slice(0, 4);
    const catLabel = { tip: 'Training Tip', transformation: 'Transformation', nutrition: 'Nutrition', business: 'Business', mindset: 'Mindset', other: 'Community' }[post.category] || 'Post';

    if (post.category === 'transformation') {
      return `
        <div class="transformation-card" data-id="${post.id}">
          <div class="transformation-header">
            <div class="post-avatar">${trainer.avatar_url ? `<img src="${trainer.avatar_url}" alt="${trainer.name}">` : initials}</div>
            <div class="post-author-info">
              <div class="post-author-name">${trainer.name || 'Trainer'}${trainer.reps_verified ? `<span class="post-verified"><svg viewBox="0 0 10 10"><path d="M2 5l2.5 2.5L8 3"/></svg></span>` : ''}</div>
              <div class="post-meta">${trainer.city || ''} · ${timeAgo}</div>
            </div>
            <span class="transformation-badge">Transformation</span>
          </div>
          <div class="post-body">
            <div class="post-title">${post.title || ''}</div>
            <div class="post-excerpt">${(post.content || '').substring(0, 200)}${(post.content || '').length > 200 ? '...' : ''}</div>
            ${post.stats ? `
              <div class="transformation-stats" style="margin-top:14px">
                ${post.stats.duration ? `<div class="transformation-stat"><strong>${post.stats.duration}</strong><span>Duration</span></div>` : ''}
                ${post.stats.weight_lost ? `<div class="transformation-stat"><strong>${post.stats.weight_lost}</strong><span>Lost</span></div>` : ''}
                ${post.stats.muscle_gained ? `<div class="transformation-stat"><strong>${post.stats.muscle_gained}</strong><span>Gained</span></div>` : ''}
              </div>
            ` : ''}
          </div>
          <div class="post-footer">
            <button class="post-action ${post.user_liked ? 'liked' : ''}" onclick="likePost('${post.id}', this)">
              <svg viewBox="0 0 24 24" fill="${post.user_liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
              ${post.like_count || 0}
            </button>
            <button class="post-action">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
              ${post.comment_count || 0}
            </button>
            ${tags.map(t => `<span class="post-tag">#${t}</span>`).join('')}
          </div>
        </div>
      `;
    }

    return `
      <div class="post-card" data-id="${post.id}">
        <div class="post-header">
          <div class="post-avatar">${trainer.avatar_url ? `<img src="${trainer.avatar_url}" alt="${trainer.name}">` : initials}</div>
          <div class="post-author-info">
            <div class="post-author-name">${trainer.name || 'Trainer'}${trainer.reps_verified ? `<span class="post-verified"><svg viewBox="0 0 10 10"><path d="M2 5l2.5 2.5L8 3"/></svg></span>` : ''}</div>
            <div class="post-meta">${trainer.city || ''} · ${timeAgo}</div>
          </div>
          <span class="post-category">${catLabel}</span>
        </div>
        <div class="post-body">
          <div class="post-title">${post.title || ''}</div>
          <div class="post-excerpt">${(post.content || '').substring(0, 280)}${(post.content || '').length > 280 ? '...' : ''}</div>
          ${tags.length > 0 ? `<div class="post-tags">${tags.map(t => `<span class="post-tag">#${t}</span>`).join('')}</div>` : ''}
        </div>
        <div class="post-footer">
          <button class="post-action ${post.user_liked ? 'liked' : ''}" onclick="likePost('${post.id}', this)">
            <svg viewBox="0 0 24 24" fill="${post.user_liked ? 'currentColor' : 'none'}" stroke="currentColor" stroke-width="2"><path d="M20.84 4.61a5.5 5.5 0 00-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 00-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 000-7.78z"/></svg>
            ${post.like_count || 0}
          </button>
          <button class="post-action">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15a2 2 0 01-2 2H7l-4 4V5a2 2 0 012-2h14a2 2 0 012 2z"/></svg>
            ${post.comment_count || 0}
          </button>
          <a class="post-read-more" href="#">Read more →</a>
        </div>
      </div>
    `;
  }).join('');
}

function getTimeAgo(dateStr) {
  const diff = Date.now() - new Date(dateStr).getTime();
  const mins = Math.floor(diff / 60000);
  if (mins < 60) return `${mins}m ago`;
  const hrs = Math.floor(mins / 60);
  if (hrs < 24) return `${hrs}h ago`;
  const days = Math.floor(hrs / 24);
  if (days < 7) return `${days}d ago`;
  return new Date(dateStr).toLocaleDateString('en-AE', { day: 'numeric', month: 'short' });
}

async function likePost(postId, btn) {
  btn.classList.toggle('liked');
  const isLiked = btn.classList.contains('liked');
  const countEl = btn.childNodes[btn.childNodes.length - 1];
  const current = parseInt(countEl.textContent.trim()) || 0;
  countEl.textContent = ` ${isLiked ? current + 1 : Math.max(0, current - 1)}`;

  await fetch(`${SUPABASE_URL}/rest/v1/rpc/toggle_post_like`, {
    method: 'POST',
    headers: { 'apikey': SUPABASE_ANON, 'Authorization': `Bearer ${SUPABASE_ANON}`, 'Content-Type': 'application/json' },
    body: JSON.stringify({ p_post_id: postId })
  });
}

// Filter buttons
document.querySelectorAll('.filter-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    activeCategory = btn.dataset.cat;
    renderPosts(allPosts);
  });
});

// Search
document.getElementById('search-input').addEventListener('input', (e) => {
  const q = e.target.value.toLowerCase();
  if (!q) { renderPosts(allPosts); return; }
  const filtered = allPosts.filter(p =>
    (p.title || '').toLowerCase().includes(q) ||
    (p.content || '').toLowerCase().includes(q) ||
    (p.tags || []).some(t => t.toLowerCase().includes(q))
  );
  renderPosts(filtered);
});

// Modal
function openModal() { document.getElementById('post-modal').classList.add('open'); }
function closeModal() { document.getElementById('post-modal').classList.remove('open'); }
function selectCategory(el) {
  document.querySelectorAll('.category-option').forEach(o => o.classList.remove('selected'));
  el.classList.add('selected');
  selectedCategory = el.dataset.val;
}

async function submitPost() {
  const title = document.getElementById('post-title').value.trim();
  const content = document.getElementById('post-content').value.trim();
  const trainerId = document.getElementById('post-trainer-id').value.trim();
  const tagsRaw = document.getElementById('post-tags').value.trim();
  const tags = tagsRaw ? tagsRaw.split(',').map(t => t.trim().replace(/^#/, '')) : [];

  if (!title || !content || !trainerId) {
    alert('Please fill in title, content, and your trainer ID.');
    return;
  }

  const btn = document.getElementById('post-submit-btn');
  btn.disabled = true;
  btn.textContent = 'Publishing...';

  try {
    const res = await fetch(`${SUPABASE_URL}/rest/v1/community_posts`, {
      method: 'POST',
      headers: {
        'apikey': SUPABASE_ANON,
        'Authorization': `Bearer ${SUPABASE_ANON}`,
        'Content-Type': 'application/json',
        'Prefer': 'return=minimal'
      },
      body: JSON.stringify({ trainer_id: trainerId, title, content, category: selectedCategory, tags, status: 'pending' })
    });

    if (res.ok) {
      closeModal();
      alert('Post submitted for review! It will appear once approved.');
      document.getElementById('post-title').value = '';
      document.getElementById('post-content').value = '';
      document.getElementById('post-tags').value = '';
    } else {
      const err = await res.json();
      alert('Error: ' + (err.message || 'Could not submit post'));
    }
  } catch (e) {
    alert('Network error. Please try again.');
  } finally {
    btn.disabled = false;
    btn.textContent = 'Publish Post';
  }
}

// Close modal on overlay click
document.getElementById('post-modal').addEventListener('click', (e) => {
  if (e.target === e.currentTarget) closeModal();
});

loadPosts();
</script>
</Base>
