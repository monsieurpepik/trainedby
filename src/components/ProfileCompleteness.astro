---
/**
 * ProfileCompleteness - Gamified profile progress widget
 * ─────────────────────────────────────────────────────────────────────────────
 * Server-rendered when score + fields are passed as props (SSR path).
 * Falls back to empty (hidden) shell when score === 0 && fields.length === 0
 * so the client-side no-op window.renderPC can still be called safely.
 */

interface Props {
  score: number;
  fields: { key: string; label: string; pts: number; done: boolean; action: string }[];
  plan: string;
  slug: string;
}

const { score, fields, plan, slug } = Astro.props;

const ssrMode = !(score === 0 && fields.length === 0);

// Derived display values
const circumference = 113.1;
const dashoffset = circumference - (score / 100) * circumference;

const ringStroke =
  score === 100 ? '#00C853' :
  score >= 70   ? '#FF5C00' :
  score >= 50   ? '#22c55e' :
                  '#FF5C00';

const statusMsg =
  score < 50   ? 'Complete your profile to get discovered' :
  score < 70   ? "You're on your way — keep going" :
  score < 100  ? 'Almost there — looking great' :
                 'Perfect profile — share it!';

const showUpgradeNudge = score >= 70 && score < 100 && plan === 'free';
const showShare = score === 100;
---

{ssrMode ? (
  <div id="profile-completeness" class="pc-widget">
    <div class="pc-header">
      <div class="pc-ring-wrap">
        <svg class="pc-ring" viewBox="0 0 44 44" fill="none">
          <circle cx="22" cy="22" r="18" stroke="rgba(255,255,255,0.08)" stroke-width="4"/>
          <circle id="pc-ring-fill" cx="22" cy="22" r="18"
            stroke={ringStroke} stroke-width="4"
            stroke-linecap="round"
            stroke-dasharray="113.1"
            stroke-dashoffset={dashoffset}
            transform="rotate(-90 22 22)"
            style="transition: stroke-dashoffset 0.8s cubic-bezier(0.4,0,0.2,1)"/>
        </svg>
        <span id="pc-pct" class="pc-pct-label">{score}%</span>
      </div>
      <div class="pc-title-block">
        <div class="pc-title">Profile Strength</div>
        <div id="pc-status" class="pc-status">{statusMsg}</div>
      </div>
      <button class="pc-toggle" onclick="togglePCDetails()" aria-label="Toggle details">
        <svg id="pc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </button>
    </div>

    <div id="pc-details" class="pc-details hidden">
      <div id="pc-items" class="pc-items">
        {fields.map(field => (
          <a href={field.done ? '#' : field.action}
             class={`pc-item${field.done ? ' done' : ''}`}
             onclick={field.done ? 'event.preventDefault()' : undefined}>
            <div class="pc-check">
              <svg class="pc-check-icon" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3">
                <path d="M20 6L9 17l-5-5"/>
              </svg>
              <span class="pc-check-empty" style="width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,0.2)"></span>
            </div>
            <span class="pc-item-label">{field.label}</span>
            <span class="pc-item-pts">{field.done ? '✓' : `+${field.pts}pts`}</span>
          </a>
        ))}
      </div>

      {showUpgradeNudge && (
        <div class="pc-upgrade-nudge">
          <span class="pc-nudge-text">Upgrade to Pro to unlock digital product sales</span>
          <a href="/pricing" class="pc-nudge-btn">Upgrade →</a>
        </div>
      )}

      {showShare && (
        <button onclick="shareProfile()" class="pc-share-btn">Share your profile</button>
      )}
    </div>
  </div>
) : (
  <div id="profile-completeness" class="pc-widget hidden">
    <div class="pc-header">
      <div class="pc-ring-wrap">
        <svg class="pc-ring" viewBox="0 0 44 44" fill="none">
          <circle cx="22" cy="22" r="18" stroke="rgba(255,255,255,0.08)" stroke-width="4"/>
          <circle id="pc-ring-fill" cx="22" cy="22" r="18"
            stroke="#FF5C00" stroke-width="4"
            stroke-linecap="round"
            stroke-dasharray="113.1"
            stroke-dashoffset="113.1"
            transform="rotate(-90 22 22)"
            style="transition: stroke-dashoffset 0.8s cubic-bezier(0.4,0,0.2,1)"/>
        </svg>
        <span id="pc-pct" class="pc-pct-label">0%</span>
      </div>
      <div class="pc-title-block">
        <div class="pc-title">Profile Strength</div>
        <div id="pc-status" class="pc-status">Loading...</div>
      </div>
      <button class="pc-toggle" onclick="togglePCDetails()" aria-label="Toggle details">
        <svg id="pc-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M6 9l6 6 6-6"/>
        </svg>
      </button>
    </div>
    <div id="pc-details" class="pc-details hidden">
      <div id="pc-items" class="pc-items"></div>
      <div id="pc-upgrade-nudge" class="pc-upgrade-nudge hidden">
        <span class="pc-nudge-text">Upgrade to Pro to unlock digital product sales</span>
        <a href="/pricing" class="pc-nudge-btn">Upgrade →</a>
      </div>
    </div>
  </div>
)}

<style>
.pc-widget {
  background: #111;
  border: 1px solid rgba(255,255,255,0.08);
  border-radius: 16px;
  padding: 16px;
  margin-bottom: 16px;
}
.pc-widget.hidden { display: none; }
.pc-header {
  display: flex;
  align-items: center;
  gap: 14px;
}
.pc-ring-wrap {
  position: relative;
  width: 44px;
  height: 44px;
  flex-shrink: 0;
}
.pc-ring { width: 44px; height: 44px; }
.pc-pct-label {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  font-weight: 800;
  color: #FF5C00;
  font-family: 'Manrope', sans-serif;
}
.pc-title-block { flex: 1; }
.pc-title {
  font-size: 12px;
  font-weight: 700;
  color: rgba(255,255,255,0.9);
  margin-bottom: 2px;
}
.pc-status {
  font-size: 11px;
  color: rgba(255,255,255,0.4);
}
.pc-toggle {
  background: none;
  border: none;
  color: rgba(255,255,255,0.4);
  padding: 4px;
  cursor: pointer;
  transition: color 0.2s;
}
.pc-toggle:hover { color: rgba(255,255,255,0.8); }
.pc-details {
  margin-top: 14px;
  padding-top: 14px;
  border-top: 1px solid rgba(255,255,255,0.06);
}
.pc-details.hidden { display: none; }
.pc-items { display: flex; flex-direction: column; gap: 8px; }
.pc-item {
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 8px 10px;
  border-radius: 10px;
  background: rgba(255,255,255,0.03);
  cursor: pointer;
  transition: background 0.15s;
  text-decoration: none;
  color: inherit;
}
.pc-item:hover { background: rgba(255,255,255,0.06); }
.pc-item.done { opacity: 0.45; cursor: default; }
.pc-item.done:hover { background: rgba(255,255,255,0.03); }
.pc-check {
  width: 20px;
  height: 20px;
  border-radius: 50%;
  border: 2px solid rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  transition: all 0.2s;
}
.pc-item.done .pc-check {
  background: #00C853;
  border-color: #00C853;
}
.pc-check-icon { display: none; }
.pc-item.done .pc-check-icon { display: block; }
.pc-check-empty { display: block; }
.pc-item.done .pc-check-empty { display: none; }
.pc-item-label {
  font-size: 12px;
  font-weight: 600;
  flex: 1;
}
.pc-item-pts {
  font-size: 10px;
  font-weight: 700;
  color: #FF5C00;
  background: rgba(255,92,0,0.1);
  border: 1px solid rgba(255,92,0,0.2);
  padding: 2px 6px;
  border-radius: 6px;
}
.pc-item.done .pc-item-pts {
  color: #00C853;
  background: rgba(0,200,83,0.08);
  border-color: rgba(0,200,83,0.2);
}
.pc-upgrade-nudge {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
  margin-top: 12px;
  padding: 10px 12px;
  background: rgba(255,92,0,0.08);
  border: 1px solid rgba(255,92,0,0.2);
  border-radius: 10px;
}
.pc-upgrade-nudge.hidden { display: none; }
.pc-nudge-text { font-size: 11px; color: rgba(255,255,255,0.6); }
.pc-nudge-btn {
  font-size: 11px;
  font-weight: 700;
  color: #FF5C00;
  text-decoration: none;
  white-space: nowrap;
}
.pc-share-btn {
  margin-top: 12px;
  width: 100%;
  padding: 10px;
  background: rgba(0,200,83,0.1);
  border: 1px solid rgba(0,200,83,0.25);
  border-radius: 10px;
  color: #00C853;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
}
.pc-share-btn:hover { background: rgba(0,200,83,0.18); }
</style>

<script is:inline define:vars={{ slug }}>
function togglePCDetails() {
  const details = document.getElementById('pc-details');
  const chevron = document.getElementById('pc-chevron');
  if (!details) return;
  const isHidden = details.classList.toggle('hidden');
  if (chevron) {
    chevron.style.transform = isHidden ? '' : 'rotate(180deg)';
  }
}

function shareProfile() {
  const url = window.location.origin + '/' + slug;
  if (navigator.share) {
    navigator.share({ title: 'My TrainedBy Profile', url });
  } else {
    navigator.clipboard?.writeText(url).catch(() => {});
  }
}
</script>
