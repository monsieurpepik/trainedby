---
interface Props {
  variant?: 'landing' | 'app' | 'consumer' | 'minimal';
  activePage?: string;
}
const { variant = 'landing', activePage = '' } = Astro.props;
---

{variant === 'minimal' ? (
  <header class="minimal-header">
    <a href="/" class="nav-logo" aria-label="Home">
      <span style="font-family:'DM Sans',sans-serif;font-weight:900;font-size:20px;text-decoration:none;color:var(--text);">
        Trained<span style="color:var(--brand)">By</span><span
          style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--brand);margin-left:2px;vertical-align:middle;margin-bottom:3px"
        ></span>
      </span>
    </a>
  </header>
) : variant === 'consumer' ? (
  <!-- Consumer homepage nav: Find a Trainer focus -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo" data-brand-name>
      <span>Trained<span style="color:#fff">By</span></span><span
        style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--brand);margin-left:2px;vertical-align:middle;margin-bottom:3px"
      ></span>
    </a>
    <div class="nav-links">
      <a href="/find" data-i18n="nav_find">Find a Trainer</a>
      <a href="/blog" data-i18n="nav_blog">Stories</a>
      <a href="/community" data-i18n="nav_community">Community</a>
      <a href="/for-trainers" class="nav-for-trainers" data-i18n="nav_for_trainers">For Trainers</a>
    </div>
    <a href="/find" class="nav-cta" data-i18n="nav_cta_find">Find Your Trainer →</a>
  </nav>
) : variant === 'landing' ? (
  <!-- For-trainers / SaaS nav -->
  <nav class="nav" id="nav">
    <a href="/" class="nav-logo" data-brand-name>
      <span>Trained<span style="color:#fff">By</span></span><span
        style="display:inline-block;width:6px;height:6px;border-radius:50%;background:var(--brand);margin-left:2px;vertical-align:middle;margin-bottom:3px"
      ></span>
    </a>
    <div class="nav-links">
      <a href="/find" data-i18n="nav_find">Find a Trainer</a>
      <a href="/blog" data-i18n="nav_blog">Stories</a>
      <a href="/community" data-i18n="nav_community">Community</a>
      <a href="/for-trainers" class="nav-for-trainers" data-i18n="nav_for_trainers">For Trainers</a>
    </div>
    <a href="/join" class="nav-cta" data-i18n="nav.get_os">Create your profile →</a>
  </nav>
) : (
  <header class="app-header">
    <a href="/" class="nav-logo" style="font-family:'DM Sans',sans-serif;font-weight:900;font-size:18px;color:var(--brand);text-decoration:none;">
      <span data-brand-name>Trained<span style="color:#fff">By</span></span>
    </a>
    <div class="header-nav">
      <a href="/edit" class={`nav-edit${activePage === 'edit' ? ' active' : ''}`}>Edit</a>
      <a id="view-link" href="#" class={`nav-view${activePage === 'profile' ? ' active' : ''}`}>View Profile</a>
    </div>
  </header>
)}

<style>
  .nav-for-trainers { color: var(--brand) !important; font-weight: 700 !important; }
  .nav-for-trainers:hover { opacity: 0.8; }
  .minimal-header {
    padding: 16px 24px;
    display: flex;
    align-items: center;
    border-bottom: 1px solid var(--border);
  }
</style>

<script>
  const nav = document.getElementById('nav');
  if (nav) {
    window.addEventListener('scroll', () => {
      nav.classList.toggle('scrolled', window.scrollY > 20);
    }, { passive: true });
  }
</script>
