{
  "name": "trainedby-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i landing-input.css -o landing-output.css --minify",
    "build:js": "esbuild js/init.js --bundle --splitting --format=esm --outdir=dist --minify --tree-shaking=true",
    "build:styles": "esbuild styles.css --bundle --minify --outfile=dist/styles.min.css",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "clean": "rm -rf dist/*.js dist/chunks dist/*.css",
    "test": "jest --testPathPattern=tests/ --testEnvironment=node --forceExit",
    "test:watch": "jest --testPathPattern=tests/ --testEnvironment=node --watch",
    "test:ci": "jest --testPathPattern=tests/ --testEnvironment=node --forceExit --ci --coverage"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "testTimeout": 15000,
    "verbose": true
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "esbuild": "^0.20.2",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "tailwindcss": "^3.4.3"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "astro": "^6.1.6"
  }
}
