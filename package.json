{
  "name": "trainedby-app",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i landing-input.css -o landing-output.css --minify",
    "build:js": "esbuild js/init.js --bundle --splitting --format=esm --outdir=dist --minify --tree-shaking=true",
    "build:styles": "esbuild styles.css --bundle --minify --outfile=dist/styles.min.css",
    "build": "npm run build:css && npm run build:js && npm run build:styles",
    "clean": "rm -rf dist/*.js dist/chunks dist/*.css"
  },
  "devDependencies": {
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "esbuild": "^0.20.2",
    "tailwindcss": "^3.4.3"
  }
}
