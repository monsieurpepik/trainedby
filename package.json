{
  "name": "trainedby-app",
  "version": "1.3.0",
  "private": true,
  "scripts": {
    "build:css": "tailwindcss -i landing-input.css -o landing-output.css --minify",
    "build:js": "esbuild js/init.js --bundle --splitting --format=esm --outdir=dist --minify --tree-shaking=true",
    "build:styles": "esbuild styles.css --bundle --minify --outfile=dist/styles.min.css",
    "build": "astro build",
    "dev": "astro dev",
    "preview": "astro preview",
    "clean": "rm -rf dist/*.js dist/chunks dist/*.css",
    "test": "jest --testPathPatterns=tests/ --testEnvironment=node --forceExit",
    "test:watch": "jest --testPathPatterns=tests/ --testEnvironment=node --watch",
    "test:ci": "jest --testPathPatterns=tests/ --testEnvironment=node --forceExit --ci --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:all": "pnpm test && pnpm test:e2e"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "testTimeout": 15000,
    "verbose": true
  },
  "devDependencies": {
    "@jest/globals": "^30.3.0",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/forms": "^0.5.7",
    "@tailwindcss/typography": "^0.5.13",
    "esbuild": "^0.20.2",
    "jest": "^30.3.0",
    "jest-environment-node": "^30.3.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.3"
  },
  "dependencies": {
    "@astrojs/netlify": "^7.0.6",
    "@astrojs/sitemap": "^3.7.2",
    "@astrojs/tailwind": "^6.0.2",
    "@resvg/resvg-wasm": "^2.6.2",
    "@sentry/astro": "^10.51.0",
    "@supabase/supabase-js": "^2.105.1",
    "astro": "^6.1.6",
    "satori": "^0.26.0"
  }
}
